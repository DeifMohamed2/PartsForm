# ===========================================
# PARTSFORM Environment Configuration
# Copy this file to .env and update values
# ===========================================

# Server Configuration
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
HOST=localhost

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/partsform

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Admin JWT (separate for admin auth)
ADMIN_JWT_SECRET=your-admin-jwt-secret-key
ADMIN_SESSION_EXPIRY=8h

# Elasticsearch
ELASTICSEARCH_HOST=http://localhost:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme

# Redis Cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=optional-password

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# Email Configuration (IMAP/SMTP for inquiry processing)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=your-email@gmail.com
EMAIL_IMAP_PASSWORD=your-app-password
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_PROCESSING_ENABLED=true

# ===========================================
# SUPPLIER DATA PORTAL - FTP Configuration
# ===========================================

# Enable/Disable built-in FTP server
ENABLE_FTP_SERVER=false

# FTP Server Settings
FTP_HOST=0.0.0.0
FTP_PORT=2121
FTP_PUBLIC_HOST=ftp.yourdomain.com

# Passive Mode Port Range (for NAT/firewall)
FTP_PASV_MIN=10000
FTP_PASV_MAX=10100

# Base directory for supplier uploads
FTP_BASE_DIR=./ftp-uploads

# TLS/FTPS Configuration (recommended for production)
FTP_TLS=false
# FTP_TLS_KEY=/path/to/private.key
# FTP_TLS_CERT=/path/to/certificate.crt

# External FTP Server (if using system FTP like vsftpd)
FTP_SERVER_HOST=ftp.yourdomain.com
FTP_SERVER_PORT=21
FTP_BASE_DIRECTORY=/var/ftp/suppliers

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_MAX_FILES=14d
