<%- include('partials/header') %>
<link rel="stylesheet" href="/css/buyerCSS/buyer-main.css">
<link rel="stylesheet" href="/css/buyerCSS/claim-details.css">

<%- include('partials/navbar') %>

<!-- ====================================
     CLAIM DETAILS PAGE - CHAT INTERFACE
     ==================================== -->
<div class="claim-details-page" data-claim-id="<%= claim ? claim._id : '' %>">
  <!-- Header Bar -->
  <div class="claim-details-header-bar">
    <div class="container">
      <div class="claim-details-header-content">
        <div class="claim-details-header-left">
          <h1 class="claim-details-header-title">Claim Support</h1>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="claim-details-content">
    <div class="container">
      <div class="claim-details-section">
        <div class="claim-details-container">
          <!-- Back Button -->
          <a href="/buyer/claim-support" class="btn-back">
            <i data-lucide="arrow-left"></i>
            <span>Back to Claims</span>
          </a>

          <div class="claim-details-grid">
            <!-- Claim Info Card -->
            <div class="claim-info-card">
              <div class="info-card-header">
                <h3 class="info-card-title">
                  <%= t('tickets.details.ticketInfo') %>
                </h3>
              </div>
              <div class="info-card-body">
                <div class="info-item">
                  <span class="info-label">Ticket ID</span>
                  <span class="info-value ticket-id" id="claim-id-header">TKT-001</span>
                </div>
                <div class="info-item">
                  <span class="info-label">Subject</span>
                  <span class="info-value" id="claim-subject-header"><%= t('tickets.details.loading') %></span>
                </div>
                <div class="info-item">
                  <span class="info-label"><%= t('tickets.details.category') %></span>
                  <span class="info-value" id="claim-category">
                    <i data-lucide="tag"></i>
                    <span><%= t('tickets.categories.shipping') %></span>
                  </span>
                </div>
                <div class="info-item">
                  <span class="info-label"><%= t('tickets.details.status') %></span>
                  <span class="info-value" id="claim-status-info">
                    <span class="status-badge-small" id="status-badge-small"><%= t('tickets.status') %></span>
                  </span>
                </div>
                <div class="info-item">
                  <span class="info-label">Order Number</span>
                  <span class="info-value" id="claim-order-header">
                    <i data-lucide="package"></i>
                    <span>ORD-2025-001</span>
                  </span>
                </div>
                <div class="info-item">
                  <span class="info-label">Created</span>
                  <span class="info-value" id="claim-created-header">
                    <i data-lucide="calendar"></i>
                    <span>Dec 20, 2025</span>
                  </span>
                </div>
                <div class="info-item">
                  <span class="info-label"><%= t('tickets.details.lastUpdated') %></span>
                  <span class="info-value" id="claim-updated">2 hours ago</span>
                </div>
              </div>
            </div>

            <!-- Chat Messages -->
            <div class="chat-container">
              <div class="chat-header">
                <div class="chat-header-icon">
                  <i data-lucide="message-circle"></i>
                </div>
                <div class="chat-header-text">
                  <h3 class="chat-title">
                    <%= t('tickets.details.conversation') %>
                  </h3>
                </div>
              </div>

              <div class="chat-messages" id="chat-messages">
              </div>

              <div class="chat-input-container">
                <form id="chat-form" class="chat-form">
                  <div class="chat-input-wrapper">
                    <textarea id="message-input" class="chat-input" placeholder="<%= t('tickets.details.typePlaceholder') %>" rows="1"></textarea>
                    <button type="button" class="btn-attach" id="btn-attach">
                      <i data-lucide="paperclip"></i>
                    </button>
                    <input type="file" id="file-input" multiple hidden>
                  </div>
                  <button type="submit" class="btn-send">
                    <i data-lucide="send"></i>
                    <span><%= t('tickets.details.send') %></span>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/quick-search') %>
<%- include('partials/footer') %>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/main.js"></script>
<script src="/js/quick-search.js"></script>
<script src="/js/cart.js"></script>
<script src="/js/claim-details.js"></script>
<script>
  lucide.createIcons();
  window.addEventListener('load', () => lucide.createIcons());
  
  document.addEventListener('DOMContentLoaded', () => {
    const navbar = document.getElementById('navbar');
    if (navbar) {
      navbar.classList.add('scrolled');
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
            if (!navbar.classList.contains('scrolled')) {
              navbar.classList.add('scrolled');
            }
          }
        });
      });
      observer.observe(navbar, { attributes: true, attributeFilter: ['class'] });
      const ensureScrolled = () => navbar.classList.add('scrolled');
      window.addEventListener('scroll', ensureScrolled, { passive: true });
    }
  });
</script>