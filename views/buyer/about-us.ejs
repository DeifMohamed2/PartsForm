<%- include('partials/header') %>
    <link rel="stylesheet" href="/css/buyerCSS/buyer-main.css">
    <link rel="stylesheet" href="/css/buyerCSS/about-us.css">

    <%- include('partials/navbar') %>

        <!-- ====================================
    ABOUT US PAGE - PROFESSIONAL DESIGN
    Branding: Kurogane + Kintsugi Gold
    ==================================== -->
        <div class="aboutus-page">
            <div class="aboutus-main-content">
                <!-- Hero Section with Stats Banner -->
                <section class="aboutus-hero">
                    <!-- Hero Background Overlay -->
                    <div class="hero-bg-overlay"></div>

                    <!-- Tagline Top Right -->
                    <div class="hero-tagline-aboutus">
                        <span class="tagline-top">Engineered for Business.</span>
                        <span class="tagline-bottom">Powered by Intelligence.</span>
                    </div>

                <!-- Stats Ticker Banner -->
                <div class="stats-banner">
                    <!-- Stats grid -->
                    <div class="stats-container" id="statsContainer">
                        <div class="stat-item">
                            <div class="stat-number" id="stat-num-0">50M+</div>
                            <div class="stat-label" id="stat-lbl-0">Components<br>Indexed</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number" id="stat-num-1">$2.8B</div>
                            <div class="stat-label" id="stat-lbl-1">Transactions<br>Secured</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number" id="stat-num-2">2,400+</div>
                            <div class="stat-label" id="stat-lbl-2">Verified<br>Suppliers</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number" id="stat-num-3">40+</div>
                            <div class="stat-label" id="stat-lbl-3">Countries<br>Connected</div>
                        </div>
                        <div class="stat-divider"></div>
                    </div>
                </div>

                <script>
                (function () {
                    var slides = [
                        [
                            { num: '50M+',    lbl: 'Components\nIndexed' },
                            { num: '$2.8B',   lbl: 'Transactions\nSecured' },
                            { num: '2,400+',  lbl: 'Verified\nSuppliers' },
                            { num: '40+',     lbl: 'Countries\nConnected' }
                        ],
                        [
                            { num: '1.2M+',   lbl: 'Active\nSKUs Live' },
                            { num: '$480M',   lbl: 'Annual\nProcurement' },
                            { num: '97%',     lbl: 'Supplier\nRating' },
                            { num: '72h',     lbl: 'Max Delivery\nTime' }
                        ],
                        [
                            { num: '98.7%',   lbl: 'Search\nAccuracy' },
                            { num: '850+',    lbl: 'New Suppliers\nPer Year' },
                            { num: '120+',    lbl: 'Cities\nReached' },
                            { num: '24/7',    lbl: 'Global\nSupport' }
                        ],
                        [
                            { num: '180+',    lbl: 'Part\nCategories' },
                            { num: '<24h',    lbl: 'Average\nFulfillment' },
                            { num: '15+',     lbl: 'Industries\nServed' },
                            { num: '4.9',    lbl: 'Platform\nRating' }
                        ]
                    ];

                    var DURATION = 5000;
                    var current = 0;
                    var startTime = null;
                    var rafId = null;

                    function setSlide(idx, animate) {
                        var s = slides[idx];
                        for (var i = 0; i < 4; i++) {
                            var numEl = document.getElementById('stat-num-' + i);
                            var lblEl = document.getElementById('stat-lbl-' + i);
                            if (!numEl || !lblEl) continue;
                            if (animate) {
                                numEl.classList.add('stat-exit');
                                lblEl.classList.add('stat-exit');
                                (function (n, l, si, ii) {
                                    setTimeout(function () {
                                        n.textContent = si[ii].num;
                                        l.innerHTML = si[ii].lbl.replace('\n', '<br>');
                                        n.classList.remove('stat-exit');
                                        l.classList.remove('stat-exit');
                                        n.classList.add('stat-enter');
                                        l.classList.add('stat-enter');
                                        setTimeout(function () {
                                            n.classList.remove('stat-enter');
                                            l.classList.remove('stat-enter');
                                        }, 500);
                                    }, 260);
                                })(numEl, lblEl, s, i);
                            } else {
                                numEl.textContent = s[i].num;
                                lblEl.innerHTML = s[i].lbl.replace('\n', '<br>');
                            }
                        }
                    }

                    function tick(ts) {
                        if (!startTime) startTime = ts;
                        var elapsed = ts - startTime;
                        if (elapsed >= DURATION) {
                            current = (current + 1) % slides.length;
                            setSlide(current, true);
                            startTime = ts;
                        }
                        rafId = requestAnimationFrame(tick);
                    }

                    // Start automatically
                    setSlide(0, false);
                    rafId = requestAnimationFrame(tick);
                })();
                </script>
                </section>

                <!-- Large Banner Section -->
                <section class="large-banner-section">
                    <div class="banner-image-side">
                        <div class="banner-overlay-gradient"></div>
                        <div class="banner-badge-bottom">
                            <img src="/images/brand/icon-gold.svg" alt="PartsForm Icon" class="badge-icon-img">
                        </div>
                    </div>
                    <div class="banner-content-side">
                        <h2 class="banner-title">OVER 1.2 MILLION<br>ACTIVE SKUS</h2>
                        <p class="banner-subtitle">With <strong>Real-Time Stock</strong> Verification.</p>
                    </div>
                </section>

                <!-- Gateway Section -->
                <section class="gateway-section">
                    <div class="gateway-container">
                        <div class="gateway-content">
                            <h2 class="gateway-title">YOUR GATEWAY TO INTELLIGENT<br>GLOBAL PARTS SUPPLY.</h2>
                            <p class="gateway-description">
                                Built on precision and operational discipline, our platform connects verified suppliers and strategic buyers through digitally authenticated procurement, structured protocols, and exact delivery standards. Every component is sourced, validated, and executed
                                with engineered accuracy — eliminating friction, reducing risk, and maximizing commercial performance.
                            </p>
                        </div>
                        <div class="gateway-cta">
                            <div class="cta-box">
                                <p class="cta-text">
                                    Join our network of partners and suppliers to access structured data and demand, precision-verified logistics, and long-term scalable growth.
                                </p>
                                <a href="/partner/register" class="btn-become-partner">BECOME A PARTNER</a>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <%- include('partials/footer') %>