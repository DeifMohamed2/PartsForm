<%- include('partials/header') %>
    <link rel="stylesheet" href="/css/buyerCSS/buyer-main.css">
    <link rel="stylesheet" href="/css/buyerCSS/about-us.css">

    <%- include('partials/navbar') %>

        <!-- ====================================
    ABOUT US PAGE - PROFESSIONAL DESIGN
    Branding: Kurogane + Kintsugi Gold
    ==================================== -->
        <div class="aboutus-page">
            <div class="aboutus-main-content">
                <!-- Hero Section with Stats Banner -->
                <section class="aboutus-hero">
                    <!-- Hero Background Overlay -->
                    <div class="hero-bg-overlay"></div>

                    <!-- Tagline Top Right -->
                    <div class="hero-tagline-aboutus">
                        <span class="tagline-top">Engineered for Business.</span>
                        <span class="tagline-bottom">Powered by Intelligence.</span>
                    </div>

                    <!-- Stats Banner -->
                    <div class="stats-banner">
                        <div class="stats-container">
                            <div class="stat-item">
                                <div class="stat-number">50M+</div>
                                <div class="stat-label">Components<br>Indexed</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">$2.8B</div>
                                <div class="stat-label">Transactions<br>Secured</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">2,400+</div>
                                <div class="stat-label">Verified<br>Suppliers</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">40+</div>
                                <div class="stat-label">Countries<br>Connected</div>
                            </div>
                            <div class="stat-divider"></div>
                        </div>
                    </div>
                </section>

                <!-- Large Banner Section -->
                <section class="large-banner-section">
                    <div class="banner-overlay-gradient"></div>
                    <div class="banner-content">
                        <div class="banner-badge">
                            <div class="badge-icon">⊕</div>
                        </div>
                        <h2 class="banner-title">OVER 1.2 MILLION<br>ACTIVE SKUS</h2>
                        <p class="banner-subtitle">With Real-Time Stock Verification.</p>
                    </div>
                    <div class="banner-badge-bottom">
                        <div class="badge-icon">⊕</div>
                    </div>
                </section>

                <!-- Gateway Section -->
                <section class="gateway-section">
                    <div class="gateway-container">
                        <div class="gateway-content">
                            <h2 class="gateway-title">YOUR GATEWAY TO INTELLIGENT<br>GLOBAL PARTS SUPPLY.</h2>
                            <p class="gateway-description">
                                Built on precision and operational discipline, our platform connects verified suppliers and strategic buyers through digitally authenticated procurement, structured protocols, and exact delivery standards. Every component is sourced, validated, and executed with engineered accuracy —
                                eliminating friction, reducing risk, and maximizing commercial performance.
                            </p>
                        </div>
                        <div class="gateway-cta">
                            <div class="cta-box">
                                <p class="cta-text">
                                    Join our network of partners and suppliers to access structured data and demand, precision-verified logistics, and long-term scalable growth.
                                </p>
                                <a href="/partner/register" class="btn-become-partner">BECOME A PARTNER</a>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <%- include('partials/footer') %>
