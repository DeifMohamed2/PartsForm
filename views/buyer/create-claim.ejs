<%- include('partials/header') %>
<link rel="stylesheet" href="/css/buyerCSS/buyer-main.css">
<link rel="stylesheet" href="/css/buyerCSS/create-claim.css">

<%- include('partials/navbar') %>

<!-- ====================================
     CREATE CLAIM PAGE - PROFESSIONAL DESIGN
     ==================================== -->
<div class="create-claim-page">
  <!-- Hero Section -->
  <div class="create-claim-hero">
    <div class="create-claim-hero-content">
      <div class="hero-badge">
        <i data-lucide="life-buoy"></i>
        <span>Claim Support</span>
      </div>

      <h1 class="create-claim-hero-title">Create New Claim</h1>
      <p class="create-claim-hero-subtitle">
        Submit a claim for any issues with your orders or inquiries
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="buyer-container">
    <div class="create-claim-section">
      <div class="create-claim-container">
        <!-- Back Button -->
        <a href="/buyer/claim-support" class="btn-back">
          <i data-lucide="arrow-left"></i>
          <span>Back to Claims</span>
        </a>

        <!-- Form Card -->
        <div class="create-claim-card">
          <div class="card-header">
            <h2 class="card-title">Claim Details</h2>
            <p class="card-subtitle">Provide details about your claim and we'll assist you</p>
          </div>

          <form id="create-claim-form" class="claim-form">
            <!-- Category (First to determine if order is needed) -->
            <div class="form-group">
              <label for="category" class="form-label">
                <i data-lucide="tag"></i>
                <span><%= t('tickets.create.category') %></span>
                <span class="required"><%= t('tickets.create.required') %></span>
              </label>
              <select id="category" name="category" class="form-select" required>
                <option value=""><%= t('tickets.create.selectCategoryPlaceholder') %></option>
                <option value="Shipping Issue"><%= t('tickets.categories.shipping') %></option>
                <option value="Order Issue"><%= t('tickets.categories.order') %></option>
                <option value="Product Inquiry"><%= t('tickets.categories.product') %></option>
                <option value="Payment"><%= t('tickets.categories.payment') %></option>
                <option value="Documentation"><%= t('tickets.categories.documentation') %></option>
                <option value="Technical Issue"><%= t('tickets.categories.technical') %></option>
                <option value="General"><%= t('tickets.categories.other') %></option>
              </select>
              <span class="form-hint"><%= t('tickets.create.categoryHint') %></span>
            </div>

            <!-- Order Number (Optional - shown for order-related categories) -->
            <div class="form-group" id="order-group">
              <label for="order-number" class="form-label">
                <i data-lucide="package"></i>
                <span><%= t('tickets.create.relatedOrder') %></span>
                <span class="optional"><%= t('tickets.create.optional') %></span>
              </label>
              <select 
                id="order-number" 
                name="orderNumber" 
                class="form-select"
              >
                <option value=""><%= t('tickets.create.noSpecificOrder') %></option>
                <% if (typeof orders !== 'undefined' && orders && orders.length > 0) { %>
                  <% orders.forEach(function(order) { %>
                    <option value="<%= order.orderNumber %>">
                      <%= order.orderNumber %> - <%= order.status ? order.status.charAt(0).toUpperCase() + order.status.slice(1) : 'N/A' %> - <%= new Date(order.createdAt).toLocaleDateString() %>
                    </option>
                  <% }); %>
                <% } %>
              </select>
              <span class="form-hint"><%= t('tickets.create.orderHint') %></span>
              <% if (typeof orders !== 'undefined' && orders && orders.length === 0) { %>
              <span class="form-hint form-hint-info"><%= t('tickets.create.noOrdersHint') || 'Orders with active claims are not listed. You can submit a general inquiry without selecting an order.' %></span>
              <% } %>
            </div>

            <!-- Subject -->
            <div class="form-group">
              <label for="subject" class="form-label">
                <i data-lucide="type"></i>
                <span><%= t('tickets.create.subject') %></span>
                <span class="required"><%= t('tickets.create.required') %></span>
              </label>
              <input 
                type="text" 
                id="subject" 
                name="subject" 
                class="form-input" 
                placeholder="<%= t('tickets.create.subjectPlaceholder') %>"
                required
              >
              <span class="form-hint"><%= t('tickets.create.subjectHint') %></span>
            </div>

            <!-- Description -->
            <div class="form-group">
              <label for="description" class="form-label">
                <i data-lucide="file-text"></i>
                <span><%= t('tickets.create.description') %></span>
                <span class="required"><%= t('tickets.create.required') %></span>
              </label>
              <textarea 
                id="description" 
                name="description" 
                class="form-textarea" 
                rows="6"
                placeholder="<%= t('tickets.create.descriptionPlaceholder') %>"
                required
              ></textarea>
              <span class="form-hint"><%= t('tickets.create.descriptionHint') %></span>
            </div>

            <!-- File Attachments -->
            <div class="form-group">
              <label for="attachments" class="form-label">
                <i data-lucide="paperclip"></i>
                <span><%= t('tickets.create.attachmentsLabel') %></span>
                <span class="optional"><%= t('tickets.create.optional') %></span>
              </label>
              <div class="file-upload-area" id="file-upload-area">
                <input 
                  type="file" 
                  id="attachments" 
                  name="attachments" 
                  multiple 
                  accept="image/*,.pdf,.doc,.docx"
                  hidden
                >
                <div class="file-upload-content">
                  <div class="file-upload-icon">
                    <i data-lucide="upload-cloud"></i>
                  </div>
                  <p class="file-upload-text">
                    <strong><%= t('tickets.create.clickToUpload') %></strong> <%= t('tickets.create.orDragDrop') %>
                  </p>
                  <p class="file-upload-hint">
                    <%= t('tickets.create.fileTypes') %>
                  </p>
                </div>
              </div>
              <div class="file-list" id="file-list"></div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
              <button type="button" class="btn-cancel" onclick="window.location.href='/buyer/claim-support'">
                <i data-lucide="x"></i>
                <span>Cancel</span>
              </button>
              <button type="submit" class="btn-submit">
                <i data-lucide="send"></i>
                <span>Submit Claim</span>
              </button>
            </div>
          </form>
        </div>

        <!-- Help Card -->
        <div class="help-card">
          <div class="help-icon">
            <i data-lucide="info"></i>
          </div>
          <div class="help-content">
            <h3 class="help-title"><%= t('tickets.create.helpTitle') %></h3>
            <p class="help-text">
              <%= t('tickets.create.helpText') %>
            </p>
            <div class="help-contacts">
              <a href="mailto:support@partsform.com" class="help-contact">
                <i data-lucide="mail"></i>
                <span>support@partsform.com</span>
              </a>
              <a href="tel:+971-4-123-4567" class="help-contact">
                <i data-lucide="phone"></i>
                <span>+971 4 123 4567</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/quick-search') %>
<%- include('partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/main.js"></script>
<script src="/js/quick-search.js"></script>
<script src="/js/cart.js"></script>
<script src="/js/cart-badge-updater.js"></script>
<script>
  lucide.createIcons();
  window.addEventListener('load', () => lucide.createIcons());
  
  // Pre-populate order from URL parameter
  const urlParams = new URLSearchParams(window.location.search);
  const orderParam = urlParams.get('order');
  if (orderParam) {
    const orderSelect = document.getElementById('order-number');
    if (orderSelect) {
      orderSelect.value = orderParam;
    }
  }
  
  // Categories that typically require an order
  const orderRelatedCategories = ['Shipping Issue', 'Order Issue', 'Payment', 'Return Request'];
  
  // Handle category change to show/hide order field hint
  const categorySelect = document.getElementById('category');
  const orderGroup = document.getElementById('order-group');
  const orderSelect = document.getElementById('order-number');
  
  categorySelect.addEventListener('change', () => {
    const category = categorySelect.value;
    if (orderRelatedCategories.includes(category)) {
      orderGroup.classList.add('order-recommended');
      orderGroup.querySelector('.form-hint').textContent = 'Recommended: Select the related order for faster resolution';
    } else {
      orderGroup.classList.remove('order-recommended');
      orderGroup.querySelector('.form-hint').textContent = 'Select an order if this issue is related to a specific order';
    }
  });
  
  // Force navbar to always stay white
  document.addEventListener('DOMContentLoaded', () => {
    const navbar = document.getElementById('navbar');
    if (navbar) {
      navbar.classList.add('scrolled');
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
            if (!navbar.classList.contains('scrolled')) {
              navbar.classList.add('scrolled');
            }
          }
        });
      });
      observer.observe(navbar, { attributes: true, attributeFilter: ['class'] });
      const ensureScrolled = () => navbar.classList.add('scrolled');
      window.addEventListener('scroll', ensureScrolled, { passive: true });
    }
  });

  // File upload handling
  const fileUploadArea = document.getElementById('file-upload-area');
  const fileInput = document.getElementById('attachments');
  const fileList = document.getElementById('file-list');
  let selectedFiles = [];

  fileUploadArea.addEventListener('click', () => fileInput.click());

  fileUploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    fileUploadArea.classList.add('drag-over');
  });

  fileUploadArea.addEventListener('dragleave', () => {
    fileUploadArea.classList.remove('drag-over');
  });

  fileUploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    fileUploadArea.classList.remove('drag-over');
    handleFiles(e.dataTransfer.files);
  });

  fileInput.addEventListener('change', (e) => {
    handleFiles(e.target.files);
  });

  function handleFiles(files) {
    selectedFiles = Array.from(files);
    renderFileList();
    lucide.createIcons();
  }

  function renderFileList() {
    if (selectedFiles.length === 0) {
      fileList.innerHTML = '';
      return;
    }

    fileList.innerHTML = selectedFiles.map((file, index) => `
      <div class="file-item">
        <div class="file-info">
          <i data-lucide="file"></i>
          <span class="file-name">${file.name}</span>
          <span class="file-size">${formatFileSize(file.size)}</span>
        </div>
        <button type="button" class="file-remove" onclick="removeFile(${index})">
          <i data-lucide="x"></i>
        </button>
      </div>
    `).join('');
  }

  function removeFile(index) {
    selectedFiles.splice(index, 1);
    renderFileList();
    lucide.createIcons();
  }

  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
  }

  // Form submission
  document.getElementById('create-claim-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = e.target.querySelector('.btn-submit');
    const originalBtnText = submitBtn.innerHTML;
    
    // Disable button and show loading
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i data-lucide="loader-2" class="spin"></i><span>Creating...</span>';
    lucide.createIcons();
    
    try {
      const formData = new FormData();
      formData.append('orderNumber', document.getElementById('order-number').value);
      formData.append('subject', document.getElementById('subject').value);
      formData.append('category', document.getElementById('category').value);
      formData.append('description', document.getElementById('description').value);
      
      // Add all selected files
      selectedFiles.forEach(file => {
        formData.append('attachments', file);
      });

      const response = await fetch('/buyer/api/claims', {
        method: 'POST',
        body: formData
      });
      
      const data = await response.json();
      
      if (data.success) {
        await Swal.fire({
          icon: 'success',
          title: 'Claim Created',
          html: '<p style="font-family: \'Antartida\', sans-serif; color: #8E9CA6; font-size: 0.95rem;">Your claim has been submitted successfully. Our support team will review it shortly.</p>',
          confirmButtonText: 'View Claim',
          confirmButtonColor: '#D4AF37',
          customClass: {
            popup: 'swal-claim-popup',
            title: 'swal-claim-title',
            confirmButton: 'swal-claim-btn'
          }
        });
        window.location.href = '/buyer/claim-support/' + data.claim.id;
      } else {
        const errorMsg = data.error || data.message || 'Failed to create claim. Please try again.';
        const hasClaimId = data.claimId;
        await Swal.fire({
          icon: 'error',
          title: hasClaimId ? 'Order Already Has Claim' : 'Submission Failed',
          text: errorMsg,
          confirmButtonText: hasClaimId ? 'View Existing Claim' : 'OK',
          confirmButtonColor: hasClaimId ? '#D4AF37' : '#40545E'
        });
        if (hasClaimId) {
          window.location.href = '/buyer/claim-support/' + data.claimId;
          return;
        }
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnText;
        lucide.createIcons();
      }
    } catch (error) {
      console.error('Error creating claim:', error);
      await Swal.fire({
        icon: 'error',
        title: 'Something Went Wrong',
        text: 'An error occurred. Please try again.',
        confirmButtonText: 'OK',
        confirmButtonColor: '#40545E'
      });
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalBtnText;
      lucide.createIcons();
    }
  });
</script>
