<%- include('partials/header') %>
    <link rel="stylesheet" href="/css/buyerCSS/buyer-main.css">
    <link rel="stylesheet" href="/css/buyerCSS/search2.css">
    <link rel="stylesheet" href="/css/buyerCSS/search-v2.css">
    <link rel="stylesheet" href="/css/buyerCSS/ai-filters.css">
    <link rel="stylesheet" href="/css/buyerCSS/ai-excel.css">

    <%- include('partials/navbar') %>

        <!-- ====================================
    SEARCH V2 PAGE - SCREENSHOT EXACT MATCH DESIGN
    Branding: Kurogane + Kintsugi Gold
    ==================================== -->
        <div class="searchv2-page">
            <!-- Advanced Filters - Full Page Overlay Sidebar -->
            <%- include('partials/search-filters-overlay') %>

                <div class="searchv2-main-content">
                    <!-- Hero Section -->
                    <section class="searchv2-hero">
                        <!-- Hero Background Overlay -->
                        <div class="hero-bg-overlay"></div>

                        <!-- Tagline Top Right -->
                        <div class="hero-tagline-v2">
                            <span class="tagline-top">Engineered for Business.</span>
                            <span class="tagline-bottom">Powered by Intelligence.</span>
                        </div>

                        <div class="hero-content-wrapper">
                            <!-- Hero Title -->
                            <h1 class="hero-title-v2">FIND AUTOMOTIVE PARTS</h1>

                            <!-- Search Bar Container -->
                            <div class="searchv2-bar-container">
                                <div class="searchv2-bar">
                                    <div class="searchv2-input-wrapper">
                                        <i data-lucide="search" class="searchv2-icon"></i>
                                        <input type="text" class="searchv2-input" id="search2-input" placeholder="<%= t('search.placeholder') %>" autocomplete="off">
                                        <button class="searchv2-clear-btn hidden" id="search2-clear">
                                            <i data-lucide="x"></i>
                                        </button>
                                    </div>
                                    <button class="searchv2-filter-btn" id="search2-btn">
            <span>FILTER SEARCH</span>
          </button>
                                    <button class="searchv2-reset-btn hidden" id="search2-reset-btn">
                                        <i data-lucide="rotate-ccw"></i>
                                        <span><%= t('search.resetBtn') %></span>
                                    </button>
                                </div>

                                <!-- Autocomplete Dropdown -->
                                <div class="search2-autocomplete" id="search2-autocomplete"></div>
                            </div>

                            <!-- Quick Actions -->
                            <div class="searchv2-quick-actions">
                                <button class="quick-action-v2" id="excel-upload-trigger">
          <i data-lucide="upload"></i>
          <span>Upload Excel</span>
        </button>
                                <button class="quick-action-v2 ai-action" id="ai-filter-trigger">
          <i data-lucide="brain"></i>
          <span>AI Smart Filter</span>
        </button>
                                <button class="quick-action-v2" id="advanced-filter-trigger">
          <i data-lucide="sliders-horizontal"></i>
          <span><%= t('search.advancedFilters') || 'Advanced Filter' %></span>
        </button>
                            </div>
                        </div>
                    </section>

                    <!-- Results Section -->
                    <section class="searchv2-results" id="search2-results-section">
                        <div class="results-container">
                            <!-- Results Table -->
                            <div class="results-table-wrapper" id="results-table-container">
                                <table class="results-table-v2" id="results-table">
                                    <thead>
                                        <tr>
                                            <th class="col-select">
                                                <%= t('searchResults.table.select') || 'SELECT' %>
                                            </th>
                                            <th class="col-brand sortable" data-sort="brand">
                                                <%= t('searchResults.table.brand') || 'BRAND' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-vendor sortable" data-sort="vendorCode">
                                                <%= t('searchResults.table.vendorCode') || 'VENDOR CODE' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-description sortable" data-sort="description">
                                                <%= t('searchResults.table.description') || 'DESCRIPTION' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-qty sortable" data-sort="quantity">
                                                <%= t('searchResults.table.qty') || 'QTY' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-stock sortable" data-sort="stockCode">
                                                <%= t('searchResults.table.stockCode') || 'STOCK CODE' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-volume sortable" data-sort="volume">
                                                <%= t('searchResults.table.volume') || 'VOLUME' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-weight sortable" data-sort="weight">
                                                <%= t('searchResults.table.weight') || 'WEIGHT' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-delivery sortable" data-sort="deliveryDays">
                                                <%= t('searchResults.table.delivery') || 'DELIVERY' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-orderqty">
                                                <%= t('searchResults.table.orderQty') || 'ORDER QTY' %>
                                            </th>
                                            <th class="col-total sortable" data-sort="price">
                                                <%= t('searchResults.table.total') || 'TOTAL' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-action">-</th>
                                        </tr>
                                    </thead>
                                    <tbody id="results-table-body">
                                        <!-- Results will be inserted here by JS -->
                                    </tbody>
                                </table>
                            </div>

                            <!-- Pagination -->
                            <div class="results-pagination-v2 hidden" id="results-pagination">
                                <!-- Populated by JS -->
                            </div>

                            <!-- Empty State Placeholder -->
                            <div class="results-empty-placeholder" id="results-empty-placeholder">
                                <div class="empty-placeholder-content">
                                    <i data-lucide="search" class="empty-icon"></i>
                                    <h3 class="empty-title">START YOUR SEARCH</h3>
                                    <p class="empty-desc">Enter a part number, brand, or description above to find automotive parts</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Footer Section - Two Parts, Same Width as Hero/Table -->
                    <section class="searchv2-footer" id="searchv2-footer">
                        <div class="footer-content-grid">
                            <!-- Left: Match Count -->
                            <div class="footer-left">
                                <h2 class="match-count-title">FOUND <span id="footer-results-count">0</span> MATCHES</h2>
                                <p class="match-count-subtitle">Select items to add to cart</p>
                                <div class="selected-total-v2">
                                    <span class="total-amount" id="selected-total-value">0.00</span>
                                    <span class="total-currency">USD</span>
                                    <span class="total-label">Total Selected</span>
                                </div>
                                <button class="btn-add-cart-v2" id="add-to-cart-btn" disabled>
          ADD TO CART
        </button>
                            </div>

                            <!-- Right: Referral Banner -->
                            <div class="footer-right">
                                <div class="referral-banner">
                                    <div class="referral-content">
                                        <h3 class="referral-title">JOIN PARTSFORM</h3>
                                        <h4 class="referral-subtitle">REFERRAL PROGRAM</h4>
                                        <p class="referral-desc">Special Price Reductions and More</p>
                                        <a href="/buyer/affiliate" class="btn-referral">INVITE A PARTNER</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <!-- No Results State -->
                <div class="searchv2-no-results hidden" id="no-results-state">
                    <div class="no-results-inner">
                        <div class="no-results-icon">
                            <i data-lucide="package-x"></i>
                        </div>
                        <h3 class="no-results-title">
                            <%= t('searchResults.noResults.title') %>
                        </h3>
                        <p class="no-results-desc">
                            <%= t('searchResults.noResults.noPartsFound') %> "<strong id="no-results-query"></strong>".
                                <%= t('searchResults.noResults.tryDifferent') %>
                        </p>
                    </div>
                </div>
        </div>

        <!-- Quick Search Modal -->
        <%- include('partials/quick-search') %>

            <!-- ====================================
     AI SMART FILTER MODAL
     ==================================== -->
            <div class="ai-filter-modal ai-filter-light" id="ai-filter-modal">
                <div class="ai-filter-backdrop" id="ai-filter-backdrop"></div>
                <div class="ai-filter-container">
                    <div class="ai-light-bg-elements">
                        <div class="ai-light-circle circle-1"></div>
                        <div class="ai-light-circle circle-2"></div>
                        <div class="ai-light-circle circle-3"></div>
                    </div>

                    <div class="ai-filter-header">
                        <div class="ai-filter-title-wrapper">
                            <div class="ai-icon-wrapper">
                                <i data-lucide="sparkles" class="ai-icon"></i>
                            </div>
                            <div class="ai-title-content">
                                <h2 class="ai-filter-title"><span class="title-ai">AI</span>
                                    <%= t('search.aiFilter.title') %>
                                </h2>
                                <p class="ai-filter-subtitle">
                                    <%= t('search.aiFilter.subtitle') %>
                                </p>
                            </div>
                        </div>
                        <button class="ai-filter-close" id="ai-filter-close">
        <i data-lucide="x"></i>
      </button>
                    </div>

                    <div class="ai-filter-body">
                        <div class="ai-input-section">
                            <div class="ai-input-wrapper">
                                <textarea class="ai-input" id="ai-filter-input" placeholder="<%= t('search.aiFilter.placeholder') %>" rows="2"></textarea>
                                <button class="ai-submit-btn" id="ai-submit-btn" title="<%= t('search.aiFilter.findParts') %>">
            <i data-lucide="search"></i>
          </button>
                            </div>
                            <div class="ai-input-hints">
                                <span class="hint-label"><%= t('search.aiFilter.try') %></span>
                                <div class="ai-hints-container">
                                    <button class="ai-hint-chip" data-hint="Find OEM brake parts under $500 from verified suppliers">
              <%= t('search.aiFilter.hint1') %>
            </button>
                                    <button class="ai-hint-chip" data-hint="Show bearings from SKF in stock with express delivery">
              <%= t('search.aiFilter.hint2') %>
            </button>
                                    <button class="ai-hint-chip" data-hint="German suppliers with ISO certification">
              <%= t('search.aiFilter.hint3') %>
            </button>
                                </div>
                            </div>
                        </div>

                        <div class="ai-response-section hidden" id="ai-response-section">
                            <div class="ai-response-header">
                                <div class="ai-thinking-indicator" id="ai-thinking">
                                    <div class="thinking-dots">
                                        <span></span>
                                        <span></span>
                                        <span></span>
                                    </div>
                                    <span class="thinking-text"><%= t('search.aiFilter.analyzing') %></span>
                                </div>
                                <div class="ai-response-title hidden" id="ai-response-title">
                                    <i data-lucide="check-circle"></i>
                                    <span><%= t('search.aiFilter.foundFilters') %></span>
                                </div>
                            </div>
                            <div class="ai-filters-preview hidden" id="ai-filters-preview">
                                <div class="ai-filters-grid" id="ai-filters-grid"></div>
                            </div>
                        </div>

                        <div class="ai-features-info">
                            <div class="ai-feature-item">
                                <div class="ai-feature-icon"><i data-lucide="brain"></i></div>
                                <div class="ai-feature-content">
                                    <h4>
                                        <%= t('search.aiFilter.features.smartSearch.title') %>
                                    </h4>
                                    <p>
                                        <%= t('search.aiFilter.features.smartSearch.desc') %>
                                    </p>
                                </div>
                            </div>
                            <div class="ai-feature-item">
                                <div class="ai-feature-icon"><i data-lucide="sliders-horizontal"></i></div>
                                <div class="ai-feature-content">
                                    <h4>
                                        <%= t('search.aiFilter.features.autoFilters.title') %>
                                    </h4>
                                    <p>
                                        <%= t('search.aiFilter.features.autoFilters.desc') %>
                                    </p>
                                </div>
                            </div>
                            <div class="ai-feature-item">
                                <div class="ai-feature-icon"><i data-lucide="zap"></i></div>
                                <div class="ai-feature-content">
                                    <h4>
                                        <%= t('search.aiFilter.features.saveTime.title') %>
                                    </h4>
                                    <p>
                                        <%= t('search.aiFilter.features.saveTime.desc') %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="ai-filter-footer">
                        <div class="ai-footer-info">
                            <i data-lucide="info"></i>
                            <span><%= t('search.aiFilter.sidebarHint') %></span>
                        </div>
                        <div class="ai-filter-actions">
                            <button class="ai-btn-secondary" id="ai-clear-all">
          <i data-lucide="rotate-ccw"></i>
          <span><%= t('search.resetBtn') %></span>
        </button>
                            <button class="ai-btn-primary" id="ai-apply-filters">
          <i data-lucide="search"></i>
          <span><%= t('search.aiFilter.applyFilters') %></span>
          <span class="results-count" id="results-preview">0</span>
        </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- AI-Powered Excel Upload Modal -->
            <div class="modal ai-excel-modal" id="excel-modal">
                <div class="modal-overlay" id="excel-modal-overlay"></div>
                <div class="modal-container ai-excel-container">
                    <!-- Modal Header -->
                    <div class="modal-header ai-excel-header">
                        <div class="ai-excel-title-wrapper">
                            <div class="ai-excel-icon">
                                <i data-lucide="file-spreadsheet"></i>
                            </div>
                            <div class="ai-excel-title-content">
                                <h3 class="modal-title">
                                    <%= t('searchResults.excel.title') %>
                                        <span class="ai-badge"><%= t('searchResults.excel.aiBadge') %></span>
                                </h3>
                                <p class="ai-excel-subtitle">
                                    <%= t('searchResults.excel.subtitle') %>
                                </p>
                            </div>
                        </div>
                        <button class="modal-close" id="excel-modal-close">
                            <i data-lucide="x"></i>
                        </button>
                    </div>

                    <div class="modal-body ai-excel-body">
                        <!-- Step 1: Upload Area -->
                        <div class="ai-excel-step" id="excel-step-upload">
                            <!-- Upload Error Banner -->
                            <div class="ai-upload-error hidden" id="upload-error-banner">
                                <div class="upload-error-icon">
                                    <i data-lucide="alert-triangle"></i>
                                </div>
                                <div class="upload-error-content">
                                    <h4 class="upload-error-title" id="upload-error-title">
                                        <%= t('searchResults.excel.fileTooLarge') %>
                                    </h4>
                                    <p class="upload-error-message" id="upload-error-message"></p>
                                    <div class="upload-error-details" id="upload-error-details"></div>
                                </div>
                                <button class="upload-error-dismiss" id="upload-error-dismiss">
                                    <i data-lucide="x"></i>
                                </button>
                            </div>

                            <div class="upload-area ai-upload-area" id="upload-area">
                                <input type="file" id="excel-file-input" accept=".xlsx,.xls,.csv" hidden>
                                <div class="ai-upload-visual">
                                    <div class="ai-upload-icon-wrapper">
                                        <div class="ai-upload-glow"></div>
                                        <i data-lucide="upload-cloud"></i>
                                    </div>
                                    <div class="ai-upload-sparkles">
                                        <i data-lucide="sparkles" class="sparkle s1"></i>
                                        <i data-lucide="sparkles" class="sparkle s2"></i>
                                        <i data-lucide="sparkles" class="sparkle s3"></i>
                                    </div>
                                </div>

                                <h4 class="upload-title">
                                    <%= t('searchResults.excel.dragDrop') %>
                                </h4>
                                <p class="upload-subtitle">
                                    <%= t('searchResults.excel.aiExtract') %>
                                </p>

                                <button class="btn-primary ai-browse-btn" id="browse-file-btn">
                                    <i data-lucide="folder-open"></i>
                                    <span><%= t('searchResults.excel.browseFiles') %></span>
                                </button>

                                <p class="upload-hint">
                                    <i data-lucide="check-circle"></i>
                                    <%= t('searchResults.excel.supportedFormats') %>
                                </p>
                            </div>

                            <div class="sample-format ai-sample-format">
                                <div class="sample-header">
                                    <i data-lucide="info"></i>
                                    <span><%= t('searchResults.excel.formatHint') %></span>
                                </div>
                                <a href="/api/download-sample-excel" class="download-sample" download>
                                    <i data-lucide="download"></i>
                                    <span><%= t('searchResults.excel.downloadSample') %></span>
                                </a>
                            </div>
                        </div>

                        <!-- Step 2: AI Analyzing -->
                        <div class="ai-excel-step hidden" id="excel-step-analyzing">
                            <div class="ai-analyzing-container">
                                <div class="ai-analyzing-visual">
                                    <div class="ai-brain-pulse">
                                        <i data-lucide="brain"></i>
                                    </div>
                                    <div class="ai-analyzing-rings">
                                        <div class="ring r1"></div>
                                        <div class="ring r2"></div>
                                        <div class="ring r3"></div>
                                    </div>
                                </div>

                                <div class="ai-analyzing-content">
                                    <h4 class="ai-analyzing-title">
                                        <%= t('searchResults.excel.analyzing') %>
                                    </h4>
                                    <p class="ai-analyzing-file" id="analyzing-file-name">processing file.xlsx</p>

                                    <div class="ai-analyzing-steps">
                                        <div class="ai-step" id="ai-step-reading">
                                            <div class="ai-step-icon"><i data-lucide="file-search"></i></div>
                                            <span><%= t('searchResults.excel.readingData') %></span>
                                            <div class="ai-step-status"><i data-lucide="loader-2" class="spin"></i></div>
                                        </div>
                                        <div class="ai-step" id="ai-step-detecting">
                                            <div class="ai-step-icon"><i data-lucide="scan-search"></i></div>
                                            <span><%= t('searchResults.excel.detectingParts') %></span>
                                            <div class="ai-step-status"></div>
                                        </div>
                                        <div class="ai-step" id="ai-step-extracting">
                                            <div class="ai-step-icon"><i data-lucide="wand-2"></i></div>
                                            <span><%= t('searchResults.excel.extractingData') %></span>
                                            <div class="ai-step-status"></div>
                                        </div>
                                        <div class="ai-step" id="ai-step-validating">
                                            <div class="ai-step-icon"><i data-lucide="check-circle"></i></div>
                                            <span><%= t('searchResults.excel.validating') %></span>
                                            <div class="ai-step-status"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Step 3: AI Results Preview -->
                        <div class="ai-excel-step hidden" id="excel-step-results">
                            <!-- AI Summary Banner -->
                            <div class="ai-results-summary">
                                <div class="ai-summary-icon">
                                    <i data-lucide="sparkles"></i>
                                </div>
                                <div class="ai-summary-content">
                                    <h4 class="ai-summary-title" id="ai-summary-title">
                                        <%= t('searchResults.excel.analysisComplete') %>
                                    </h4>
                                    <p class="ai-summary-text" id="ai-summary-text">
                                        <%= t('searchResults.excel.partsReady') %>
                                    </p>
                                </div>
                                <div class="ai-summary-badge" id="ai-summary-badge">
                                    <i data-lucide="zap"></i>
                                    <span><%= t('searchResults.excel.aiPowered') %></span>
                                </div>
                            </div>

                            <!-- Data Quality Indicator -->
                            <div class="ai-data-quality" id="ai-data-quality">
                                <div class="quality-meter">
                                    <div class="quality-label">
                                        <%= t('searchResults.excel.dataQuality') %>
                                    </div>
                                    <div class="quality-bar">
                                        <div class="quality-fill" id="quality-fill"></div>
                                    </div>
                                    <div class="quality-text" id="quality-text">
                                        <%= t('searchResults.excel.qualityGood') %>
                                    </div>
                                </div>
                                <div class="quality-issues hidden" id="quality-issues">
                                    <i data-lucide="alert-circle"></i>
                                    <span id="quality-issues-text"></span>
                                </div>
                            </div>

                            <!-- Parts List Header -->
                            <div class="ai-parts-header">
                                <div class="parts-header-left">
                                    <label class="select-all-checkbox">
                                        <input type="checkbox" id="select-all-parts" checked>
                                        <span class="checkbox-custom"></span>
                                        <span class="checkbox-label"><%= t('searchResults.excel.selectAll') %></span>
                                    </label>
                                    <label class="select-all-checkbox select-first-option hidden" id="select-first-1000-label">
                                        <input type="checkbox" id="select-first-1000">
                                        <span class="checkbox-custom"></span>
                                        <span class="checkbox-label"><%= t('searchResults.excel.selectFirst1000') %></span>
                                    </label>
                                    <span class="parts-count" id="parts-count"><%= t('searchResults.excel.partsSelected') %></span>
                                </div>
                                <div class="parts-header-right">
                                    <div class="parts-filter">
                                        <button class="filter-btn active" data-filter="all"><%= t('searchResults.excel.filterAll') %></button>
                                        <button class="filter-btn" data-filter="high"><%= t('searchResults.excel.filterHigh') %></button>
                                        <button class="filter-btn" data-filter="medium"><%= t('searchResults.excel.filterMedium') %></button>
                                        <button class="filter-btn" data-filter="low"><%= t('searchResults.excel.filterLow') %></button>
                                    </div>
                                </div>
                            </div>

                            <!-- Parts List -->
                            <div class="ai-parts-list" id="ai-parts-list">
                                <!-- Parts will be dynamically inserted here -->
                            </div>

                            <!-- AI Suggestions -->
                            <div class="ai-suggestions hidden" id="ai-suggestions">
                                <div class="suggestions-header">
                                    <i data-lucide="lightbulb"></i>
                                    <span><%= t('searchResults.excel.aiSuggestions') %></span>
                                </div>
                                <ul class="suggestions-list" id="suggestions-list">
                                </ul>
                            </div>
                        </div>

                        <!-- Step 4: Search Results with Recommendations -->
                        <div class="ai-excel-step hidden" id="excel-step-search-results">
                            <!-- Analytics Summary -->
                            <div class="excel-analytics" id="excel-analytics">
                                <div class="analytics-header">
                                    <h4>
                                        <%= t('searchResults.excel.importAnalytics') %>
                                    </h4>
                                    <span class="analytics-filename" id="analytics-filename">file.xlsx</span>
                                </div>

                                <!-- Stats Cards -->
                                <div class="analytics-stats">
                                    <div class="stat-card stat-total">
                                        <div class="stat-icon">
                                            <i data-lucide="file-spreadsheet"></i>
                                        </div>
                                        <div class="stat-content">
                                            <div class="stat-value" id="stat-total">0</div>
                                            <div class="stat-label">
                                                <%= t('searchResults.excel.totalParts') %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="stat-card stat-found">
                                        <div class="stat-icon">
                                            <i data-lucide="check-circle"></i>
                                        </div>
                                        <div class="stat-content">
                                            <div class="stat-value" id="stat-found">0</div>
                                            <div class="stat-label">
                                                <%= t('searchResults.excel.found') %>
                                            </div>
                                        </div>
                                        <div class="stat-percent stat-percent-found" id="stat-percent-found">0%</div>
                                    </div>
                                    <div class="stat-card stat-not-found">
                                        <div class="stat-icon">
                                            <i data-lucide="x-circle"></i>
                                        </div>
                                        <div class="stat-content">
                                            <div class="stat-value" id="stat-not-found">0</div>
                                            <div class="stat-label">
                                                <%= t('searchResults.excel.notFound') %>
                                            </div>
                                        </div>
                                        <div class="stat-percent stat-percent-not-found" id="stat-percent-not-found">0%</div>
                                    </div>
                                    <div class="stat-card stat-duplicates hidden" id="stat-duplicates-card">
                                        <div class="stat-icon">
                                            <i data-lucide="copy"></i>
                                        </div>
                                        <div class="stat-content">
                                            <div class="stat-value" id="stat-duplicates">0</div>
                                            <div class="stat-label">
                                                <%= t('searchResults.excel.duplicates') %>
                                            </div>
                                        </div>
                                        <div class="stat-note">
                                            <%= t('searchResults.excel.notCounted') %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Success Rate Bar -->
                                <div class="success-rate-container">
                                    <div class="success-rate-header">
                                        <span class="success-rate-label"><%= t('searchResults.excel.successRate') %></span>
                                        <span class="success-rate-value" id="success-rate-value">0%</span>
                                    </div>
                                    <div class="success-rate-bar">
                                        <div class="success-rate-fill" id="success-rate-fill"></div>
                                    </div>
                                </div>

                                <!-- Not Found Parts List -->
                                <div class="not-found-section hidden" id="not-found-section">
                                    <div class="not-found-header">
                                        <i data-lucide="alert-triangle"></i>
                                        <span><%= t('searchResults.excel.partsNotFound') %></span>
                                        <button class="not-found-toggle" id="not-found-toggle">
                                            <i data-lucide="chevron-down"></i>
                                        </button>
                                    </div>
                                    <div class="not-found-list" id="not-found-list">
                                        <!-- Not found parts will be listed here -->
                                    </div>
                                </div>

                                <!-- Duplicates Warning -->
                                <div class="duplicates-section hidden" id="duplicates-section">
                                    <div class="duplicates-header">
                                        <i data-lucide="info"></i>
                                        <span><%= t('searchResults.excel.duplicatesDetected') %></span>
                                        <button class="duplicates-toggle" id="duplicates-toggle">
                                            <i data-lucide="chevron-down"></i>
                                        </button>
                                    </div>
                                    <div class="duplicates-list" id="duplicates-list">
                                        <!-- Duplicates will be listed here -->
                                    </div>
                                </div>
                            </div>

                            <div class="ai-search-header">
                                <div class="search-header-left">
                                    <h4>
                                        <%= t('searchResults.excel.searchResultsTitle') %>
                                    </h4>
                                    <p class="search-summary" id="search-summary">
                                        <%= t('searchResults.excel.foundOptions') %>
                                    </p>
                                </div>
                                <div class="search-header-right">
                                    <button class="btn-secondary" id="back-to-parts-btn">
                                        <i data-lucide="arrow-left"></i>
                                        <span><%= t('searchResults.excel.backToParts') %></span>
                                    </button>
                                </div>
                            </div>

                            <!-- Recommendations List -->
                            <div class="ai-recommendations-list" id="ai-recommendations-list">
                                <!-- Recommendations will be dynamically inserted here -->
                            </div>
                        </div>
                    </div>

                    <!-- Modal Footer -->
                    <div class="modal-footer ai-excel-footer">
                        <div class="footer-left">
                            <button class="btn-secondary hidden" id="excel-reset-btn">
                                <i data-lucide="rotate-ccw"></i>
                                <span><%= t('searchResults.excel.uploadNewFile') %></span>
                            </button>
                        </div>
                        <div class="footer-right">
                            <button class="btn-secondary" id="excel-cancel-btn">
                                <%= t('common.cancel') %>
                            </button>
                            <button class="btn-primary ai-search-btn hidden" id="excel-search-btn">
                                <i data-lucide="search"></i>
                                <span><%= t('searchResults.excel.searchParts') %></span>
                                <span class="search-count" id="excel-search-count">0</span>
                            </button>
                            <button class="btn-primary ai-cart-btn hidden" id="excel-add-cart-btn">
                                <i data-lucide="shopping-cart"></i>
                                <span><%= t('searchResults.excel.addToCartBtn') %></span>
                                <span class="cart-count" id="excel-cart-count">0</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sign In Modal -->
            <div class="modal" id="sign-in-modal">
                <div class="modal-backdrop" id="modal-backdrop"></div>
                <div class="modal-content">
                    <button class="modal-close" id="modal-close">
      <i data-lucide="x"></i>
    </button>
                    <div class="modal-body">
                        <div class="modal-badge">
                            <i data-lucide="sparkles"></i>
                            <span><%= t('common.welcomeBack') %></span>
                        </div>
                        <h3 class="modal-title">
                            <%= t('common.signIn') %>
                        </h3>
                        <p class="modal-description">
                            <%= t('common.signInDesc') %>
                        </p>
                        <form class="sign-in-form" id="sign-in-form">
                            <div class="form-group">
                                <label class="form-label"><%= t('common.email') %></label>
                                <div class="input-wrapper">
                                    <i data-lucide="mail" class="input-icon"></i>
                                    <input type="email" class="form-input" id="login-email" placeholder="<%= t('common.emailPlaceholder') %>" required>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label"><%= t('common.password') %></label>
                                <div class="input-wrapper">
                                    <i data-lucide="lock" class="input-icon"></i>
                                    <input type="password" class="form-input" id="login-password" placeholder="••••••••" required>
                                </div>
                            </div>
                            <div class="form-footer">
                                <a href="#" class="forgot-password">
                                    <%= t('common.forgotPassword') %>
                                </a>
                            </div>
                            <button type="submit" class="btn-primary btn-full">
          <span><%= t('common.signIn') %></span>
          <i data-lucide="arrow-right"></i>
        </button>
                        </form>
                        <div class="modal-footer">
                            <span><%= t('common.noAccount') %></span>
                            <a href="#" class="sign-up-link">
                                <%= t('common.signUp') %>
                            </a>
                        </div>
                        <div class="modal-divider">
                            <span><%= t('common.orContinueWith') %></span>
                        </div>
                        <div class="social-login">
                            <button class="social-btn">Google</button>
                            <button class="social-btn">LinkedIn</button>
                        </div>
                    </div>
                </div>
            </div>

            <script src="/js/animations.js"></script>
            <script src="/js/main.js"></script>
            <script src="/js/cart.js"></script>
            <script src="/js/buyer-auth.js"></script>
            <script>
                window.__translations = {
                    search: {
                        placeholder: "<%= t('search.placeholder') %>",
                        emptyState: {
                            title: "<%= t('searchResults.emptyState.title') %>",
                            description: "<%= t('searchResults.emptyState.description') %>"
                        },
                        signInRequired: "<%= t('common.signInRequired') || 'Sign In Required' %>",
                        signInToSearch: "<%= t('common.signInToSearch') || 'Please sign in to search for parts from verified suppliers worldwide.' %>"
                    }
                };
            </script>
            <script src="/js/search-v2.js"></script>
            <script src="/js/quick-search.js"></script>
            <script src="/js/cart-badge-updater.js"></script>
            <script src="/js/ai-learning.js"></script>
            <script src="/js/ai-filters.js"></script>
            <script src="/js/ai-excel.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
            <script>
                lucide.createIcons();
                window.addEventListener('load', () => lucide.createIcons());
            </script>

            <%- include('partials/footer') %>