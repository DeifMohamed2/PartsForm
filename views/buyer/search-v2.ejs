<%- include('partials/header') %>
    <link rel="stylesheet" href="/css/buyerCSS/buyer-main.css">
    <link rel="stylesheet" href="/css/buyerCSS/search2.css">
    <link rel="stylesheet" href="/css/buyerCSS/search-v2.css">
    <link rel="stylesheet" href="/css/buyerCSS/ai-filters.css">
    <link rel="stylesheet" href="/css/buyerCSS/ai-excel.css">

    <%- include('partials/navbar') %>

        <!-- ====================================
    SEARCH V2 PAGE - SCREENSHOT EXACT MATCH DESIGN
    Branding: Kurogane + Kintsugi Gold
    ==================================== -->
        <div class="searchv2-page">
            <!-- Advanced Filters - Full Page Overlay Sidebar -->
            <%- include('partials/search-filters-overlay') %>

                <div class="searchv2-main-content">
                    <!-- Hero Section -->
                    <section class="searchv2-hero">
                        <!-- Hero Background Overlay -->
                        <div class="hero-bg-overlay"></div>

                        <!-- Tagline Top Right -->
                        <div class="hero-tagline-v2">
                            <span class="tagline-top">Engineered for Business.</span>
                            <span class="tagline-bottom">Powered by Intelligence.</span>
                        </div>

                        <div class="hero-content-wrapper">
                            <!-- Hero Title -->
                            <h1 class="hero-title-v2">FIND AUTOMOTIVE PARTS</h1>

                            <!-- Search Bar Container -->
                            <div class="searchv2-bar-container">
                                <div class="searchv2-bar">
                                    <div class="searchv2-input-wrapper">
                                        <i data-lucide="search" class="searchv2-icon"></i>
                                        <input type="text" class="searchv2-input" id="search2-input" placeholder="<%= t('search.placeholder') %>" autocomplete="off">
                                        <button class="searchv2-clear-btn hidden" id="search2-clear">
                                            <i data-lucide="x"></i>
                                        </button>
                                    </div>
                                    <button class="searchv2-filter-btn" id="search2-btn">
            <span>FILTER SEARCH</span>
          </button>
                                    <button class="searchv2-reset-btn hidden" id="search2-reset-btn">
                                        <i data-lucide="rotate-ccw"></i>
                                        <span><%= t('search.resetBtn') %></span>
                                    </button>
                                </div>

                                <!-- Autocomplete Dropdown -->
                                <div class="search2-autocomplete" id="search2-autocomplete"></div>
                            </div>

                            <!-- Quick Actions -->
                            <div class="searchv2-quick-actions">
                                <button class="quick-action-v2" id="excel-upload-trigger">
          <i data-lucide="upload"></i>
          <span>Upload Excel</span>
        </button>
                                <button class="quick-action-v2 ai-action" id="ai-filter-trigger">
          <i data-lucide="brain"></i>
          <span>AI Smart Filter</span>
        </button>
                            </div>
                        </div>
                    </section>

                    <!-- Results Section -->
                    <section class="searchv2-results" id="search2-results-section">
                        <div class="results-container">
                            <!-- Results Table -->
                            <div class="results-table-wrapper" id="results-table-container">
                                <table class="results-table-v2" id="results-table">
                                    <thead>
                                        <tr>
                                            <th class="col-select">
                                                <%= t('searchResults.table.select') || 'SELECT' %>
                                            </th>
                                            <th class="col-brand sortable" data-sort="brand">
                                                <%= t('searchResults.table.brand') || 'BRAND' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-vendor sortable" data-sort="vendorCode">
                                                <%= t('searchResults.table.vendorCode') || 'VENDOR CODE' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-description sortable" data-sort="description">
                                                <%= t('searchResults.table.description') || 'DESCRIPTION' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-qty sortable" data-sort="quantity">
                                                <%= t('searchResults.table.qty') || 'QTY' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-stock sortable" data-sort="stockCode">
                                                <%= t('searchResults.table.stockCode') || 'STOCK CODE' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-volume sortable" data-sort="volume">
                                                <%= t('searchResults.table.volume') || 'VOLUME' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-weight sortable" data-sort="weight">
                                                <%= t('searchResults.table.weight') || 'WEIGHT' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-delivery sortable" data-sort="deliveryDays">
                                                <%= t('searchResults.table.delivery') || 'DELIVERY' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-orderqty">
                                                <%= t('searchResults.table.orderQty') || 'ORDER QTY' %>
                                            </th>
                                            <th class="col-total sortable" data-sort="price">
                                                <%= t('searchResults.table.total') || 'TOTAL' %> <i data-lucide="chevron-down" class="sort-icon"></i></th>
                                            <th class="col-action">-</th>
                                        </tr>
                                    </thead>
                                    <tbody id="results-table-body">
                                        <!-- Results will be inserted here by JS -->
                                    </tbody>
                                </table>
                            </div>

                            <!-- Pagination -->
                            <div class="results-pagination-v2 hidden" id="results-pagination">
                                <!-- Populated by JS -->
                            </div>

                            <!-- Empty State Placeholder -->
                            <div class="results-empty-placeholder" id="results-empty-placeholder">
                                <div class="empty-placeholder-content">
                                    <i data-lucide="search" class="empty-icon"></i>
                                    <h3 class="empty-title">START YOUR SEARCH</h3>
                                    <p class="empty-desc">Enter a part number, brand, or description above to find automotive parts</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Footer Section - Two Parts, Same Width as Hero/Table -->
                    <section class="searchv2-footer" id="searchv2-footer">
                        <div class="footer-content-grid">
                            <!-- Left: Match Count -->
                            <div class="footer-left">
                                <h2 class="match-count-title">FOUND <span id="footer-results-count">0</span> MATCHES</h2>
                                <p class="match-count-subtitle">Select items to add to cart</p>
                                <div class="selected-total-v2">
                                    <span class="total-amount" id="selected-total-value">0.00</span>
                                    <span class="total-currency">USD</span>
                                    <span class="total-label">Total Selected</span>
                                </div>
                                <button class="btn-add-cart-v2" id="add-to-cart-btn" disabled>
          ADD TO CART
        </button>
                            </div>

                            <!-- Right: Referral Banner -->
                            <div class="footer-right">
                                <div class="referral-banner">
                                    <div class="referral-content">
                                        <h3 class="referral-title">JOIN PARTSFORM</h3>
                                        <h4 class="referral-subtitle">REFERRAL PROGRAM</h4>
                                        <p class="referral-desc">Special Price Reductions and More</p>
                                        <a href="/buyer/affiliate" class="btn-referral">INVITE A PARTNER</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <!-- No Results State -->
                <div class="searchv2-no-results hidden" id="no-results-state">
                    <div class="no-results-inner">
                        <div class="no-results-icon">
                            <i data-lucide="package-x"></i>
                        </div>
                        <h3 class="no-results-title">
                            <%= t('searchResults.noResults.title') %>
                        </h3>
                        <p class="no-results-desc">
                            <%= t('searchResults.noResults.noPartsFound') %> "<strong id="no-results-query"></strong>".
                                <%= t('searchResults.noResults.tryDifferent') %>
                        </p>
                    </div>
                </div>
        </div>

        <!-- Quick Search Modal -->
        <%- include('partials/quick-search') %>

            <!-- ====================================
     AI SMART FILTER MODAL
     ==================================== -->
            <div class="ai-filter-modal ai-filter-light" id="ai-filter-modal">
                <div class="ai-filter-backdrop" id="ai-filter-backdrop"></div>
                <div class="ai-filter-container">
                    <div class="ai-light-bg-elements">
                        <div class="ai-light-circle circle-1"></div>
                        <div class="ai-light-circle circle-2"></div>
                        <div class="ai-light-circle circle-3"></div>
                    </div>

                    <div class="ai-filter-header">
                        <div class="ai-filter-title-wrapper">
                            <div class="ai-icon-wrapper">
                                <i data-lucide="sparkles" class="ai-icon"></i>
                            </div>
                            <div class="ai-title-content">
                                <h2 class="ai-filter-title"><span class="title-ai">AI</span>
                                    <%= t('search.aiFilter.title') %>
                                </h2>
                                <p class="ai-filter-subtitle">
                                    <%= t('search.aiFilter.subtitle') %>
                                </p>
                            </div>
                        </div>
                        <button class="ai-filter-close" id="ai-filter-close">
        <i data-lucide="x"></i>
      </button>
                    </div>

                    <div class="ai-filter-body">
                        <div class="ai-input-section">
                            <div class="ai-input-wrapper">
                                <textarea class="ai-input" id="ai-filter-input" placeholder="<%= t('search.aiFilter.placeholder') %>" rows="2"></textarea>
                                <button class="ai-submit-btn" id="ai-submit-btn" title="<%= t('search.aiFilter.findParts') %>">
            <i data-lucide="search"></i>
          </button>
                            </div>
                            <div class="ai-input-hints">
                                <span class="hint-label"><%= t('search.aiFilter.try') %></span>
                                <div class="ai-hints-container">
                                    <button class="ai-hint-chip" data-hint="Find OEM brake parts under $500 from verified suppliers">
              <%= t('search.aiFilter.hint1') %>
            </button>
                                    <button class="ai-hint-chip" data-hint="Show bearings from SKF in stock with express delivery">
              <%= t('search.aiFilter.hint2') %>
            </button>
                                    <button class="ai-hint-chip" data-hint="German suppliers with ISO certification">
              <%= t('search.aiFilter.hint3') %>
            </button>
                                </div>
                            </div>
                        </div>

                        <div class="ai-response-section hidden" id="ai-response-section">
                            <div class="ai-response-header">
                                <div class="ai-thinking-indicator" id="ai-thinking">
                                    <div class="thinking-dots">
                                        <span></span>
                                        <span></span>
                                        <span></span>
                                    </div>
                                    <span class="thinking-text"><%= t('search.aiFilter.analyzing') %></span>
                                </div>
                                <div class="ai-response-title hidden" id="ai-response-title">
                                    <i data-lucide="check-circle"></i>
                                    <span><%= t('search.aiFilter.foundFilters') %></span>
                                </div>
                            </div>
                            <div class="ai-filters-preview hidden" id="ai-filters-preview">
                                <div class="ai-filters-grid" id="ai-filters-grid"></div>
                            </div>
                        </div>

                        <div class="ai-features-info">
                            <div class="ai-feature-item">
                                <div class="ai-feature-icon"><i data-lucide="brain"></i></div>
                                <div class="ai-feature-content">
                                    <h4>
                                        <%= t('search.aiFilter.features.smartSearch.title') %>
                                    </h4>
                                    <p>
                                        <%= t('search.aiFilter.features.smartSearch.desc') %>
                                    </p>
                                </div>
                            </div>
                            <div class="ai-feature-item">
                                <div class="ai-feature-icon"><i data-lucide="sliders-horizontal"></i></div>
                                <div class="ai-feature-content">
                                    <h4>
                                        <%= t('search.aiFilter.features.autoFilters.title') %>
                                    </h4>
                                    <p>
                                        <%= t('search.aiFilter.features.autoFilters.desc') %>
                                    </p>
                                </div>
                            </div>
                            <div class="ai-feature-item">
                                <div class="ai-feature-icon"><i data-lucide="zap"></i></div>
                                <div class="ai-feature-content">
                                    <h4>
                                        <%= t('search.aiFilter.features.saveTime.title') %>
                                    </h4>
                                    <p>
                                        <%= t('search.aiFilter.features.saveTime.desc') %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="ai-filter-footer">
                        <div class="ai-footer-info">
                            <i data-lucide="info"></i>
                            <span><%= t('search.aiFilter.sidebarHint') %></span>
                        </div>
                        <div class="ai-filter-actions">
                            <button class="ai-btn-secondary" id="ai-clear-all">
          <i data-lucide="rotate-ccw"></i>
          <span><%= t('search.resetBtn') %></span>
        </button>
                            <button class="ai-btn-primary" id="ai-apply-filters">
          <i data-lucide="search"></i>
          <span><%= t('search.aiFilter.applyFilters') %></span>
          <span class="results-count" id="results-preview">0</span>
        </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sign In Modal -->
            <div class="modal" id="sign-in-modal">
                <div class="modal-backdrop" id="modal-backdrop"></div>
                <div class="modal-content">
                    <button class="modal-close" id="modal-close">
      <i data-lucide="x"></i>
    </button>
                    <div class="modal-body">
                        <div class="modal-badge">
                            <i data-lucide="sparkles"></i>
                            <span><%= t('common.welcomeBack') %></span>
                        </div>
                        <h3 class="modal-title">
                            <%= t('common.signIn') %>
                        </h3>
                        <p class="modal-description">
                            <%= t('common.signInDesc') %>
                        </p>
                        <form class="sign-in-form" id="sign-in-form">
                            <div class="form-group">
                                <label class="form-label"><%= t('common.email') %></label>
                                <div class="input-wrapper">
                                    <i data-lucide="mail" class="input-icon"></i>
                                    <input type="email" class="form-input" id="login-email" placeholder="<%= t('common.emailPlaceholder') %>" required>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label"><%= t('common.password') %></label>
                                <div class="input-wrapper">
                                    <i data-lucide="lock" class="input-icon"></i>
                                    <input type="password" class="form-input" id="login-password" placeholder="••••••••" required>
                                </div>
                            </div>
                            <div class="form-footer">
                                <a href="#" class="forgot-password">
                                    <%= t('common.forgotPassword') %>
                                </a>
                            </div>
                            <button type="submit" class="btn-primary btn-full">
          <span><%= t('common.signIn') %></span>
          <i data-lucide="arrow-right"></i>
        </button>
                        </form>
                        <div class="modal-footer">
                            <span><%= t('common.noAccount') %></span>
                            <a href="#" class="sign-up-link">
                                <%= t('common.signUp') %>
                            </a>
                        </div>
                        <div class="modal-divider">
                            <span><%= t('common.orContinueWith') %></span>
                        </div>
                        <div class="social-login">
                            <button class="social-btn">Google</button>
                            <button class="social-btn">LinkedIn</button>
                        </div>
                    </div>
                </div>
            </div>

            <script src="/js/animations.js"></script>
            <script src="/js/main.js"></script>
            <script src="/js/cart.js"></script>
            <script src="/js/buyer-auth.js"></script>
            <script>
                window.__translations = {
                    search: {
                        placeholder: "<%= t('search.placeholder') %>",
                        emptyState: {
                            title: "<%= t('searchResults.emptyState.title') %>",
                            description: "<%= t('searchResults.emptyState.description') %>"
                        },
                        signInRequired: "<%= t('common.signInRequired') || 'Sign In Required' %>",
                        signInToSearch: "<%= t('common.signInToSearch') || 'Please sign in to search for parts from verified suppliers worldwide.' %>"
                    }
                };
            </script>
            <script src="/js/search-v2.js"></script>
            <script src="/js/quick-search.js"></script>
            <script src="/js/cart-badge-updater.js"></script>
            <script src="/js/ai-learning.js"></script>
            <script src="/js/ai-filters.js"></script>
            <script src="/js/ai-excel.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
            <script>
                lucide.createIcons();
                window.addEventListener('load', () => lucide.createIcons());
            </script>

            <%- include('partials/footer') %>