<!-- Results Section -->
<div class="search2-results-section hidden" id="search2-results-section">
  <div class="container search-results-container">
    <!-- Main Content Area -->
    <div class="search-results-main">
      <!-- Results Header -->
      <div class="results-header hidden" id="results-header">
        <div class="results-header-left">
        <p class="results-count">
          <%= t('searchResults.header.found') %> <strong id="results-count">0</strong> <%= t('searchResults.header.partsMatching') %>
          <span class="results-page-info hidden" id="results-page-info"></span>
        </p>
        <p class="results-subtitle">
          <span id="selection-status"><%= t('searchResults.header.selectItems') %></span>
          <span class="selected-badge hidden" id="selected-badge">
            <i data-lucide="shopping-cart"></i>
            <span id="selected-items-count">0</span> <%= t('searchResults.header.selected') %>
          </span>
        </p>
        </div>
        <div class="results-header-right">
        <div class="selected-total-box">
          <span class="selected-total-label"><%= t('searchResults.header.selectedTotal') %></span>
          <span class="selected-total-amount" id="selected-total">0.00 AED</span>
          </div>
          <!-- Add to Cart Button in Header -->
          <button class="btn-add-to-cart-header" id="add-to-cart-btn-header" disabled>
            <i data-lucide="shopping-cart"></i>
            <span><%= t('searchResults.header.addToCart') %> (<span id="selected-count-header">0</span>)</span>
          </button>
          <button class="filter-toggle-btn" id="mobile-filter-toggle">
            <i data-lucide="sliders-horizontal"></i>
            <span><%= t('searchResults.header.filters') %></span>
          </button>
        </div>
      </div>

      <!-- Quick Sort & Filter Bar -->
      <div class="quick-sort-bar hidden" id="quick-sort-bar">
        <div class="quick-sort-left">
          <span class="quick-sort-label"><%= t('searchResults.sort.sortBy') %></span>
          <div class="quick-sort-buttons">
            <button class="quick-sort-btn active" data-sort="relevance" data-order="desc">
              <i data-lucide="sparkles"></i>
              <span><%= t('searchResults.sort.relevance') %></span>
            </button>
            <button class="quick-sort-btn" data-sort="price" data-order="asc">
              <i data-lucide="arrow-down-narrow-wide"></i>
              <span><%= t('searchResults.sort.cheapest') %></span>
            </button>
            <button class="quick-sort-btn" data-sort="price" data-order="desc">
              <i data-lucide="arrow-up-narrow-wide"></i>
              <span><%= t('searchResults.sort.expensive') %></span>
            </button>
            <button class="quick-sort-btn" data-sort="deliveryDays" data-order="asc">
              <i data-lucide="zap"></i>
              <span><%= t('searchResults.sort.fastestDelivery') %></span>
            </button>
            <button class="quick-sort-btn" data-sort="quantity" data-order="desc">
              <i data-lucide="package-check"></i>
              <span><%= t('searchResults.sort.mostStock') %></span>
            </button>
          </div>
        </div>
        <div class="quick-sort-right">
          <button class="quick-filter-btn" data-filter="in-stock">
            <span class="stock-dot green"></span>
            <%= t('searchResults.sort.inStockOnly') %>
          </button>
          <button class="quick-filter-btn" data-filter="low-stock">
            <span class="stock-dot yellow"></span>
            <%= t('searchResults.sort.lowStock') %>
          </button>
        </div>
      </div>

      <!-- Results Table -->
      <div class="results-table-container hidden" id="results-table-container">
        <div class="table-wrapper">
          <table class="results-table" id="results-table">
            <thead>
              <tr>
                <th><%= t('searchResults.table.select') %></th>
                <th><%= t('searchResults.table.brand') %></th>
                <th><%= t('searchResults.table.vendorCode') %></th>
                <th><%= t('searchResults.table.description') %></th>
                <th><%= t('searchResults.table.qty') %></th>
                <th><%= t('searchResults.table.stockCode') %></th>
                <th><%= t('searchResults.table.volume') %></th>
                <th><%= t('searchResults.table.weight') %></th>
                <th><%= t('searchResults.table.delivery') %></th>
                <th><%= t('searchResults.table.orderQty') %></th>
                <th><%= t('searchResults.table.total') %></th>
                <th>-</th>
              </tr>
            </thead>
            <tbody id="results-table-body">
              <!-- Results will be inserted here -->
            </tbody>
          </table>
        </div>

        <!-- Pagination Controls -->
        <div class="results-pagination hidden" id="results-pagination">
          <!-- Populated by JS -->
        </div>

        <!-- Results Footer - New Design -->
        <div class="results-footer">
          <div class="results-footer-content">
            <div class="results-footer-left">
              <h2 class="found-matches-title"><%= t('searchResults.footer.found') || 'FOUND' %> <span id="footer-results-count">0</span> <%= t('searchResults.footer.matches') || 'MATCHES' %></h2>
              <p class="found-matches-subtitle"><%= t('searchResults.footer.selectItems') || 'Select Items to add to cart' %></p>
            </div>
            <div class="selected-total-display">
              <span class="selected-total-value" id="selected-total-value">0.00 USD</span>
              <span class="selected-total-label"><%= t('searchResults.footer.totalSelected') || 'Total Selected' %></span>
            </div>
          </div>
          <div class="results-footer-actions">
            <button class="btn-add-to-cart" id="add-to-cart-btn" disabled>
              <i data-lucide="shopping-cart"></i>
              <span><%= t('searchResults.footer.addToCart') || 'ADD TO CART' %></span>
            </button>
          </div>
        </div>
      </div>

      <!-- Empty State — Minimal -->
      <div class="empty-state empty-state-minimal" id="empty-state">
        <div class="empty-state-icon-wrapper">
          <i data-lucide="search" class="empty-state-icon"></i>
        </div>
        <h3 class="empty-state-title"><%= t('searchResults.emptyState.title') %></h3>
        <p class="empty-state-description">
          <%= t('searchResults.emptyState.description') %>
        </p>
      </div>

      <!-- No Results State -->
      <div class="empty-state hidden" id="no-results-state">
        <div class="empty-state-icon-wrapper">
          <i data-lucide="package-x" class="empty-state-icon"></i>
        </div>
        <h3 class="empty-state-title"><%= t('searchResults.noResults.title') %></h3>
        <p class="empty-state-description">
          <%= t('searchResults.noResults.noPartsFound') %> "<strong id="no-results-query"></strong>".
          <%= t('searchResults.noResults.tryDifferent') %>
        </p>

        <div class="no-results-actions">
          <button class="btn-try-again" id="try-again-btn">
            <i data-lucide="refresh-cw"></i>
            <%= t('searchResults.noResults.tryAgain') %>
          </button>
          <button class="btn-contact-support">
            <i data-lucide="message-circle"></i>
            <%= t('searchResults.noResults.contactSupport') %>
          </button>
        </div>

        <!-- Suggestions -->
        <div class="no-results-suggestions">
          <h4><%= t('searchResults.noResults.suggestions') %></h4>
          <ul>
            <li><%= t('searchResults.noResults.checkSpelling') %></li>
            <li><%= t('searchResults.noResults.tryDifferentFormat') %></li>
            <li><%= t('searchResults.noResults.useFewerKeywords') %></li>
            <li><%= t('searchResults.noResults.clearFilters') %></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Referral Program Sidebar -->
    <div class="referral-sidebar" id="referral-sidebar">
      <h3 class="referral-sidebar-title"><%= t('searchResults.referral.title') || 'JOIN PARTSFORM REFERRAL PROGRAM' %></h3>
      <p class="referral-sidebar-subtitle"><%= t('searchResults.referral.subtitle') || 'Special Price Reductions and More.' %></p>
      <a href="/partner/register" class="referral-sidebar-btn">
        <%= t('searchResults.referral.inviteBtn') || 'INVITE A PARTNER' %>
      </a>
    </div>
  </div>
</div>

<!-- AI-Powered Excel Upload Modal -->
<div class="modal ai-excel-modal" id="excel-modal">
  <div class="modal-overlay" id="excel-modal-overlay"></div>
  <div class="modal-container ai-excel-container">
    <!-- Modal Header -->
    <div class="modal-header ai-excel-header">
      <div class="ai-excel-title-wrapper">
        <div class="ai-excel-icon">
          <i data-lucide="file-spreadsheet"></i>
        </div>
        <div class="ai-excel-title-content">
          <h3 class="modal-title">
            <%= t('searchResults.excel.title') %>
            <span class="ai-badge"><%= t('searchResults.excel.aiBadge') %></span>
          </h3>
          <p class="ai-excel-subtitle"><%= t('searchResults.excel.subtitle') %></p>
        </div>
      </div>
      <button class="modal-close" id="excel-modal-close">
        <i data-lucide="x"></i>
      </button>
    </div>

    <div class="modal-body ai-excel-body">
      <!-- Step 1: Upload Area -->
      <div class="ai-excel-step" id="excel-step-upload">
        <!-- Upload Error Banner -->
        <div class="ai-upload-error hidden" id="upload-error-banner">
          <div class="upload-error-icon">
            <i data-lucide="alert-triangle"></i>
          </div>
          <div class="upload-error-content">
            <h4 class="upload-error-title" id="upload-error-title"><%= t('searchResults.excel.fileTooLarge') %></h4>
            <p class="upload-error-message" id="upload-error-message"></p>
            <div class="upload-error-details" id="upload-error-details"></div>
          </div>
          <button class="upload-error-dismiss" id="upload-error-dismiss">
            <i data-lucide="x"></i>
          </button>
        </div>

        <div class="upload-area ai-upload-area" id="upload-area">
          <input type="file" id="excel-file-input" accept=".xlsx,.xls,.csv" hidden>
          <div class="ai-upload-visual">
            <div class="ai-upload-icon-wrapper">
              <div class="ai-upload-glow"></div>
              <i data-lucide="upload-cloud"></i>
            </div>
            <div class="ai-upload-sparkles">
              <i data-lucide="sparkles" class="sparkle s1"></i>
              <i data-lucide="sparkles" class="sparkle s2"></i>
              <i data-lucide="sparkles" class="sparkle s3"></i>
            </div>
          </div>
          
          <h4 class="upload-title"><%= t('searchResults.excel.dragDrop') %></h4>
          <p class="upload-subtitle"><%= t('searchResults.excel.aiExtract') %></p>
          
          <button class="btn-primary ai-browse-btn" id="browse-file-btn">
            <i data-lucide="folder-open"></i>
            <span><%= t('searchResults.excel.browseFiles') %></span>
          </button>
          
          <p class="upload-hint">
            <i data-lucide="check-circle"></i>
            <%= t('searchResults.excel.supportedFormats') %>
          </p>
        </div>

        <div class="sample-format ai-sample-format">
          <div class="sample-header">
            <i data-lucide="info"></i>
            <span><%= t('searchResults.excel.formatHint') %></span>
          </div>
          <a href="/api/download-sample-excel" class="download-sample" download>
            <i data-lucide="download"></i>
            <span><%= t('searchResults.excel.downloadSample') %></span>
          </a>
        </div>
      </div>

      <!-- Step 2: AI Analyzing -->
      <div class="ai-excel-step hidden" id="excel-step-analyzing">
        <div class="ai-analyzing-container">
          <div class="ai-analyzing-visual">
            <div class="ai-brain-pulse">
              <i data-lucide="brain"></i>
            </div>
            <div class="ai-analyzing-rings">
              <div class="ring r1"></div>
              <div class="ring r2"></div>
              <div class="ring r3"></div>
            </div>
          </div>
          
          <div class="ai-analyzing-content">
            <h4 class="ai-analyzing-title"><%= t('searchResults.excel.analyzing') %></h4>
            <p class="ai-analyzing-file" id="analyzing-file-name">processing file.xlsx</p>
            
            <div class="ai-analyzing-steps">
              <div class="ai-step" id="ai-step-reading">
                <div class="ai-step-icon"><i data-lucide="file-search"></i></div>
                <span><%= t('searchResults.excel.readingData') %></span>
                <div class="ai-step-status"><i data-lucide="loader-2" class="spin"></i></div>
              </div>
              <div class="ai-step" id="ai-step-detecting">
                <div class="ai-step-icon"><i data-lucide="scan-search"></i></div>
                <span><%= t('searchResults.excel.detectingParts') %></span>
                <div class="ai-step-status"></div>
              </div>
              <div class="ai-step" id="ai-step-extracting">
                <div class="ai-step-icon"><i data-lucide="wand-2"></i></div>
                <span><%= t('searchResults.excel.extractingData') %></span>
                <div class="ai-step-status"></div>
              </div>
              <div class="ai-step" id="ai-step-validating">
                <div class="ai-step-icon"><i data-lucide="check-circle"></i></div>
                <span><%= t('searchResults.excel.validating') %></span>
                <div class="ai-step-status"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: AI Results Preview -->
      <div class="ai-excel-step hidden" id="excel-step-results">
        <!-- AI Summary Banner -->
        <div class="ai-results-summary">
          <div class="ai-summary-icon">
            <i data-lucide="sparkles"></i>
          </div>
          <div class="ai-summary-content">
            <h4 class="ai-summary-title" id="ai-summary-title"><%= t('searchResults.excel.analysisComplete') %></h4>
            <p class="ai-summary-text" id="ai-summary-text"><%= t('searchResults.excel.partsReady') %></p>
          </div>
          <div class="ai-summary-badge" id="ai-summary-badge">
            <i data-lucide="zap"></i>
            <span><%= t('searchResults.excel.aiPowered') %></span>
          </div>
        </div>

        <!-- Data Quality Indicator -->
        <div class="ai-data-quality" id="ai-data-quality">
          <div class="quality-meter">
            <div class="quality-label"><%= t('searchResults.excel.dataQuality') %></div>
            <div class="quality-bar">
              <div class="quality-fill" id="quality-fill"></div>
            </div>
            <div class="quality-text" id="quality-text"><%= t('searchResults.excel.qualityGood') %></div>
          </div>
          <div class="quality-issues hidden" id="quality-issues">
            <i data-lucide="alert-circle"></i>
            <span id="quality-issues-text"></span>
          </div>
        </div>

        <!-- Parts List Header -->
        <div class="ai-parts-header">
          <div class="parts-header-left">
            <label class="select-all-checkbox">
              <input type="checkbox" id="select-all-parts" checked>
              <span class="checkbox-custom"></span>
              <span class="checkbox-label"><%= t('searchResults.excel.selectAll') %></span>
            </label>
            <label class="select-all-checkbox select-first-option hidden" id="select-first-1000-label">
              <input type="checkbox" id="select-first-1000">
              <span class="checkbox-custom"></span>
              <span class="checkbox-label"><%= t('searchResults.excel.selectFirst1000') %></span>
            </label>
            <span class="parts-count" id="parts-count"><%= t('searchResults.excel.partsSelected') %></span>
          </div>
          <div class="parts-header-right">
            <div class="parts-filter">
              <button class="filter-btn active" data-filter="all"><%= t('searchResults.excel.filterAll') %></button>
              <button class="filter-btn" data-filter="high"><%= t('searchResults.excel.filterHigh') %></button>
              <button class="filter-btn" data-filter="medium"><%= t('searchResults.excel.filterMedium') %></button>
              <button class="filter-btn" data-filter="low"><%= t('searchResults.excel.filterLow') %></button>
            </div>
          </div>
        </div>

        <!-- Parts List -->
        <div class="ai-parts-list" id="ai-parts-list">
          <!-- Parts will be dynamically inserted here -->
        </div>

        <!-- AI Suggestions -->
        <div class="ai-suggestions hidden" id="ai-suggestions">
          <div class="suggestions-header">
            <i data-lucide="lightbulb"></i>
            <span><%= t('searchResults.excel.aiSuggestions') %></span>
          </div>
          <ul class="suggestions-list" id="suggestions-list">
          </ul>
        </div>
      </div>

      <!-- Step 4: Search Results with Recommendations -->
      <div class="ai-excel-step hidden" id="excel-step-search-results">
        <!-- Analytics Summary -->
        <div class="excel-analytics" id="excel-analytics">
          <div class="analytics-header">
            <h4><%= t('searchResults.excel.importAnalytics') %></h4>
            <span class="analytics-filename" id="analytics-filename">file.xlsx</span>
          </div>
          
          <!-- Stats Cards -->
          <div class="analytics-stats">
            <div class="stat-card stat-total">
              <div class="stat-icon">
                <i data-lucide="file-spreadsheet"></i>
              </div>
              <div class="stat-content">
                <div class="stat-value" id="stat-total">0</div>
                <div class="stat-label"><%= t('searchResults.excel.totalParts') %></div>
              </div>
            </div>
            <div class="stat-card stat-found">
              <div class="stat-icon">
                <i data-lucide="check-circle"></i>
              </div>
              <div class="stat-content">
                <div class="stat-value" id="stat-found">0</div>
                <div class="stat-label"><%= t('searchResults.excel.found') %></div>
              </div>
              <div class="stat-percent stat-percent-found" id="stat-percent-found">0%</div>
            </div>
            <div class="stat-card stat-not-found">
              <div class="stat-icon">
                <i data-lucide="x-circle"></i>
              </div>
              <div class="stat-content">
                <div class="stat-value" id="stat-not-found">0</div>
                <div class="stat-label"><%= t('searchResults.excel.notFound') %></div>
              </div>
              <div class="stat-percent stat-percent-not-found" id="stat-percent-not-found">0%</div>
            </div>
            <div class="stat-card stat-duplicates hidden" id="stat-duplicates-card">
              <div class="stat-icon">
                <i data-lucide="copy"></i>
              </div>
              <div class="stat-content">
                <div class="stat-value" id="stat-duplicates">0</div>
                <div class="stat-label"><%= t('searchResults.excel.duplicates') %></div>
              </div>
              <div class="stat-note"><%= t('searchResults.excel.notCounted') %></div>
            </div>
          </div>
          
          <!-- Success Rate Bar -->
          <div class="success-rate-container">
            <div class="success-rate-header">
              <span class="success-rate-label"><%= t('searchResults.excel.successRate') %></span>
              <span class="success-rate-value" id="success-rate-value">0%</span>
            </div>
            <div class="success-rate-bar">
              <div class="success-rate-fill" id="success-rate-fill"></div>
            </div>
          </div>
          
          <!-- Not Found Parts List -->
          <div class="not-found-section hidden" id="not-found-section">
            <div class="not-found-header">
              <i data-lucide="alert-triangle"></i>
              <span><%= t('searchResults.excel.partsNotFound') %></span>
              <button class="not-found-toggle" id="not-found-toggle">
                <i data-lucide="chevron-down"></i>
              </button>
            </div>
            <div class="not-found-list" id="not-found-list">
              <!-- Not found parts will be listed here -->
            </div>
          </div>
          
          <!-- Duplicates Warning -->
          <div class="duplicates-section hidden" id="duplicates-section">
            <div class="duplicates-header">
              <i data-lucide="info"></i>
              <span><%= t('searchResults.excel.duplicatesDetected') %></span>
              <button class="duplicates-toggle" id="duplicates-toggle">
                <i data-lucide="chevron-down"></i>
              </button>
            </div>
            <div class="duplicates-list" id="duplicates-list">
              <!-- Duplicates will be listed here -->
            </div>
          </div>
        </div>

        <div class="ai-search-header">
          <div class="search-header-left">
            <h4><%= t('searchResults.excel.searchResultsTitle') %></h4>
            <p class="search-summary" id="search-summary"><%= t('searchResults.excel.foundOptions') %></p>
          </div>
          <div class="search-header-right">
            <button class="btn-secondary" id="back-to-parts-btn">
              <i data-lucide="arrow-left"></i>
              <span><%= t('searchResults.excel.backToParts') %></span>
            </button>
          </div>
        </div>

        <!-- Recommendations List -->
        <div class="ai-recommendations-list" id="ai-recommendations-list">
          <!-- Recommendations will be dynamically inserted here -->
        </div>
      </div>
    </div>

    <!-- Modal Footer -->
    <div class="modal-footer ai-excel-footer">
      <div class="footer-left">
        <button class="btn-secondary hidden" id="excel-reset-btn">
          <i data-lucide="rotate-ccw"></i>
          <span><%= t('searchResults.excel.uploadNewFile') %></span>
        </button>
      </div>
      <div class="footer-right">
        <button class="btn-secondary" id="excel-cancel-btn">
          <%= t('common.cancel') %>
        </button>
        <button class="btn-primary ai-search-btn hidden" id="excel-search-btn">
          <i data-lucide="search"></i>
          <span><%= t('searchResults.excel.searchParts') %></span>
          <span class="search-count" id="excel-search-count">0</span>
        </button>
        <button class="btn-primary ai-cart-btn hidden" id="excel-add-cart-btn">
          <i data-lucide="shopping-cart"></i>
          <span><%= t('searchResults.excel.addToCartBtn') %></span>
          <span class="cart-count" id="excel-cart-count">0</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Recent Searches Modal -->
<div class="modal" id="recent-searches-modal">
  <div class="modal-overlay" id="recent-searches-overlay"></div>
  <div class="modal-container modal-sm">
    <div class="modal-header">
      <h3 class="modal-title">
        <i data-lucide="clock"></i>
        <span><%= t('searchResults.recentSearches.title') %></span>
      </h3>
      <button class="modal-close" id="recent-searches-close">
        <i data-lucide="x"></i>
      </button>
    </div>
    <div class="modal-body">
      <div class="recent-searches-list" id="recent-searches-list">
        <!-- Recent searches will be populated here -->
        <div class="recent-search-empty">
          <i data-lucide="search"></i>
          <p><%= t('searchResults.recentSearches.empty') %></p>
        </div>
      </div>
      <button class="btn-clear-history hidden" id="clear-search-history">
        <i data-lucide="trash-2"></i>
        <%= t('searchResults.recentSearches.clearHistory') %>
      </button>
    </div>
  </div>
</div>
