<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= dir %>">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="theme-color" content="#2B2B2B">
  <title><%= typeof title !== 'undefined' ? title : t('common.messages.loading') + ' - PARTSFORM' %></title>

  <!-- Favicon — Brand Turbine Icon -->
  <link rel="icon" type="image/png" href="/images/brand/icon-gold.png">

  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@0.294.0/dist/umd/lucide.min.js"></script>

  <!-- Brand System (fonts, tokens, utilities) -->
  <link rel="stylesheet" href="/css/brand-system.css">

  <!-- Main Stylesheet -->
  <link rel="stylesheet" href="/css/styles.css">

  <!-- Buyer Navbar — Glassy, brand system -->
  <link rel="stylesheet" href="/css/buyerCSS/navbar-buyer.css">
  
  <!-- RTL Stylesheet for Arabic -->
  <% if (isRTL) { %>
  <link rel="stylesheet" href="/css/rtl.css">
  <% } %>
</head>

<body class="<%= isRTL ? 'rtl-mode' : 'ltr-mode' %>">
