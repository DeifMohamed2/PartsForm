    <!-- ====================================
         FOOTER — Minimal Bar
         ==================================== -->
    <footer class="footer">
        <div class="footer-nav">
            <div class="footer-nav-left">
                <a href="#about" class="footer-nav-link">ABOUT</a>
                <a href="#contact" class="footer-nav-link">CONTACT</a>
                <a href="#careers" class="footer-nav-link">CAREERS</a>
            </div>
            <div class="footer-logo-center">
                <img src="/images/brand/icon-light.png" alt="PARTSFORM" class="footer-logo-icon">
            </div>
            <div class="footer-nav-right">
                <a href="#how-it-works" class="footer-nav-link">HOW IT WORKS</a>
                <a href="#referral" class="footer-nav-link">REFERRAL PROGRAM</a>
                <a href="#support" class="footer-nav-link">SUPPORT</a>
            </div>
        </div>
        <div class="footer-copyright-bar">
            <span class="footer-copyright-text">©<%= new Date().getFullYear() %> - PartsForm | All right reserved</span>
        </div>
    </footer>

    <!-- Scroll to top — fixed, separate from footer -->
    <button type="button" class="scroll-top-fixed hidden" id="footer-scroll-top" aria-label="Scroll to top">
        <i data-lucide="arrow-up"></i>
    </button>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof lucide !== 'undefined') {
          lucide.createIcons();
        }
        var scrollTopBtn = document.getElementById('footer-scroll-top');
        if (scrollTopBtn) {
          scrollTopBtn.addEventListener('click', function() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
          window.addEventListener('scroll', function() {
            if (window.scrollY > 400) {
              scrollTopBtn.classList.remove('hidden');
            } else {
              scrollTopBtn.classList.add('hidden');
            }
          });
        }
      });
    </script>
</body>
</html>
