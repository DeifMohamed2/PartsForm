<!DOCTYPE html>
<html lang="<%= typeof currentLang !== 'undefined' ? currentLang : 'en' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Error' %> | PartsForm</title>
    <link rel="icon" type="image/webp" href="/images/PARTSFORM-LOGO.webp">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        
        /* Navigation */
        .error-nav {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
            padding: 1rem 2rem;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }
        
        .error-nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .error-nav-logo {
            display: flex;
            align-items: center;
            text-decoration: none;
        }
        
        .error-nav-logo img {
            height: 36px;
            width: auto;
        }
        
        .error-nav-links {
            display: flex;
            align-items: center;
            gap: 2rem;
        }
        
        .error-nav-link {
            color: #475569;
            text-decoration: none;
            font-size: 0.9375rem;
            font-weight: 500;
            transition: color 0.2s ease;
        }
        
        .error-nav-link:hover {
            color: #1e40af;
        }
        
        .error-nav-btn {
            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
            color: white;
            padding: 0.625rem 1.25rem;
            border-radius: 8px;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 600;
            transition: all 0.2s ease;
            box-shadow: 0 2px 8px rgba(30, 64, 175, 0.25);
        }
        
        .error-nav-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(30, 64, 175, 0.35);
        }
        
        /* Main Content */
        .error-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8rem 2rem 4rem;
        }
        
        .error-card {
            background: white;
            border-radius: 24px;
            padding: 3.5rem;
            max-width: 540px;
            width: 100%;
            text-align: center;
            box-shadow: 
                0 4px 6px -1px rgba(0, 0, 0, 0.05),
                0 10px 15px -3px rgba(0, 0, 0, 0.08),
                0 20px 25px -5px rgba(0, 0, 0, 0.05);
        }
        
        .error-icon-wrapper {
            width: 120px;
            height: 120px;
            margin: 0 auto 2rem;
            position: relative;
        }
        
        .error-icon-bg {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            opacity: 0.1;
        }
        
        .error-icon-bg.is-404 {
            background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
        }
        
        .error-icon-bg.is-error {
            background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
        }
        
        .error-icon {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .error-icon svg {
            width: 56px;
            height: 56px;
        }
        
        .error-icon.is-404 svg {
            color: #f59e0b;
        }
        
        .error-icon.is-error svg {
            color: #ef4444;
        }
        
        .error-code {
            font-size: 4.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1e293b 0%, #475569 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
            margin-bottom: 0.75rem;
        }
        
        .error-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 1rem;
        }
        
        .error-description {
            font-size: 1rem;
            color: #64748b;
            line-height: 1.6;
            margin-bottom: 2rem;
        }
        
        .error-reference {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #f1f5f9;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.8125rem;
            color: #64748b;
            margin-bottom: 2rem;
        }
        
        .error-reference code {
            font-family: 'SF Mono', 'Fira Code', monospace;
            color: #475569;
            font-size: 0.75rem;
        }
        
        .error-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .btn-primary-error {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
            color: white;
            padding: 0.875rem 1.75rem;
            border-radius: 12px;
            text-decoration: none;
            font-size: 0.9375rem;
            font-weight: 600;
            transition: all 0.2s ease;
            box-shadow: 0 4px 14px rgba(30, 64, 175, 0.3);
        }
        
        .btn-primary-error:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(30, 64, 175, 0.4);
        }
        
        .btn-secondary-error {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #f1f5f9;
            color: #475569;
            padding: 0.875rem 1.75rem;
            border-radius: 12px;
            text-decoration: none;
            font-size: 0.9375rem;
            font-weight: 600;
            transition: all 0.2s ease;
            border: 1px solid #e2e8f0;
        }
        
        .btn-secondary-error:hover {
            background: #e2e8f0;
            border-color: #cbd5e1;
        }
        
        /* Footer */
        .error-footer {
            text-align: center;
            padding: 1.5rem 2rem;
            color: #94a3b8;
            font-size: 0.875rem;
        }
        
        .error-footer a {
            color: #64748b;
            text-decoration: none;
            transition: color 0.2s ease;
        }
        
        .error-footer a:hover {
            color: #1e40af;
        }
        
        /* Responsive */
        @media (max-width: 640px) {
            .error-nav-links {
                display: none;
            }
            
            .error-card {
                padding: 2rem 1.5rem;
                border-radius: 16px;
            }
            
            .error-code {
                font-size: 3.5rem;
            }
            
            .error-title {
                font-size: 1.25rem;
            }
            
            .error-actions {
                flex-direction: column;
            }
            
            .btn-primary-error,
            .btn-secondary-error {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="error-nav">
        <div class="error-nav-container">
            <a href="/" class="error-nav-logo">
                <img src="/images/PARTSFORM-LOGO.webp" alt="PartsForm">
            </a>
            <div class="error-nav-links">
                <a href="/" class="error-nav-link">Home</a>
                <a href="/#sectors" class="error-nav-link">Services</a>
                <a href="/#about" class="error-nav-link">About</a>
                <a href="/#contact" class="error-nav-link">Contact</a>
                <% if (typeof user !== 'undefined' && user) { %>
                <a href="<%= (typeof userRole !== 'undefined' && userRole === 'admin') ? '/admin' : '/buyer' %>" class="error-nav-btn">Dashboard</a>
                <% } else { %>
                <a href="/login" class="error-nav-btn">Sign In</a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="error-content">
        <div class="error-card">
            <% const is404 = typeof error !== 'undefined' && error === 'Page Not Found'; %>
            
            <div class="error-icon-wrapper">
                <div class="error-icon-bg <%= is404 ? 'is-404' : 'is-error' %>"></div>
                <div class="error-icon <%= is404 ? 'is-404' : 'is-error' %>">
                    <% if (is404) { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="m21 21-4.35-4.35"/>
                        <path d="m9 9 4 4"/>
                        <path d="m13 9-4 4"/>
                    </svg>
                    <% } else { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <% } %>
                </div>
            </div>
            
            <% if (is404) { %>
            <div class="error-code">404</div>
            <h1 class="error-title">Page Not Found</h1>
            <p class="error-description">
                The page you're looking for doesn't exist or may have been moved. 
                Let's get you back on track.
            </p>
            <% } else { %>
            <div class="error-code">Oops!</div>
            <h1 class="error-title"><%= typeof error !== 'undefined' && error ? error : 'Something went wrong' %></h1>
            <p class="error-description">
                We encountered an unexpected error. Please try again or contact our support team if the problem persists.
            </p>
            <% } %>
            
            <% if (typeof requestId !== 'undefined' && requestId) { %>
            <div class="error-reference">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
                Reference: <code><%= requestId %></code>
            </div>
            <% } %>
            
            <div class="error-actions">
                <a href="/" class="btn-primary-error">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    Back to Home
                </a>
                <a href="javascript:history.back()" class="btn-secondary-error">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"/>
                        <polyline points="12 19 5 12 12 5"/>
                    </svg>
                    Go Back
                </a>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="error-footer">
        <p>&copy; <%= new Date().getFullYear() %> PartsForm. <a href="/#contact">Need help?</a></p>
    </footer>
</body>
</html>

