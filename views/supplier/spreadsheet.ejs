<%- include('partials/header', { currentPage: 'tables', pageTitle: 'Edit Table' }) %>

<!-- Toolbar -->
<div class="spreadsheet-toolbar">
  <div class="toolbar-left">
    <a href="/supplier/tables" class="btn btn-secondary btn-sm">
      <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i>
      Back
    </a>
    <div class="toolbar-divider"></div>
    <h2 class="table-title" id="tableTitle">Loading...</h2>
    <span class="record-count" id="recordCount"></span>
  </div>
  
  <div class="toolbar-right">
    <div class="toolbar-group">
      <button class="toolbar-btn" onclick="undoChange()" title="Undo (Ctrl+Z)" id="undoBtn" disabled>
        <i data-lucide="undo-2"></i>
      </button>
      <button class="toolbar-btn" onclick="redoChange()" title="Redo (Ctrl+Y)" id="redoBtn" disabled>
        <i data-lucide="redo-2"></i>
      </button>
    </div>
    
    <div class="toolbar-divider"></div>
    
    <div class="toolbar-group">
      <button class="toolbar-btn" onclick="addRow()" title="Add Row">
        <i data-lucide="plus"></i>
        Add Row
      </button>
      <button class="toolbar-btn danger" onclick="deleteSelectedRows()" title="Delete Selected">
        <i data-lucide="trash-2"></i>
      </button>
    </div>
    
    <div class="toolbar-divider"></div>
    
    <div class="toolbar-group">
      <button class="toolbar-btn" onclick="openImportModal()" title="Import">
        <i data-lucide="upload"></i>
        Import
      </button>
      <button class="toolbar-btn" onclick="exportData('xlsx')" title="Export">
        <i data-lucide="download"></i>
        Export
      </button>
    </div>
    
    <div class="toolbar-divider"></div>
    
    <button class="btn btn-primary btn-sm" onclick="saveAllChanges()" id="saveBtn" disabled>
      <i data-lucide="save" style="width: 16px; height: 16px;"></i>
      Save Changes
      <span class="change-badge" id="changeBadge" style="display: none;">0</span>
    </button>
  </div>
</div>

<!-- Search/Filter Bar -->
<div class="filter-bar">
  <div class="filter-left">
    <div style="position: relative;">
      <i data-lucide="search" style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--text-secondary);"></i>
      <input type="text" id="searchInput" placeholder="Search records..." class="form-input" style="padding-left: 36px; width: 240px; height: 36px; font-size: 13px;">
    </div>
    
    <select id="columnFilter" class="form-input form-select" style="height: 36px; font-size: 13px; width: 160px;">
      <option value="">Filter by column...</option>
    </select>
    
    <input type="text" id="filterValue" placeholder="Filter value..." class="form-input" style="height: 36px; font-size: 13px; width: 180px; display: none;">
    
    <button class="btn btn-secondary btn-sm" onclick="applyFilter()" id="applyFilterBtn" style="display: none;">Apply</button>
    <button class="btn btn-secondary btn-sm" onclick="clearFilter()" id="clearFilterBtn" style="display: none;">Clear</button>
  </div>
  
  <div class="filter-right">
    <span class="showing-text" id="showingText"></span>
  </div>
</div>

<!-- Spreadsheet Container -->
<div class="spreadsheet-container">
  <div id="spreadsheet"></div>
</div>

<!-- Status Bar -->
<div class="status-bar">
  <div class="status-left">
    <span id="selectionInfo">Ready</span>
  </div>
  <div class="status-right">
    <span id="lastSaved">Not saved yet</span>
    <span class="status-divider">|</span>
    <span id="connectionStatus" class="status-connected">
      <i data-lucide="wifi" style="width: 14px; height: 14px;"></i>
      Connected
    </span>
  </div>
</div>

<!-- Import Modal -->
<div class="modal-overlay" id="importModal">
  <div class="modal" style="max-width: 600px;">
    <div class="modal-header">
      <h3 class="modal-title">Import Data</h3>
      <button class="modal-close" onclick="closeModal('importModal')">
        <i data-lucide="x" style="width: 20px; height: 20px;"></i>
      </button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Select File (Excel or CSV)</label>
        <input type="file" id="importFile" accept=".xlsx,.xls,.csv" class="form-input">
      </div>
      
      <div class="form-group">
        <label class="form-label">Import Mode</label>
        <select id="importMode" class="form-input form-select">
          <option value="append">Append - Add new records to existing data</option>
          <option value="replace">Replace - Clear existing data and import fresh</option>
          <option value="update">Update - Update matching records by key column</option>
        </select>
      </div>
      
      <div class="form-group" id="keyColumnGroup" style="display: none;">
        <label class="form-label">Key Column (for matching)</label>
        <select id="keyColumn" class="form-input form-select"></select>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-secondary" onclick="closeModal('importModal')">Cancel</button>
      <button type="button" class="btn btn-primary" onclick="importData()">Import</button>
    </div>
  </div>
</div>

<!-- Version History Modal -->
<div class="modal-overlay" id="historyModal">
  <div class="modal" style="max-width: 700px;">
    <div class="modal-header">
      <h3 class="modal-title">Version History</h3>
      <button class="modal-close" onclick="closeModal('historyModal')">
        <i data-lucide="x" style="width: 20px; height: 20px;"></i>
      </button>
    </div>
    <div class="modal-body" id="historyContent">
      <div class="loading">
        <div class="spinner"></div>
      </div>
    </div>
  </div>
</div>

