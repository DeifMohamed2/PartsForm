<%- include('partials/header', { currentPage: 'tables', pageTitle: 'My Tables' }) %>

<!-- Action Bar -->
<div class="card" style="padding: 16px 24px; margin-bottom: 24px;">
  <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
    <div style="display: flex; align-items: center; gap: 16px;">
      <div style="position: relative;">
        <i data-lucide="search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 18px; height: 18px; color: var(--text-secondary);"></i>
        <input type="text" id="searchInput" placeholder="Search tables..." class="form-input" style="padding-left: 40px; width: 280px;">
      </div>
    </div>
    
    <div style="display: flex; gap: 12px;">
      <button class="btn btn-secondary" onclick="openModal('createTableModal')">
        <i data-lucide="plus" style="width: 18px; height: 18px;"></i>
        Create Table
      </button>
    </div>
  </div>
</div>

<!-- Tables List -->
<div id="tablesContainer">
  <div class="loading">
    <div class="spinner"></div>
  </div>
</div>

<!-- Create Table Modal -->
<div class="modal-overlay" id="createTableModal">
  <div class="modal" style="max-width: 700px;">
    <div class="modal-header">
      <h3 class="modal-title">Create New Table</h3>
      <button class="modal-close" onclick="closeModal('createTableModal')">
        <i data-lucide="x" style="width: 20px; height: 20px;"></i>
      </button>
    </div>
    <div class="modal-body">
      <form id="createTableForm">
        <div class="form-group">
          <label class="form-label">Table Name *</label>
          <input type="text" name="name" class="form-input" placeholder="e.g., Parts Inventory" required>
        </div>
        
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-input" rows="2" placeholder="What is this table for?"></textarea>
        </div>
        
        <div class="form-group">
          <label class="form-label">Columns *</label>
          <div id="columnsContainer">
            <!-- Column rows will be added here -->
          </div>
          <button type="button" class="btn btn-secondary btn-sm" onclick="addColumnRow()" style="margin-top: 12px;">
            <i data-lucide="plus" style="width: 16px; height: 16px;"></i>
            Add Column
          </button>
        </div>
        
        <div class="form-group">
          <label class="form-label">
            <input type="checkbox" name="enableSftp" style="margin-right: 8px;">
            Enable automatic SFTP export
          </label>
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-secondary" onclick="closeModal('createTableModal')">Cancel</button>
      <button type="button" class="btn btn-primary" onclick="createTable()">Create Table</button>
    </div>
  </div>
</div>

<style>
  .table-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: border-color 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }
  
  .table-card:hover {
    border-color: var(--primary);
    box-shadow: 0 2px 8px rgba(12, 74, 110, 0.1);
  }
  
  .table-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: rgba(14, 165, 233, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--info);
    flex-shrink: 0;
  }
  
  .table-details {
    flex: 1;
  }
  
  .table-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  
  .table-description {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }
  
  .table-stats {
    display: flex;
    gap: 16px;
    font-size: 13px;
    color: var(--text-secondary);
  }
  
  .table-stat {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .table-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }
  
  .column-row {
    display: grid;
    grid-template-columns: 1fr 120px 100px 40px;
    gap: 8px;
    margin-bottom: 8px;
    align-items: center;
  }
  
  .column-row input,
  .column-row select {
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 13px;
  }
  
  .remove-column {
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--danger);
    cursor: pointer;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .remove-column:hover {
    background: rgba(239, 68, 68, 0.1);
  }
</style>

<script>
  let tables = [];
  
  document.addEventListener('DOMContentLoaded', async () => {
    addColumnRow(); // Add initial column
    addColumnRow();
    await loadTables();
    
    // Search functionality
    document.getElementById('searchInput').addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      renderTables(tables.filter(t => 
        t.name.toLowerCase().includes(query) || 
        (t.description || '').toLowerCase().includes(query)
      ));
    });
  });
  
  async function loadTables() {
    try {
      const response = await API.get('/tables');
      tables = response.tables || [];
      renderTables(tables);
    } catch (err) {
      console.error('Failed to load tables:', err);
      showToast('Failed to load tables', 'error');
    }
  }
  
  function renderTables(tableList) {
    const container = document.getElementById('tablesContainer');
    
    if (tableList.length === 0) {
      container.innerHTML = `
        <div class="card">
          <div class="empty-state">
            <i data-lucide="table-2" class="empty-state-icon" style="width: 64px; height: 64px;"></i>
            <div class="empty-state-title">No tables found</div>
            <div class="empty-state-description">Create your first table to start organizing your data</div>
            <button class="btn btn-primary" onclick="openModal('createTableModal')">
              <i data-lucide="plus" style="width: 18px; height: 18px;"></i>
              Create Your First Table
            </button>
          </div>
        </div>
      `;
      lucide.createIcons();
      return;
    }
    
    container.innerHTML = tableList.map(table => `
      <div class="table-card" onclick="openTable('${table._id}')">
        <div class="table-icon">
          <i data-lucide="table-2" style="width: 24px; height: 24px;"></i>
        </div>
        <div class="table-details">
          <div class="table-name">${table.name}</div>
          ${table.description ? `<div class="table-description">${table.description}</div>` : ''}
          <div class="table-stats">
            <span class="table-stat">
              <i data-lucide="database" style="width: 14px; height: 14px;"></i>
              ${formatNumber(table.recordCount || 0)} records
            </span>
            <span class="table-stat">
              <i data-lucide="columns" style="width: 14px; height: 14px;"></i>
              ${table.columns?.length || 0} columns
            </span>
            <span class="table-stat">
              <i data-lucide="clock" style="width: 14px; height: 14px;"></i>
              Updated ${formatDate(table.updatedAt)}
            </span>
          </div>
        </div>
        <div class="table-actions" onclick="event.stopPropagation()">
          <button class="btn btn-secondary btn-sm" onclick="exportTable('${table._id}', 'xlsx')" title="Export to Excel">
            <i data-lucide="download" style="width: 16px; height: 16px;"></i>
          </button>
          <button class="btn btn-secondary btn-sm" onclick="openTableSettings('${table._id}')" title="Settings">
            <i data-lucide="settings" style="width: 16px; height: 16px;"></i>
          </button>
          <button class="btn btn-danger btn-sm" onclick="confirmDeleteTable('${table._id}', '${table.name}')" title="Delete">
            <i data-lucide="trash-2" style="width: 16px; height: 16px;"></i>
          </button>
        </div>
      </div>
    `).join('');
    
    lucide.createIcons();
  }
  
  function openTable(tableId) {
    window.location.href = `/supplier/tables/${tableId}`;
  }
  
  function openTableSettings(tableId) {
    window.location.href = `/supplier/tables/${tableId}/settings`;
  }
  
  async function exportTable(tableId, format) {
    try {
      showToast('Starting export...', 'success');
      const response = await API.post(`/tables/${tableId}/export`, { format });
      showToast('Export completed!', 'success');
      
      // Trigger download if URL provided
      if (response.export?.filePath) {
        window.location.href = `/api/supplier/exports/${response.export._id}/download`;
      }
    } catch (err) {
      showToast('Export failed: ' + err.message, 'error');
    }
  }
  
  function confirmDeleteTable(tableId, tableName) {
    if (confirm(`Are you sure you want to delete "${tableName}"? This will also delete all records. This action cannot be undone.`)) {
      deleteTable(tableId);
    }
  }
  
  async function deleteTable(tableId) {
    try {
      await API.delete(`/tables/${tableId}`);
      showToast('Table deleted successfully', 'success');
      await loadTables();
    } catch (err) {
      showToast('Failed to delete table: ' + err.message, 'error');
    }
  }
  
  // Column management
  let columnCount = 0;
  
  function addColumnRow() {
    columnCount++;
    const container = document.getElementById('columnsContainer');
    const row = document.createElement('div');
    row.className = 'column-row';
    row.id = `column-${columnCount}`;
    row.innerHTML = `
      <input type="text" placeholder="Column name" class="column-name" required>
      <select class="column-type">
        <option value="string">Text</option>
        <option value="number">Number</option>
        <option value="date">Date</option>
        <option value="boolean">Yes/No</option>
        <option value="select">Dropdown</option>
        <option value="email">Email</option>
        <option value="url">URL</option>
      </select>
      <label style="display: flex; align-items: center; gap: 4px; font-size: 13px;">
        <input type="checkbox" class="column-required">
        Required
      </label>
      <button type="button" class="remove-column" onclick="removeColumnRow(${columnCount})">
        <i data-lucide="x" style="width: 16px; height: 16px;"></i>
      </button>
    `;
    container.appendChild(row);
    lucide.createIcons();
  }
  
  function removeColumnRow(id) {
    const row = document.getElementById(`column-${id}`);
    if (row) {
      row.remove();
    }
  }
  
  async function createTable() {
    const form = document.getElementById('createTableForm');
    const name = form.name.value.trim();
    const description = form.description.value.trim();
    const enableSftp = form.enableSftp.checked;
    
    if (!name) {
      showToast('Please enter a table name', 'error');
      return;
    }
    
    // Gather columns
    const columnRows = document.querySelectorAll('.column-row');
    const columns = [];
    
    for (const row of columnRows) {
      const colName = row.querySelector('.column-name').value.trim();
      const colType = row.querySelector('.column-type').value;
      const colRequired = row.querySelector('.column-required').checked;
      
      if (colName) {
        columns.push({
          name: colName,
          key: colName.toLowerCase().replace(/\s+/g, '_'),
          type: colType,
          required: colRequired
        });
      }
    }
    
    if (columns.length === 0) {
      showToast('Please add at least one column', 'error');
      return;
    }
    
    try {
      const response = await API.post('/tables', {
        name,
        description,
        columns,
        sftpExport: {
          enabled: enableSftp,
          format: 'csv'
        }
      });
      
      showToast('Table created successfully', 'success');
      closeModal('createTableModal');
      
      // Navigate to the new table
      window.location.href = `/supplier/tables/${response.table._id}`;
    } catch (err) {
      showToast('Failed to create table: ' + err.message, 'error');
    }
  }
</script>

<%- include('partials/footer') %>
