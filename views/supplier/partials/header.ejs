<!DOCTYPE html>
<html lang="en" class="supplier-page">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="PARTSFORM Supplier Portal - Data Management Platform">
  <title><%= title || 'Supplier Portal | PARTSFORM' %></title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/brand/icon-gold.png">
  
  <!-- Brand System - PARTSFORM Shibui Design (must load first) -->
  <link rel="stylesheet" href="/css/brand-system.css">
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@0.294.0/dist/umd/lucide.min.js"></script>
  
  <!-- Handsontable for Excel-like tables -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/handsontable/dist/handsontable.full.min.css">
  <script src="https://cdn.jsdelivr.net/npm/handsontable/dist/handsontable.full.min.js"></script>
  
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <!-- Supplier Portal CSS -->
  <link rel="stylesheet" href="/css/supplierCSS/supplier-main.css">
  <link rel="stylesheet" href="/css/supplierCSS/supplier-components.css">
  <link rel="stylesheet" href="/css/supplierCSS/supplier-dashboard.css">
  <link rel="stylesheet" href="/css/supplierCSS/supplier-spreadsheet.css">
  <link rel="stylesheet" href="/css/supplierCSS/supplier-import.css">
  <link rel="stylesheet" href="/css/supplierCSS/supplier-pages.css">
  <link rel="stylesheet" href="/css/supplierCSS/supplier-overrides.css">
  
  <style>
    /* Enhanced Sidebar Styles */
    .supplier-sidebar {
      background: var(--aitetsu);
      border-right: none;
    }
    
    .sidebar-header {
      padding: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .sidebar-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
    }
    
    .sidebar-logo img {
      height: 40px;
      width: auto;
      object-fit: contain;
    }
    
    .sidebar-nav {
      padding: 16px 12px;
    }
    
    .nav-section {
      margin-bottom: 24px;
    }
    
    .nav-section-title {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--sei);
      padding: 0 12px;
      margin-bottom: 8px;
    }
    
    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      color: rgba(255, 255, 255, 0.85);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      border-radius: 0;
      border-left: 3px solid transparent;
      transition: all 0.2s;
      margin-bottom: 4px;
    }
    
    .nav-item:hover {
      background: rgba(149, 175, 192, 0.2);
      color: var(--washi);
    }
    
    .nav-item.active {
      background: rgba(212, 175, 55, 0.15);
      color: var(--kintsugi);
      font-weight: 600;
      border-left: 3px solid var(--kintsugi);
    }
    
    .nav-item i, .nav-item svg {
      width: 20px;
      height: 20px;
      opacity: 0.9;
    }
    
    .nav-badge {
      margin-left: auto;
      background: var(--kintsugi);
      color: var(--kurogane);
      padding: 2px 8px;
      border-radius: 0;
      font-size: 0.75rem;
      font-weight: 600;
    }
    
    /* Enhanced Topbar — Same as buyer about-us: solid Kurogane (#2B2B2B) */
    .supplier-topbar {
      background: #2B2B2B !important;
      border-bottom: none !important;
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.35) !important;
      padding: 0.5rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    
    .page-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.95);
    }
    
    .topbar-right {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    
    .topbar-btn {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      border-radius: 0;
      color: rgba(255, 255, 255, 0.85);
      cursor: pointer;
      transition: all 0.2s;
    }
    
    .topbar-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      color: #FFFFFF;
    }
    
    .user-menu {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 8px 12px;
      border-radius: 0;
      cursor: pointer;
      transition: all 0.2s;
      margin-left: 8px;
    }
    
    .user-menu:hover {
      background: rgba(255, 255, 255, 0.08);
    }
    
    .user-avatar {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--aitetsu);
      color: white;
      font-weight: 700;
      font-size: 1rem;
      border-radius: 0;
    }
    
    .user-info {
      display: flex;
      flex-direction: column;
    }
    
    .user-name {
      font-weight: 600;
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.95);
    }
    
    .user-company {
      font-size: 0.75rem;
      color: #829AB1;
    }
    
    /* Logout link at bottom */
    .sidebar-footer {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 16px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .logout-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px;
      background: rgba(142, 156, 166, 0.25);
      color: var(--namari);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      border-radius: 0;
      transition: all 0.2s;
    }
    
    .logout-btn:hover {
      background: rgba(142, 156, 166, 0.4);
      color: var(--washi);
    }
  </style>
</head>
<body>
  <div class="supplier-layout">
    <!-- Sidebar -->
    <aside class="supplier-sidebar" id="sidebar">
      <div class="sidebar-header">
        <a href="/supplier" class="sidebar-logo">
          <img src="/images/brand/logo-dark.png" alt="PARTSFORM">
        </a>
      </div>
      
      <nav class="sidebar-nav">
        <div class="nav-section">
          <span class="nav-section-title">Overview</span>
          <a href="/supplier" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
            <i data-lucide="layout-dashboard"></i>
            Dashboard
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Parts Management</span>
          <a href="/supplier/parts" class="nav-item <%= currentPage === 'parts' ? 'active' : '' %>">
            <i data-lucide="boxes"></i>
            My Parts
            <% if (typeof partsCount !== 'undefined' && partsCount > 0) { %>
              <span class="nav-badge"><%= partsCount > 1000 ? Math.floor(partsCount/1000) + 'k' : partsCount %></span>
            <% } %>
          </a>
          <a href="/supplier/import" class="nav-item <%= currentPage === 'import' ? 'active' : '' %>">
            <i data-lucide="upload"></i>
            Upload Parts
          </a>
          <a href="/supplier/files" class="nav-item <%= currentPage === 'files' ? 'active' : '' %>">
            <i data-lucide="folder-open"></i>
            Import Files
          </a>
        </div>
        
        <div class="nav-section">
          <span class="nav-section-title">Account</span>
          <a href="/supplier/settings" class="nav-item <%= currentPage === 'settings' ? 'active' : '' %>">
            <i data-lucide="settings"></i>
            Settings
          </a>
        </div>
      </nav>
      
      <div class="sidebar-footer">
        <a href="/supplier/logout" class="logout-btn" onclick="localStorage.removeItem('supplierToken');">
          <i data-lucide="log-out" style="width: 18px; height: 18px;"></i>
          Sign Out
        </a>
      </div>
    </aside>
    
    <!-- Main Content -->
    <main class="supplier-main">
      <!-- Topbar -->
      <header class="supplier-topbar">
        <div class="topbar-left">
          <h1 class="page-title"><%= pageTitle || 'Dashboard' %></h1>
        </div>
        
        <div class="topbar-right">
          <button class="topbar-btn" title="Refresh" onclick="location.reload()">
            <i data-lucide="refresh-cw" style="width: 18px; height: 18px;"></i>
          </button>
          
          <div class="user-menu" id="userMenu">
            <div class="user-avatar">
              <%= supplier ? supplier.companyName.charAt(0).toUpperCase() : 'S' %>
            </div>
            <div class="user-info">
              <div class="user-name"><%= supplier ? supplier.contactName : 'Supplier' %></div>
              <div class="user-company"><%= supplier ? supplier.companyCode : '' %></div>
            </div>
          </div>
        </div>
      </header>
      
      <!-- Page Content -->
      <div class="supplier-content">
