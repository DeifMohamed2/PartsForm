<%- include('partials/header', { currentPage: 'sftp', pageTitle: 'SFTP Settings' }) %>

<div class="grid grid-2" style="gap: 24px;">
  <!-- Connection Settings -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">SFTP Connection</h3>
      <span class="connection-status" id="connectionStatus">
        <i data-lucide="circle" style="width: 10px; height: 10px;"></i>
        Not configured
      </span>
    </div>
    
    <form id="sftpForm">
      <div class="form-group">
        <label class="form-label">Host *</label>
        <input type="text" name="host" class="form-input" placeholder="sftp.example.com" id="sftpHost">
      </div>
      
      <div class="form-group">
        <label class="form-label">Port</label>
        <input type="number" name="port" class="form-input" placeholder="22" value="22" id="sftpPort">
      </div>
      
      <div class="form-group">
        <label class="form-label">Username *</label>
        <input type="text" name="username" class="form-input" placeholder="your-username" id="sftpUsername">
      </div>
      
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-input" placeholder="Enter password" id="sftpPassword">
        <small style="color: var(--text-secondary); font-size: 12px; margin-top: 4px; display: block;">
          Leave blank to keep existing password
        </small>
      </div>
      
      <div class="form-group">
        <label class="form-label">Remote Directory</label>
        <input type="text" name="directory" class="form-input" placeholder="/uploads" id="sftpDirectory">
      </div>
      
      <div style="display: flex; gap: 12px; margin-top: 24px;">
        <button type="button" class="btn btn-secondary" onclick="testConnection()">
          <i data-lucide="plug" style="width: 18px; height: 18px;"></i>
          Test Connection
        </button>
        <button type="submit" class="btn btn-primary">
          <i data-lucide="save" style="width: 18px; height: 18px;"></i>
          Save Settings
        </button>
      </div>
    </form>
  </div>
  
  <!-- Export Settings -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Automatic Exports</h3>
    </div>
    
    <div class="form-group">
      <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
        <input type="checkbox" id="enableAutoExport">
        <span>Enable automatic exports to SFTP</span>
      </label>
    </div>
    
    <div id="autoExportSettings" style="display: none;">
      <div class="form-group">
        <label class="form-label">Export Schedule</label>
        <select id="exportSchedule" class="form-input form-select">
          <option value="*/30 * * * *">Every 30 minutes</option>
          <option value="0 * * * *">Every hour</option>
          <option value="0 */6 * * *">Every 6 hours</option>
          <option value="0 0 * * *">Daily at midnight</option>
          <option value="0 0 * * 0">Weekly on Sunday</option>
        </select>
      </div>
      
      <div class="form-group">
        <label class="form-label">Export Format</label>
        <select id="exportFormat" class="form-input form-select">
          <option value="csv">CSV</option>
          <option value="xlsx">Excel (XLSX)</option>
          <option value="json">JSON</option>
        </select>
      </div>
      
      <div class="form-group">
        <label class="form-label">Tables to Export</label>
        <div id="tablesList" style="margin-top: 8px;">
          <div class="loading">
            <div class="spinner"></div>
          </div>
        </div>
      </div>
      
      <button type="button" class="btn btn-primary" onclick="saveExportSettings()">
        <i data-lucide="save" style="width: 18px; height: 18px;"></i>
        Save Export Settings
      </button>
    </div>
  </div>
</div>

<!-- Recent Exports -->
<div class="card" style="margin-top: 24px;">
  <div class="card-header">
    <h3 class="card-title">Export History</h3>
    <button class="btn btn-secondary btn-sm" onclick="loadExportHistory()">
      <i data-lucide="refresh-cw" style="width: 16px; height: 16px;"></i>
      Refresh
    </button>
  </div>
  
  <div id="exportHistory">
    <div class="loading">
      <div class="spinner"></div>
    </div>
  </div>
</div>

<style>
  .connection-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-secondary);
  }
  
  .connection-status.connected {
    color: var(--success);
  }
  
  .connection-status.error {
    color: var(--danger);
  }
  
  .table-checkbox {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px;
    background: var(--bg-main);
    border-radius: 6px;
    margin-bottom: 8px;
    cursor: pointer;
  }
  
  .table-checkbox:hover {
    background: var(--border);
  }
  
  .export-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  
  .export-row:last-child {
    border-bottom: none;
  }
  
  .export-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .export-icon.success {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
  }
  
  .export-icon.pending {
    background: rgba(245, 158, 11, 0.1);
    color: var(--warning);
  }
  
  .export-icon.failed {
    background: rgba(239, 68, 68, 0.1);
    color: var(--danger);
  }
  
  .export-details {
    flex: 1;
  }
  
  .export-name {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  
  .export-meta {
    font-size: 13px;
    color: var(--text-secondary);
  }
  
  .export-status {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
  }
  
  .export-status.completed {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
  }
  
  .export-status.pending {
    background: rgba(245, 158, 11, 0.1);
    color: var(--warning);
  }
  
  .export-status.failed {
    background: rgba(239, 68, 68, 0.1);
    color: var(--danger);
  }
</style>

<script>
  let tables = [];
  let sftpConfig = null;
  
  document.addEventListener('DOMContentLoaded', async () => {
    await loadSettings();
    await loadTables();
    await loadExportHistory();
    setupEventListeners();
  });
  
  async function loadSettings() {
    try {
      const response = await API.get('/profile');
      const supplier = response.supplier;
      
      if (supplier.sftpConfig) {
        sftpConfig = supplier.sftpConfig;
        document.getElementById('sftpHost').value = sftpConfig.host || '';
        document.getElementById('sftpPort').value = sftpConfig.port || 22;
        document.getElementById('sftpUsername').value = sftpConfig.username || '';
        document.getElementById('sftpDirectory').value = sftpConfig.remotePath || '';
        
        if (sftpConfig.host) {
          updateConnectionStatus('configured');
        }
      }
    } catch (err) {
      console.error('Failed to load settings:', err);
    }
  }
  
  async function loadTables() {
    try {
      const response = await API.get('/tables');
      tables = response.tables || [];
      
      const container = document.getElementById('tablesList');
      if (tables.length === 0) {
        container.innerHTML = '<p style="color: var(--text-secondary);">No tables available</p>';
        return;
      }
      
      container.innerHTML = tables.map(table => `
        <label class="table-checkbox">
          <input type="checkbox" class="export-table" value="${table._id}" 
            ${table.sftpExport?.enabled ? 'checked' : ''}>
          <div>
            <div style="font-weight: 500;">${table.name}</div>
            <div style="font-size: 12px; color: var(--text-secondary);">${table.recordCount || 0} records</div>
          </div>
        </label>
      `).join('');
    } catch (err) {
      console.error('Failed to load tables:', err);
    }
  }
  
  async function loadExportHistory() {
    try {
      const response = await API.get('/exports?limit=20');
      const exports = response.exports || [];
      
      const container = document.getElementById('exportHistory');
      if (exports.length === 0) {
        container.innerHTML = `
          <div style="text-align: center; padding: 40px; color: var(--text-secondary);">
            <i data-lucide="file-text" style="width: 48px; height: 48px; margin-bottom: 16px;"></i>
            <p>No exports yet</p>
          </div>
        `;
        lucide.createIcons();
        return;
      }
      
      container.innerHTML = exports.map(exp => {
        let iconClass = 'success';
        let statusClass = 'completed';
        let icon = 'check-circle';
        
        if (exp.status === 'pending' || exp.status === 'processing') {
          iconClass = 'pending';
          statusClass = 'pending';
          icon = 'clock';
        } else if (exp.status === 'failed') {
          iconClass = 'failed';
          statusClass = 'failed';
          icon = 'x-circle';
        }
        
        return `
          <div class="export-row">
            <div class="export-icon ${iconClass}">
              <i data-lucide="${icon}" style="width: 20px; height: 20px;"></i>
            </div>
            <div class="export-details">
              <div class="export-name">${exp.fileName || 'Export'}</div>
              <div class="export-meta">
                ${exp.format?.toUpperCase() || 'CSV'} · ${formatFileSize(exp.fileSize || 0)} · ${formatDateTime(exp.createdAt)}
              </div>
            </div>
            <span class="export-status ${statusClass}">${exp.status}</span>
            ${exp.status === 'completed' ? `
              <button class="btn btn-secondary btn-sm" onclick="downloadExport('${exp._id}')">
                <i data-lucide="download" style="width: 16px; height: 16px;"></i>
              </button>
            ` : ''}
          </div>
        `;
      }).join('');
      
      lucide.createIcons();
    } catch (err) {
      console.error('Failed to load export history:', err);
    }
  }
  
  function setupEventListeners() {
    document.getElementById('enableAutoExport').addEventListener('change', (e) => {
      document.getElementById('autoExportSettings').style.display = e.target.checked ? 'block' : 'none';
    });
    
    document.getElementById('sftpForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      await saveSftpSettings();
    });
  }
  
  async function saveSftpSettings() {
    const host = document.getElementById('sftpHost').value.trim();
    const port = parseInt(document.getElementById('sftpPort').value) || 22;
    const username = document.getElementById('sftpUsername').value.trim();
    const password = document.getElementById('sftpPassword').value;
    const directory = document.getElementById('sftpDirectory').value.trim();
    
    if (!host || !username) {
      showToast('Please enter host and username', 'error');
      return;
    }
    
    try {
      await API.put('/sftp/config', {
        host,
        port,
        username,
        password: password || undefined,
        remotePath: directory
      });
      
      showToast('SFTP settings saved successfully', 'success');
      updateConnectionStatus('configured');
    } catch (err) {
      showToast('Failed to save settings: ' + err.message, 'error');
    }
  }
  
  async function testConnection() {
    const host = document.getElementById('sftpHost').value.trim();
    const port = parseInt(document.getElementById('sftpPort').value) || 22;
    const username = document.getElementById('sftpUsername').value.trim();
    const password = document.getElementById('sftpPassword').value;
    
    if (!host || !username) {
      showToast('Please enter host and username', 'error');
      return;
    }
    
    updateConnectionStatus('testing');
    
    try {
      await API.post('/sftp/test', {
        host,
        port,
        username,
        password
      });
      
      updateConnectionStatus('connected');
      showToast('Connection successful!', 'success');
    } catch (err) {
      updateConnectionStatus('error');
      showToast('Connection failed: ' + err.message, 'error');
    }
  }
  
  function updateConnectionStatus(status) {
    const el = document.getElementById('connectionStatus');
    
    switch (status) {
      case 'connected':
        el.className = 'connection-status connected';
        el.innerHTML = '<i data-lucide="check-circle" style="width: 14px; height: 14px;"></i> Connected';
        break;
      case 'error':
        el.className = 'connection-status error';
        el.innerHTML = '<i data-lucide="x-circle" style="width: 14px; height: 14px;"></i> Connection failed';
        break;
      case 'testing':
        el.className = 'connection-status';
        el.innerHTML = '<i data-lucide="loader" style="width: 14px; height: 14px; animation: spin 1s linear infinite;"></i> Testing...';
        break;
      case 'configured':
        el.className = 'connection-status';
        el.innerHTML = '<i data-lucide="circle" style="width: 10px; height: 10px;"></i> Configured';
        break;
      default:
        el.className = 'connection-status';
        el.innerHTML = '<i data-lucide="circle" style="width: 10px; height: 10px;"></i> Not configured';
    }
    
    lucide.createIcons();
  }
  
  async function saveExportSettings() {
    const schedule = document.getElementById('exportSchedule').value;
    const format = document.getElementById('exportFormat').value;
    const selectedTables = Array.from(document.querySelectorAll('.export-table:checked')).map(cb => cb.value);
    
    try {
      // Update each table's export settings
      for (const tableId of selectedTables) {
        await API.put(`/tables/${tableId}`, {
          sftpExport: {
            enabled: true,
            schedule,
            format
          }
        });
      }
      
      // Disable export for unchecked tables
      const uncheckedTables = tables.filter(t => !selectedTables.includes(t._id));
      for (const table of uncheckedTables) {
        if (table.sftpExport?.enabled) {
          await API.put(`/tables/${table._id}`, {
            sftpExport: {
              enabled: false
            }
          });
        }
      }
      
      showToast('Export settings saved successfully', 'success');
    } catch (err) {
      showToast('Failed to save export settings: ' + err.message, 'error');
    }
  }
  
  function downloadExport(exportId) {
    window.location.href = `/api/supplier/exports/${exportId}/download`;
  }
</script>

<%- include('partials/footer') %>
