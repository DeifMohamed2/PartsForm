<%- include('partials/header', { currentPage: 'import', pageTitle: 'Upload Parts' }) %>

<style>
  .import-page {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .upload-hero {
    background: linear-gradient(135deg, var(--supplier-accent) 0%, var(--supplier-accent-dark) 100%);
    border-radius: var(--supplier-radius-xl);
    padding: 48px 40px;
    margin-bottom: var(--supplier-space-lg);
    color: white;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  
  .upload-hero h1 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 12px;
  }
  
  .upload-hero p {
    opacity: 0.9;
    font-size: 1rem;
    max-width: 500px;
    margin: 0 auto;
  }
  
  .upload-card {
    background: var(--supplier-bg-primary);
    border-radius: var(--supplier-radius-lg);
    padding: 48px 40px;
    text-align: center;
    border: 3px dashed var(--supplier-border);
    transition: var(--supplier-transition);
    cursor: pointer;
    margin-bottom: var(--supplier-space-lg);
  }
  
  .upload-card:hover,
  .upload-card.drag-over {
    border-color: var(--supplier-accent);
    background: var(--supplier-bg-accent);
  }
  
  .upload-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--supplier-accent), var(--supplier-accent-dark));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
    box-shadow: var(--supplier-shadow-lg);
  }
  
  .upload-icon svg {
    width: 36px;
    height: 36px;
    color: white;
  }
  
  .upload-card h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--supplier-text-primary);
    margin-bottom: 8px;
  }
  
  .upload-card > p {
    color: var(--supplier-text-muted);
    margin-bottom: 24px;
  }
  
  .upload-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    background: linear-gradient(135deg, var(--supplier-accent), var(--supplier-accent-dark));
    color: white;
    font-weight: 600;
    border-radius: var(--supplier-radius-md);
    border: none;
    cursor: pointer;
    transition: var(--supplier-transition);
    font-size: 1rem;
    box-shadow: var(--supplier-shadow-md);
  }
  
  .upload-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--supplier-shadow-lg);
  }
  
  .file-formats {
    margin-top: 24px;
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  
  .file-format {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--supplier-text-muted);
    font-size: 0.9rem;
    padding: 8px 14px;
    background: var(--supplier-bg-secondary);
    border-radius: var(--supplier-radius-sm);
  }
  
  .file-format svg {
    width: 18px;
    height: 18px;
    color: var(--supplier-success);
  }
  
  /* Processing State */
  .processing-card {
    display: none;
    background: var(--supplier-bg-primary);
    border-radius: var(--supplier-radius-lg);
    padding: 48px 40px;
    text-align: center;
    margin-bottom: var(--supplier-space-lg);
    box-shadow: var(--supplier-shadow-md);
  }
  
  .processing-spinner {
    width: 80px;
    height: 80px;
    margin: 0 auto 24px;
    border: 4px solid var(--supplier-border);
    border-top-color: var(--supplier-accent);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  
  .processing-text {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--supplier-text-primary);
    margin-bottom: 8px;
  }
  
  .processing-file {
    color: var(--supplier-text-muted);
    font-size: 0.9rem;
  }
  
  /* Success State */
  .success-card {
    display: none;
    background: var(--supplier-bg-primary);
    border-radius: var(--supplier-radius-lg);
    padding: 48px 40px;
    text-align: center;
    margin-bottom: var(--supplier-space-lg);
    box-shadow: var(--supplier-shadow-md);
  }
  
  .success-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--supplier-success), #16a34a);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
    box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
  }
  
  .success-icon svg {
    width: 40px;
    height: 40px;
    color: white;
  }
  
  .success-card h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--supplier-text-primary);
    margin-bottom: 8px;
  }
  
  .success-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin: 24px 0;
  }
  
  .success-stat {
    text-align: center;
  }
  
  .success-stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--supplier-accent);
  }
  
  .success-stat-label {
    font-size: 0.85rem;
    color: var(--supplier-text-muted);
    margin-top: 4px;
  }
  
  .success-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 24px;
  }
  
  /* Info Card */
  .info-card {
    background: var(--supplier-bg-primary);
    border-radius: var(--supplier-radius-md);
    padding: 20px;
    margin-bottom: var(--supplier-space-sm);
    box-shadow: var(--supplier-shadow-sm);
  }
  
  .info-card h3 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--supplier-text-primary);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .info-card h3 svg {
    width: 18px;
    height: 18px;
    color: var(--supplier-accent);
  }
  
  .column-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 8px;
  }
  
  .column-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: var(--supplier-bg-secondary);
    border-radius: var(--supplier-radius-sm);
    font-size: 0.85rem;
    color: var(--supplier-text-secondary);
  }
  
  .column-item svg {
    width: 14px;
    height: 14px;
    color: var(--supplier-success);
  }
  
  /* Options */
  .upload-options {
    background: var(--supplier-bg-primary);
    border-radius: var(--supplier-radius-md);
    padding: 20px;
    margin-bottom: var(--supplier-space-lg);
    box-shadow: var(--supplier-shadow-sm);
  }
  
  .option-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--supplier-border-light);
  }
  
  .option-row:last-child {
    border-bottom: none;
  }
  
  .option-label {
    font-weight: 500;
    color: var(--supplier-text-primary);
  }
  
  .option-desc {
    font-size: 0.85rem;
    color: var(--supplier-text-muted);
  }
  
  .toggle {
    width: 48px;
    height: 26px;
    background: var(--supplier-border);
    border-radius: 13px;
    position: relative;
    cursor: pointer;
    transition: var(--supplier-transition-fast);
  }
  
  .toggle.active {
    background: var(--supplier-accent);
  }
  
  .toggle::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 22px;
    background: white;
    border-radius: 50%;
    top: 2px;
    left: 2px;
    transition: var(--supplier-transition-fast);
    box-shadow: var(--supplier-shadow-sm);
  }
  
  .toggle.active::after {
    left: 24px;
  }

  /* Data Options */
  .option-group {
    padding: 16px 0;
  }

  .option-label-main {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--supplier-text-secondary);
    margin-bottom: 14px;
  }

  .data-options {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .data-option {
    display: block;
    padding: 14px;
    border: 2px solid var(--supplier-border);
    border-radius: var(--supplier-radius-md);
    cursor: pointer;
    transition: var(--supplier-transition-fast);
    background: var(--supplier-bg-primary);
  }

  .data-option input {
    display: none;
  }

  .data-option:hover {
    border-color: var(--supplier-border-medium);
    background: var(--supplier-bg-secondary);
  }

  .data-option.selected {
    border-color: var(--supplier-accent);
    background: var(--supplier-info-light);
  }

  .data-option.danger.selected {
    border-color: var(--supplier-danger);
    background: var(--supplier-danger-light);
  }

  .option-content {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .option-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--supplier-radius-md);
    background: var(--supplier-bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .option-icon i {
    width: 18px;
    height: 18px;
    color: var(--supplier-text-muted);
  }

  .data-option.selected .option-icon {
    background: var(--supplier-accent);
  }

  .data-option.selected .option-icon i {
    color: white;
  }

  .data-option.danger.selected .option-icon {
    background: var(--supplier-danger);
  }

  .option-text {
    flex: 1;
  }

  .option-text strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--supplier-text-primary);
    margin-bottom: 2px;
  }

  .option-text span {
    font-size: 0.8rem;
    color: var(--supplier-text-muted);
    line-height: 1.4;
  }

  /* Brand Selection */
  .brand-select-wrapper {
    margin-top: 16px;
    padding: 16px;
    background: var(--supplier-bg-secondary);
    border-radius: var(--supplier-radius-md);
    border: 1px solid var(--supplier-border);
  }

  .brand-checkboxes {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 8px;
    max-height: 200px;
    overflow-y: auto;
  }

  .brand-checkbox {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--supplier-bg-primary);
    border: 1px solid var(--supplier-border);
    border-radius: var(--supplier-radius-sm);
    cursor: pointer;
    transition: var(--supplier-transition-fast);
  }

  .brand-checkbox:hover {
    border-color: var(--supplier-accent);
    background: var(--supplier-info-light);
  }

  .brand-checkbox input {
    accent-color: var(--supplier-accent);
  }

  .brand-checkbox.checked {
    border-color: var(--supplier-accent);
    background: var(--supplier-info-light);
  }

  .brand-name {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--supplier-text-secondary);
    flex: 1;
  }

  .brand-count {
    font-size: 0.75rem;
    color: var(--supplier-text-subtle);
    background: var(--supplier-bg-tertiary);
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* Data Summary */
  .data-summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 12px;
  }

  .summary-item {
    text-align: center;
    padding: 14px;
    background: var(--supplier-bg-secondary);
    border-radius: var(--supplier-radius-md);
  }

  .summary-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--supplier-accent);
  }

  .summary-label {
    font-size: 0.75rem;
    color: var(--supplier-text-muted);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  @media (max-width: 640px) {
    .data-options {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="import-page">
  <!-- Hero -->
  <div class="upload-hero">
    <h1>Upload Your Parts</h1>
    <p>Import your inventory from Excel or CSV files. Your parts will be automatically indexed and made searchable.</p>
  </div>
  
  <!-- Upload Card -->
  <div class="upload-card" id="uploadCard">
    <div class="upload-icon">
      <i data-lucide="upload-cloud"></i>
    </div>
    <h2>Drag & drop your file here</h2>
    <p>or click to browse your computer</p>
    <button class="upload-btn" onclick="document.getElementById('fileInput').click()">
      <i data-lucide="folder-open" style="width: 20px; height: 20px;"></i>
      Choose File
    </button>
    <input type="file" id="fileInput" accept=".csv,.xlsx,.xls" style="display: none;">
    
    <div class="file-formats">
      <div class="file-format">
        <i data-lucide="check"></i>
        Excel (.xlsx)
      </div>
      <div class="file-format">
        <i data-lucide="check"></i>
        CSV (.csv)
      </div>
      <div class="file-format">
        <i data-lucide="check"></i>
        Up to 500,000 rows
      </div>
    </div>
  </div>
  
  <!-- Processing Card -->
  <div class="processing-card" id="processingCard">
    <div class="processing-spinner"></div>
    <div class="processing-text">Processing your file...</div>
    <div class="processing-file" id="processingFile">filename.xlsx</div>
  </div>
  
  <!-- Success Card -->
  <div class="success-card" id="successCard">
    <div class="success-icon">
      <i data-lucide="check"></i>
    </div>
    <h2>Import Successful!</h2>
    <p style="color: #64748b;">Your parts have been imported and indexed.</p>
    
    <div class="success-stats">
      <div class="success-stat">
        <div class="success-stat-value" id="importedCount">0</div>
        <div class="success-stat-label">Parts Imported</div>
      </div>
      <div class="success-stat">
        <div class="success-stat-value" id="errorsCount">0</div>
        <div class="success-stat-label">Errors</div>
      </div>
      <div class="success-stat">
        <div class="success-stat-value" id="duration">0s</div>
        <div class="success-stat-label">Duration</div>
      </div>
    </div>
    
    <div class="success-actions">
      <a href="/supplier/parts" class="btn btn-primary">
        <i data-lucide="boxes" style="width: 18px; height: 18px;"></i>
        View Parts
      </a>
      <button class="btn btn-secondary" onclick="resetUpload()">
        <i data-lucide="upload" style="width: 18px; height: 18px;"></i>
        Upload Another
      </button>
    </div>
  </div>
  
  <!-- Data Management Options -->
  <div class="upload-options">
    <h3 style="font-size: 0.95rem; font-weight: 600; color: #1e293b; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
      <i data-lucide="settings-2" style="width: 18px; height: 18px; color: var(--primary);"></i>
      Import Options
    </h3>
    
    <div class="option-group">
      <div class="option-label-main">Before importing, delete existing data:</div>
      
      <div class="data-options" id="dataOptions">
        <label class="data-option selected" data-value="none">
          <input type="radio" name="deleteOption" value="none" checked>
          <div class="option-content">
            <div class="option-icon"><i data-lucide="plus-circle"></i></div>
            <div class="option-text">
              <strong>Add to existing</strong>
              <span>Keep all current data, add new parts</span>
            </div>
          </div>
        </label>
        
        <label class="data-option" data-value="file">
          <input type="radio" name="deleteOption" value="file">
          <div class="option-content">
            <div class="option-icon"><i data-lucide="file-x"></i></div>
            <div class="option-text">
              <strong>Replace same file</strong>
              <span>Delete parts from previous upload of same filename</span>
            </div>
          </div>
        </label>
        
        <label class="data-option" data-value="brand">
          <input type="radio" name="deleteOption" value="brand">
          <div class="option-content">
            <div class="option-icon"><i data-lucide="tag"></i></div>
            <div class="option-text">
              <strong>Replace by brand</strong>
              <span>Choose which brands to replace</span>
            </div>
          </div>
        </label>
        
        <label class="data-option danger" data-value="all">
          <input type="radio" name="deleteOption" value="all">
          <div class="option-content">
            <div class="option-icon"><i data-lucide="trash-2"></i></div>
            <div class="option-text">
              <strong>Replace all data</strong>
              <span>Delete ALL your parts before import</span>
            </div>
          </div>
        </label>
      </div>
      
      <!-- Brand Selection (shown when "brand" option selected) -->
      <div class="brand-select-wrapper" id="brandSelectWrapper" style="display: none;">
        <label style="font-size: 0.85rem; color: #64748b; display: block; margin-bottom: 8px;">
          Select brands to replace:
        </label>
        <div class="brand-checkboxes" id="brandCheckboxes">
          <div style="padding: 20px; text-align: center; color: #94a3b8;">Loading brands...</div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Column Info -->
  <div class="info-card">
    <h3>
      <i data-lucide="info"></i>
      Supported Column Names
    </h3>
    <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 12px;">
      We automatically detect these columns. Supports CSV (semicolon, comma, tab delimited) and Excel files.
    </p>
    <div class="column-list">
      <div class="column-item"><i data-lucide="check"></i> VENDOR CODE / Part Number*</div>
      <div class="column-item"><i data-lucide="check"></i> TITLE / Description</div>
      <div class="column-item"><i data-lucide="check"></i> BRAND</div>
      <div class="column-item"><i data-lucide="check"></i> PRICE / PRICE,AED</div>
      <div class="column-item"><i data-lucide="check"></i> QUANTITY / QTY</div>
      <div class="column-item"><i data-lucide="check"></i> WEIGHT</div>
      <div class="column-item"><i data-lucide="check"></i> VOLUME</div>
      <div class="column-item"><i data-lucide="check"></i> DELIVERY</div>
      <div class="column-item"><i data-lucide="check"></i> STOCK</div>
      <div class="column-item"><i data-lucide="check"></i> MIN_LOT / Min Order</div>
    </div>
  </div>

  <!-- Current Data Summary -->
  <div class="info-card" id="dataSummaryCard">
    <h3>
      <i data-lucide="database"></i>
      Your Current Data
    </h3>
    <div id="dataSummary">
      <div style="padding: 12px; text-align: center; color: #94a3b8;">
        <div class="processing-spinner" style="width: 24px; height: 24px; margin: 0 auto 8px; border-width: 2px;"></div>
        Loading summary...
      </div>
    </div>
  </div>
</div>

<script>
  let supplierBrands = [];
  let selectedBrands = new Set();

  document.addEventListener('DOMContentLoaded', () => {
    lucide.createIcons();
    
    const uploadCard = document.getElementById('uploadCard');
    const fileInput = document.getElementById('fileInput');
    
    // Drag and drop
    uploadCard.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadCard.classList.add('drag-over');
    });
    
    uploadCard.addEventListener('dragleave', () => {
      uploadCard.classList.remove('drag-over');
    });
    
    uploadCard.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadCard.classList.remove('drag-over');
      const file = e.dataTransfer.files[0];
      if (file) handleFile(file);
    });
    
    uploadCard.addEventListener('click', () => {
      fileInput.click();
    });
    
    fileInput.addEventListener('change', (e) => {
      if (e.target.files[0]) handleFile(e.target.files[0]);
    });

    // Data options selection
    document.querySelectorAll('.data-option').forEach(option => {
      option.addEventListener('click', () => {
        document.querySelectorAll('.data-option').forEach(o => o.classList.remove('selected'));
        option.classList.add('selected');
        option.querySelector('input').checked = true;

        const value = option.dataset.value;
        const brandWrapper = document.getElementById('brandSelectWrapper');
        brandWrapper.style.display = value === 'brand' ? 'block' : 'none';
      });
    });

    // Load data summary and brands
    loadDataSummary();
    loadBrands();
  });

  async function loadDataSummary() {
    try {
      const response = await fetch('/api/supplier/import-summary');
      const data = await response.json();

      const summaryDiv = document.getElementById('dataSummary');
      
      if (!data.totalParts) {
        summaryDiv.innerHTML = `
          <div style="padding: 16px; text-align: center; color: #64748b;">
            <i data-lucide="inbox" style="width: 32px; height: 32px; margin-bottom: 8px; opacity: 0.5;"></i>
            <p>No parts uploaded yet</p>
          </div>
        `;
        lucide.createIcons();
        return;
      }

      summaryDiv.innerHTML = `
        <div class="data-summary-grid">
          <div class="summary-item">
            <div class="summary-value">${(data.totalParts || 0).toLocaleString()}</div>
            <div class="summary-label">Total Parts</div>
          </div>
          <div class="summary-item">
            <div class="summary-value">${data.brandCount || 0}</div>
            <div class="summary-label">Brands</div>
          </div>
          <div class="summary-item">
            <div class="summary-value">${data.fileCount || 0}</div>
            <div class="summary-label">Files</div>
          </div>
          <div class="summary-item">
            <div class="summary-value">${data.lastImport ? new Date(data.lastImport).toLocaleDateString() : '-'}</div>
            <div class="summary-label">Last Import</div>
          </div>
        </div>
      `;
    } catch (err) {
      console.error('Error loading summary:', err);
      document.getElementById('dataSummary').innerHTML = '<div style="color: #dc2626;">Error loading summary</div>';
    }
  }

  async function loadBrands() {
    try {
      const response = await fetch('/api/supplier/brands');
      const data = await response.json();
      supplierBrands = data.brands || [];

      const container = document.getElementById('brandCheckboxes');
      
      if (!supplierBrands.length) {
        container.innerHTML = '<div style="padding: 12px; text-align: center; color: #94a3b8;">No brands yet</div>';
        return;
      }

      container.innerHTML = supplierBrands.map(b => `
        <label class="brand-checkbox" data-brand="${b.brand}">
          <input type="checkbox" value="${b.brand}" onchange="toggleBrand('${b.brand}', this)">
          <span class="brand-name">${escapeHtml(b.brand)}</span>
          <span class="brand-count">${b.partsCount}</span>
        </label>
      `).join('');
    } catch (err) {
      console.error('Error loading brands:', err);
      document.getElementById('brandCheckboxes').innerHTML = '<div style="color: #dc2626;">Error loading brands</div>';
    }
  }

  function toggleBrand(brand, checkbox) {
    const label = checkbox.closest('.brand-checkbox');
    if (checkbox.checked) {
      selectedBrands.add(brand);
      label.classList.add('checked');
    } else {
      selectedBrands.delete(brand);
      label.classList.remove('checked');
    }
  }
  
  async function handleFile(file) {
    const allowedTypes = ['.csv', '.xlsx', '.xls'];
    const ext = '.' + file.name.split('.').pop().toLowerCase();
    
    if (!allowedTypes.includes(ext)) {
      alert('Please upload a CSV or Excel file.');
      return;
    }

    // Get selected delete option
    const deleteOption = document.querySelector('input[name="deleteOption"]:checked').value;

    // Validate brand selection if brand option selected
    if (deleteOption === 'brand' && selectedBrands.size === 0) {
      alert('Please select at least one brand to replace.');
      return;
    }

    // Confirm dangerous operations
    if (deleteOption === 'all') {
      if (!confirm('⚠️ WARNING: This will DELETE ALL your existing parts before importing!\n\nAre you sure you want to continue?')) {
        return;
      }
    } else if (deleteOption === 'brand') {
      const brands = Array.from(selectedBrands).join(', ');
      if (!confirm(`This will delete all parts from brands: ${brands}\n\nAre you sure?`)) {
        return;
      }
    }
    
    // Show processing
    document.getElementById('uploadCard').style.display = 'none';
    document.getElementById('processingCard').style.display = 'block';
    document.getElementById('processingFile').textContent = file.name;
    
    try {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('deleteOption', deleteOption);
      
      if (deleteOption === 'brand') {
        formData.append('brands', JSON.stringify(Array.from(selectedBrands)));
      }
      
      const response = await fetch('/api/supplier/parts/import', {
        method: 'POST',
        body: formData
      });
      
      const result = await response.json();
      
      if (!response.ok) {
        throw new Error(result.message || 'Import failed');
      }
      
      // Show success
      document.getElementById('processingCard').style.display = 'none';
      document.getElementById('successCard').style.display = 'block';
      document.getElementById('importedCount').textContent = result.imported?.toLocaleString() || '0';
      document.getElementById('errorsCount').textContent = result.errors?.length || '0';
      document.getElementById('duration').textContent = (result.duration / 1000).toFixed(1) + 's';

      // Show deleted count if any
      if (result.deleted > 0) {
        const deletedInfo = document.createElement('div');
        deletedInfo.className = 'success-stat';
        deletedInfo.innerHTML = `
          <div class="success-stat-value" style="color: #dc2626;">${result.deleted.toLocaleString()}</div>
          <div class="success-stat-label">Parts Deleted</div>
        `;
        document.querySelector('.success-stats').appendChild(deletedInfo);
      }
      
      lucide.createIcons();
      
    } catch (err) {
      alert('Import failed: ' + err.message);
      resetUpload();
    }
  }
  
  function resetUpload() {
    document.getElementById('uploadCard').style.display = 'block';
    document.getElementById('processingCard').style.display = 'none';
    document.getElementById('successCard').style.display = 'none';
    document.getElementById('fileInput').value = '';

    // Reset options to default
    document.querySelectorAll('.data-option').forEach(o => o.classList.remove('selected'));
    document.querySelector('.data-option[data-value="none"]').classList.add('selected');
    document.querySelector('input[name="deleteOption"][value="none"]').checked = true;
    document.getElementById('brandSelectWrapper').style.display = 'none';
    selectedBrands.clear();
    document.querySelectorAll('.brand-checkbox').forEach(cb => {
      cb.classList.remove('checked');
      cb.querySelector('input').checked = false;
    });

    // Reload summary
    loadDataSummary();
    loadBrands();
  }

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/[&<>"']/g, m => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[m]));
  }
</script>

