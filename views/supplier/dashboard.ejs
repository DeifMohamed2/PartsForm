<%- include('partials/header', { currentPage: 'dashboard', pageTitle: 'Dashboard' }) %>

<!-- Stats Grid -->
<div class="grid grid-4" style="margin-bottom: 24px;">
  <div class="stat-card">
    <div class="stat-icon blue">
      <i data-lucide="boxes"></i>
    </div>
    <div class="stat-content">
      <div class="stat-label">Total Parts</div>
      <div class="stat-value" id="statParts">-</div>
    </div>
  </div>
  
  <div class="stat-card">
    <div class="stat-icon green">
      <i data-lucide="check-circle"></i>
    </div>
    <div class="stat-content">
      <div class="stat-label">In Stock</div>
      <div class="stat-value" id="statInStock">-</div>
    </div>
  </div>
  
  <div class="stat-card">
    <div class="stat-icon orange">
      <i data-lucide="tags"></i>
    </div>
    <div class="stat-content">
      <div class="stat-label">Unique Brands</div>
      <div class="stat-value" id="statBrands">-</div>
    </div>
  </div>
  
  <div class="stat-card">
    <div class="stat-icon purple">
      <i data-lucide="file-spreadsheet"></i>
    </div>
    <div class="stat-content">
      <div class="stat-label">Import Files</div>
      <div class="stat-value" id="statFiles">-</div>
    </div>
  </div>
</div>

<!-- Main Content Grid -->
<div class="grid grid-2">
  <!-- Recent Uploads -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Recent Import Files</h3>
      <a href="/supplier/files" class="btn btn-secondary btn-sm">View All</a>
    </div>
    
    <div id="filesContainer">
      <div class="loading">
        <div class="spinner"></div>
      </div>
    </div>
  </div>
  
  <!-- Quick Stats -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Inventory Summary</h3>
    </div>
    
    <div id="summaryContainer" style="padding: 16px 0;">
      <div class="loading">
        <div class="spinner"></div>
      </div>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="card" style="margin-top: 24px;">
  <div class="card-header">
    <h3 class="card-title">Quick Actions</h3>
  </div>
  
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px;">
    <a href="/supplier/import" class="quick-action-card">
      <div class="stat-icon blue">
        <i data-lucide="upload-cloud"></i>
      </div>
      <div>
        <div style="font-weight: 600; color: var(--text-primary);">Upload Parts</div>
        <div style="font-size: 13px; color: var(--text-secondary);">Import Excel or CSV files</div>
      </div>
    </a>
    
    <a href="/supplier/parts" class="quick-action-card">
      <div class="stat-icon green">
        <i data-lucide="edit-3"></i>
      </div>
      <div>
        <div style="font-weight: 600; color: var(--text-primary);">Edit Parts</div>
        <div style="font-size: 13px; color: var(--text-secondary);">Update prices, quantities & more</div>
      </div>
    </a>
    
    <a href="/api/supplier/parts/export" class="quick-action-card" download>
      <div class="stat-icon orange">
        <i data-lucide="download"></i>
      </div>
      <div>
        <div style="font-weight: 600; color: var(--text-primary);">Export Parts</div>
        <div style="font-size: 13px; color: var(--text-secondary);">Download your parts as Excel</div>
      </div>
    </a>
    
    <a href="/supplier/settings" class="quick-action-card">
      <div class="stat-icon purple">
        <i data-lucide="settings"></i>
      </div>
      <div>
        <div style="font-weight: 600; color: var(--text-primary);">Account Settings</div>
        <div style="font-size: 13px; color: var(--text-secondary);">Manage your profile</div>
      </div>
    </a>
  </div>
</div>

<style>
  .quick-action-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
    background: white;
  }
  
  .quick-action-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 12px rgba(12, 74, 110, 0.1);
    transform: translateY(-2px);
  }
  
  .file-row {
    display: flex;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  
  .file-row:last-child {
    border-bottom: none;
  }
  
  .file-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 12px;
    flex-shrink: 0;
  }
  
  .file-icon.excel {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
  }
  
  .file-icon.csv {
    background: rgba(14, 165, 233, 0.1);
    color: #0ea5e9;
  }
  
  .file-info {
    flex: 1;
    min-width: 0;
  }
  
  .file-name {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .file-meta {
    font-size: 12px;
    color: var(--text-secondary);
  }
  
  .file-count {
    font-size: 13px;
    font-weight: 600;
    color: var(--primary);
    background: rgba(14, 165, 233, 0.1);
    padding: 4px 10px;
    border-radius: 6px;
  }
  
  .summary-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  
  .summary-item:last-child {
    border-bottom: none;
  }
  
  .summary-label {
    color: var(--text-secondary);
    font-size: 14px;
  }
  
  .summary-value {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 15px;
  }
  
  .empty-state {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-secondary);
  }
  
  .empty-state i {
    width: 48px;
    height: 48px;
    margin-bottom: 16px;
    opacity: 0.5;
  }
  
  .empty-state h4 {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    lucide.createIcons();
    
    try {
      // Fetch dashboard stats
      const response = await fetch('/api/supplier/dashboard', {
        headers: { 'Content-Type': 'application/json' }
      });
      
      if (!response.ok) throw new Error('Failed to load dashboard');
      
      const data = await response.json();
      
      // Update stats
      document.getElementById('statParts').textContent = formatNumber(data.totalParts || 0);
      document.getElementById('statInStock').textContent = formatNumber(data.inStockCount || 0);
      document.getElementById('statBrands').textContent = formatNumber(data.uniqueBrands || 0);
      document.getElementById('statFiles').textContent = formatNumber(data.files?.length || 0);
      
      // Render files list
      renderFiles(data.files || []);
      
      // Render summary
      renderSummary(data);
      
    } catch (err) {
      console.error('Dashboard error:', err);
      document.getElementById('filesContainer').innerHTML = `
        <div class="empty-state">
          <i data-lucide="alert-circle"></i>
          <h4>Error loading data</h4>
          <p>Please refresh the page</p>
        </div>
      `;
      lucide.createIcons();
    }
  });
  
  function renderFiles(files) {
    const container = document.getElementById('filesContainer');
    
    if (!files.length) {
      container.innerHTML = `
        <div class="empty-state">
          <i data-lucide="folder-open"></i>
          <h4>No files uploaded yet</h4>
          <p>Upload your first parts file to get started</p>
          <a href="/supplier/import" class="btn btn-primary" style="margin-top: 16px;">
            <i data-lucide="upload" style="width: 16px; height: 16px;"></i>
            Upload Parts
          </a>
        </div>
      `;
      lucide.createIcons();
      return;
    }
    
    container.innerHTML = files.slice(0, 5).map(file => {
      const ext = file.fileName?.split('.').pop()?.toLowerCase() || 'file';
      const iconClass = ext === 'csv' ? 'csv' : 'excel';
      const icon = ext === 'csv' ? 'file-text' : 'file-spreadsheet';
      
      return `
        <div class="file-row">
          <div class="file-icon ${iconClass}">
            <i data-lucide="${icon}" style="width: 20px; height: 20px;"></i>
          </div>
          <div class="file-info">
            <div class="file-name">${file.fileName || 'Unknown File'}</div>
            <div class="file-meta">${formatDate(file.importedAt)}</div>
          </div>
          <div class="file-count">${formatNumber(file.partsCount)} parts</div>
        </div>
      `;
    }).join('');
    
    lucide.createIcons();
  }
  
  function renderSummary(data) {
    const container = document.getElementById('summaryContainer');
    
    container.innerHTML = `
      <div class="summary-item">
        <span class="summary-label">Total Parts Value</span>
        <span class="summary-value">AED ${formatNumber(data.totalValue || 0)}</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">Average Price</span>
        <span class="summary-value">AED ${(data.avgPrice || 0).toFixed(2)}</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">In Stock</span>
        <span class="summary-value" style="color: #22c55e;">${formatNumber(data.inStockCount || 0)} parts</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">Out of Stock</span>
        <span class="summary-value" style="color: #ef4444;">${formatNumber(data.outOfStockCount || 0)} parts</span>
      </div>
    `;
  }
  
  function formatNumber(num) {
    if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
    if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
    return num.toLocaleString();
  }
  
  function formatDate(dateStr) {
    if (!dateStr) return 'N/A';
    const date = new Date(dateStr);
    const now = new Date();
    const diff = now - date;
    
    if (diff < 3600000) return 'Just now';
    if (diff < 86400000) return Math.floor(diff / 3600000) + ' hours ago';
    if (diff < 604800000) return Math.floor(diff / 86400000) + ' days ago';
    
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }
</script>

<%- include('partials/footer') %>
