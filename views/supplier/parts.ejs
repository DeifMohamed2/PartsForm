    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--supplier-text-secondary);
    margin-bottom: 8px;
  }

  .bulk-field select,
  .bulk-field input {
    width: 100%;
    padding: 12px 14px;
    border: 2px solid var(--supplier-border);
