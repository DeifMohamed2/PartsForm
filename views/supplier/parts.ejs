<script>
  // State
  let parts = [];
  let currentPage = 1;
  let totalPages = 1;
  let selectedParts = new Set();
  let currentSort = { field: 'createdAt', order: 'desc' };
  let editingCell = null;
  
  // Multi-select file filter state
  let allFiles = [];
  let selectedFiles = new Set();

  // Initialize
  document.addEventListener('DOMContentLoaded', async () => {
    lucide.createIcons();
    await loadFilters();
    
    // Check for file param in URL
    const urlParams = new URLSearchParams(window.location.search);
    const fileParam = urlParams.get('file');
    if (fileParam) {
      selectedFiles.add(fileParam);
      updateFileFilterUI();
    }
    
    await loadParts();
    setupEventListeners();
  });

  function setupEventListeners() {
    const searchInput = document.getElementById('searchInput');
    const searchSection = document.getElementById('searchSection');
    const clearSearch = document.getElementById('clearSearch');
    const searchResultsBadge = document.getElementById('searchResultsBadge');
    
    // Search input handling
    searchInput.addEventListener('input', (e) => {
      searchSection.classList.toggle('has-value', e.target.value.length > 0);
      debounce(loadParts, 300)();
    });
    
    // Clear search button
    clearSearch.addEventListener('click', (e) => {
      e.stopPropagation();
      searchInput.value = '';
      searchSection.classList.remove('has-value');
      searchInput.focus();
      currentPage = 1;
      loadParts();
    });
    
    // Escape key clears search
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        searchSection.classList.remove('has-value');
        currentPage = 1;
        loadParts();
      }
    });
    
    // Brand filter
    const brandFilter = document.getElementById('brandFilter');
    const brandFilterBtn = document.getElementById('brandFilterBtn');
    const brandFilterLabel = document.getElementById('brandFilterLabel');
    const clearBrandFilter = document.getElementById('clearBrandFilter');
    
    brandFilter.addEventListener('change', () => { 
      const hasValue = brandFilter.value !== '';
      brandFilterBtn.classList.toggle('active', hasValue);
      brandFilterLabel.textContent = hasValue ? brandFilter.options[brandFilter.selectedIndex].text : 'All Brands';
      currentPage = 1; 
      loadParts(); 
    });
    
    clearBrandFilter.addEventListener('click', (e) => {
      e.stopPropagation();
      brandFilter.value = '';
      brandFilterBtn.classList.remove('active');
      brandFilterLabel.textContent = 'All Brands';
      currentPage = 1;
      loadParts();
    });
    
    // Multi-select File filter
    const fileFilterBtn = document.getElementById('fileFilterBtn');
    const fileDropdown = document.getElementById('fileFilterDropdown');
    const fileSearch = document.getElementById('fileFilterSearch');
    
    // Toggle dropdown on button click
    fileFilterBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      // Check if clear button was clicked
      if (e.target.closest('#clearFileFilter')) {
        clearFileSelection();
        fileDropdown.classList.remove('open');
        return;
      }
      
      // Toggle dropdown
      const isOpen = fileDropdown.classList.contains('open');
      fileDropdown.classList.toggle('open');
      
      if (!isOpen) {
        setTimeout(() => fileSearch.focus(), 100);
      }
    });
    
    // Search within dropdown
    fileSearch.addEventListener('input', function(e) {
      filterFileList(e.target.value);
    });
    
    // Close dropdown on outside click
    document.addEventListener('click', function(e) {
      if (!e.target.closest('#fileFilterContainer')) {
        fileDropdown.classList.remove('open');
      }
    });
    
    // Prevent dropdown from closing when clicking inside it
    fileDropdown.addEventListener('click', function(e) {
      e.stopPropagation();
    });

    document.getElementById('selectAll').addEventListener('change', toggleSelectAll);
    document.getElementById('prevPage').addEventListener('click', () => changePage(-1));
    document.getElementById('nextPage').addEventListener('click', () => changePage(1));
    document.getElementById('exportBtn').addEventListener('click', exportParts);
    
    document.querySelectorAll('.sortable').forEach(th => {
      th.addEventListener('click', () => sortBy(th.dataset.sort));
    });

    // Bulk edit field selector
    document.getElementById('bulkFieldSelect').addEventListener('change', (e) => {
      const valueField = document.getElementById('bulkValueField');
      const valueInput = document.getElementById('bulkValueInput');
      const applyBtn = document.getElementById('applyBulkBtn');
      
      if (e.target.value) {
        valueField.style.display = 'block';
        valueInput.type = ['price', 'quantity', 'minOrderQty'].includes(e.target.value) ? 'number' : 'text';
        valueInput.placeholder = `Enter new ${e.target.options[e.target.selectedIndex].text}`;
        document.getElementById('bulkValueLabel').textContent = e.target.options[e.target.selectedIndex].text;
        applyBtn.disabled = false;
      } else {
        valueField.style.display = 'none';
        applyBtn.disabled = true;
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (editingCell) finishInlineEdit(false);
        closeQuickEdit();
        closeBulkModal();
      }
    });
    
    // Show edit hint on hover for editable cells
    setupEditHint();
  }

  function setupEditHint() {
    const hint = document.getElementById('editHint');
    let hintTimeout;
    
    document.addEventListener('mouseover', (e) => {
      const cell = e.target.closest('.cell-content.editable');
      if (cell && !editingCell) {
        clearTimeout(hintTimeout);
        hintTimeout = setTimeout(() => {
          const rect = cell.getBoundingClientRect();
          hint.style.left = rect.left + 'px';
          hint.style.top = (rect.bottom + 8) + 'px';
          hint.classList.add('visible');
        }, 600);
      }
    });
    
    document.addEventListener('mouseout', (e) => {
      const cell = e.target.closest('.cell-content.editable');
      if (cell) {
        clearTimeout(hintTimeout);
        hint.classList.remove('visible');
      }
    });
  }

  async function loadFilters() {
    try {
      const [brandsRes, filesRes] = await Promise.all([
        fetch('/api/supplier/brands'),
        fetch('/api/supplier/files')
      ]);
      
      const brandsData = await brandsRes.json();
      const files = await filesRes.json();
      
      const brandSelect = document.getElementById('brandFilter');
      (brandsData.brands || []).forEach(b => {
        const opt = document.createElement('option');
        opt.value = b.brand;
        opt.textContent = `${b.brand} (${b.partsCount})`;
        brandSelect.appendChild(opt);
      });

      // Store files for multi-select
      allFiles = files;
      renderFileFilterList(files);
    } catch (err) {
      console.error('Error loading filters:', err);
    }
  }
  
  function renderFileFilterList(files) {
    const list = document.getElementById('fileFilterList');
    
    if (!files || !files.length) {
      list.innerHTML = '<div class="filter-dropdown-empty">No files found</div>';
      return;
    }
    
    list.innerHTML = files.map(f => `
      <label class="filter-dropdown-item ${selectedFiles.has(f.fileName) ? 'selected' : ''}" data-filename="${escapeHtml(f.fileName)}">
        <input type="checkbox" 
               value="${escapeHtml(f.fileName)}" 
               ${selectedFiles.has(f.fileName) ? 'checked' : ''}
               onchange="toggleFileSelection('${escapeHtml(f.fileName)}')">
        <div class="filter-item-content">
          <div class="filter-item-name">${escapeHtml(f.fileName)}</div>
          <div class="filter-item-count">${f.partsCount?.toLocaleString() || 0} parts</div>
        </div>
      </label>
    `).join('');
  }
  
  function filterFileList(searchTerm) {
    const term = searchTerm.toLowerCase().trim();
    const filtered = term 
      ? allFiles.filter(f => f.fileName.toLowerCase().includes(term))
      : allFiles;
    renderFileFilterList(filtered);
  }
  
  function toggleFileSelection(fileName) {
    if (selectedFiles.has(fileName)) {
      selectedFiles.delete(fileName);
    } else {
      selectedFiles.add(fileName);
    }
    updateFileFilterUI();
    currentPage = 1;
    loadParts();
  }
  
  function selectAllFiles() {
    allFiles.forEach(f => selectedFiles.add(f.fileName));
    renderFileFilterList(allFiles);
    updateFileFilterUI();
    currentPage = 1;
    loadParts();
  }
  
  function clearFileSelection() {
    selectedFiles.clear();
    renderFileFilterList(allFiles);
    updateFileFilterUI();
    currentPage = 1;
    loadParts();
  }
  
  function updateFileFilterUI() {
    const btn = document.getElementById('fileFilterBtn');
    const label = document.getElementById('fileFilterLabel');
    const countBadge = document.getElementById('fileFilterCount');
    const clearBtn = document.getElementById('clearFileFilter');
    
    if (selectedFiles.size === 0) {
      btn.classList.remove('active');
      label.textContent = 'All Files';
      countBadge.style.display = 'none';
      clearBtn.style.display = 'none';
    } else if (selectedFiles.size === 1) {
      btn.classList.add('active');
      label.textContent = [...selectedFiles][0];
      countBadge.style.display = 'none';
      clearBtn.style.display = 'flex';
    } else {
      btn.classList.add('active');
      label.textContent = 'Files';
      countBadge.textContent = selectedFiles.size;
      countBadge.style.display = 'inline';
      clearBtn.style.display = 'flex';
    }
    
    // Update item styles in dropdown
    document.querySelectorAll('.filter-dropdown-item').forEach(item => {
      const fileName = item.dataset.filename;
      const checkbox = item.querySelector('input[type="checkbox"]');
      if (selectedFiles.has(fileName)) {
        item.classList.add('selected');
        if (checkbox) checkbox.checked = true;
      } else {
        item.classList.remove('selected');
        if (checkbox) checkbox.checked = false;
      }
    });
  }

  async function loadParts() {
    const search = document.getElementById('searchInput').value;
    const brand = document.getElementById('brandFilter').value;
    const searchResultsBadge = document.getElementById('searchResultsBadge');
    const searchSection = document.getElementById('searchSection');

    try {
      const params = new URLSearchParams({
        page: currentPage,
        limit: 500,
        sortBy: currentSort.field,
        sortOrder: currentSort.order
      });

      if (search) params.append('search', search);
      if (brand) params.append('brand', brand);
      
      // Multi-select files - send as comma-separated or multiple params
      if (selectedFiles.size > 0) {
        // Send each file name as separate param for proper handling
        Array.from(selectedFiles).forEach(f => params.append('fileName', f));
      }

      const response = await fetch(`/api/supplier/parts?${params}`);
      const data = await response.json();

      parts = data.results || [];
      
      // Update search results badge
      if (search && search.trim()) {
        searchResultsBadge.textContent = data.total || 0;
        searchSection.classList.add('has-value');
      } else {
        searchSection.classList.remove('has-value');
      }
      
      renderParts();
      updatePagination(data);
    } catch (err) {
      console.error('Error loading parts:', err);
      searchSection.classList.toggle('has-value', search && search.trim());
      showEmptyState('Error loading parts. Please refresh.');
    }
  }

  function renderParts() {
    const tbody = document.getElementById('partsBody');

    if (!parts.length) {
      showEmptyState();
      return;
    }

    tbody.innerHTML = parts.map(part => `
      <tr data-id="${part._id}" class="${selectedParts.has(part._id) ? 'selected' : ''}">
        <td class="col-checkbox" onclick="event.stopPropagation()">
          <input type="checkbox" class="row-checkbox" value="${part._id}"
                 ${selectedParts.has(part._id) ? 'checked' : ''}
                 onchange="event.stopPropagation(); toggleSelect('${part._id}')">
        </td>
        <td class="col-partnumber">
          <div class="cell-content readonly">${escapeHtml(part.partNumber)}</div>
        </td>
        <td class="col-description">
          <div class="cell-content editable" data-field="description" data-id="${part._id}"
               ondblclick="handleCellDoubleClick(this, event)" title="${escapeHtml(part.description || '')}">${escapeHtml(part.description || '-')}</div>
        </td>
        <td class="col-brand">
          <div class="cell-content editable" data-field="brand" data-id="${part._id}"
               ondblclick="handleCellDoubleClick(this, event)">${escapeHtml(part.brand || '-')}</div>
        </td>
        <td class="col-quantity">
          <div class="cell-content editable" data-field="quantity" data-id="${part._id}" data-type="number"
               ondblclick="handleCellDoubleClick(this, event)">${part.quantity || 0}</div>
        </td>
        <td class="col-weight">
          <div class="cell-content readonly">${part.weight ? part.weight.toFixed(3) : '-'}</div>
        </td>
        <td class="col-volume">
          <div class="cell-content readonly">${part.volume ? part.volume.toFixed(3) : '-'}</div>
        </td>
        <td class="col-delivery">
          <div class="cell-content readonly">
            ${part.deliveryTime || part.deliveryDays ? `<span class="delivery-badge">${part.deliveryTime || part.deliveryDays}</span>` : '-'}
          </div>
        </td>
        <td class="col-stock">
          <div class="cell-content readonly">
            <span class="stock-badge">${part.stockCode || '-'}</span>
          </div>
        </td>
        <td class="col-price">
          <div class="cell-content editable" data-field="price" data-id="${part._id}" data-type="number"
               ondblclick="handleCellDoubleClick(this, event)">${(part.price || 0).toFixed(2)}</div>
        </td>
        <td class="col-minlot">
          <div class="cell-content readonly">${part.minOrderQty || 1}</div>
        </td>
        <td class="col-actions">
          <div class="actions-cell">
            <button class="action-btn edit-btn" onclick="event.stopPropagation(); openQuickEdit('${part._id}')" title="Edit part details">
              <i data-lucide="edit-2"></i>
            </button>
            <button class="action-btn delete-btn" onclick="deletePart('${part._id}', event)" title="Delete part">
              <i data-lucide="trash-2"></i>
            </button>
          </div>
        </td>
      </tr>
    `).join('');

    lucide.createIcons();
  }

  function handleCellDoubleClick(cell, event) {
    // Stop event bubbling to prevent accidental actions
    event.stopPropagation();
    event.preventDefault();
    
    // Hide edit hint
    document.getElementById('editHint').classList.remove('visible');
    
    // Start editing
    startInlineEdit(cell);
    return false;
  }

  function showEmptyState(message) {
    const tbody = document.getElementById('partsBody');
    tbody.innerHTML = `
      <tr>
        <td colspan="12">
          <div class="empty-state">
            <div class="empty-icon">
              <i data-lucide="inbox"></i>
            </div>
            <h3>${message || 'No parts found'}</h3>
            <p>${message ? '' : 'Upload your first file to get started'}</p>
            ${!message ? '<a href="/supplier/import" class="btn btn-primary"><i data-lucide="upload"></i> Import Parts</a>' : ''}
          </div>
        </td>
      </tr>
    `;
    lucide.createIcons();
  }

  function startInlineEdit(cell) {
    if (editingCell && editingCell !== cell) {
      finishInlineEdit(true);
    }

    const field = cell.dataset.field;
    const id = cell.dataset.id;
    const type = cell.dataset.type || 'text';
    const currentValue = cell.textContent.trim();

    editingCell = cell;
    cell.classList.add('editing');
    cell.closest('tr').classList.add('editing');

    const input = document.createElement('input');
    input.type = type === 'number' ? 'number' : 'text';
    input.className = 'inline-edit-input';
    input.value = currentValue === '-' ? '' : currentValue;
    input.dataset.originalValue = currentValue;
    input.dataset.field = field;
    input.dataset.id = id;

    if (type === 'number') {
      input.step = field === 'price' ? '0.01' : '1';
      input.min = '0';
    }

    cell.innerHTML = '';
    cell.appendChild(input);
    input.focus();
    input.select();

    input.addEventListener('blur', () => finishInlineEdit(true));
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        finishInlineEdit(true);
      } else if (e.key === 'Escape') {
        e.preventDefault();
        finishInlineEdit(false);
      } else if (e.key === 'Tab') {
        e.preventDefault();
        finishInlineEdit(true);
        const cells = cell.closest('tr').querySelectorAll('.cell-content.editable');
        const idx = Array.from(cells).indexOf(cell);
        if (idx < cells.length - 1) {
          startInlineEdit(cells[idx + 1]);
        }
      }
    });
  }

  async function finishInlineEdit(save) {
    if (!editingCell) return;

    const input = editingCell.querySelector('input');
    if (!input) return;

    const field = input.dataset.field;
    const id = input.dataset.id;
    const originalValue = input.dataset.originalValue;
    const newValue = input.value.trim();

    editingCell.closest('tr').classList.remove('editing');
    editingCell.classList.remove('editing');

    if (save && newValue !== originalValue && newValue !== (originalValue === '-' ? '' : originalValue)) {
      try {
        const updates = {};
        updates[field] = field === 'price' || field === 'quantity' ? parseFloat(newValue) || 0 : newValue;

        const response = await fetch(`/api/supplier/parts/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updates)
        });

        if (!response.ok) throw new Error('Update failed');

        const part = parts.find(p => p._id === id);
        if (part) part[field] = updates[field];

        editingCell.innerHTML = field === 'price' ? parseFloat(newValue || 0).toFixed(2) : (newValue || '-');
        
        // Show save indicator
        showSaveIndicator();
      } catch (err) {
        console.error('Error saving:', err);
        editingCell.innerHTML = originalValue;
      }
    } else {
      editingCell.innerHTML = originalValue;
    }

    const savedCell = editingCell;
    editingCell = null;
    
    // Re-add the double-click handler and data attributes
    savedCell.dataset.field = field;
    savedCell.dataset.id = id;
    savedCell.ondblclick = (e) => handleCellDoubleClick(savedCell, e);
  }

  function showSaveIndicator(message = 'Changes saved') {
    const indicator = document.getElementById('saveIndicator');
    const textEl = indicator.querySelector('span');
    if (textEl) textEl.textContent = message;
    indicator.classList.add('show');
    lucide.createIcons();
    setTimeout(() => {
      indicator.classList.remove('show');
    }, 2000);
  }

  async function openQuickEdit(id) {
    try {
      const response = await fetch(`/api/supplier/parts/${id}`);
      const part = await response.json();

      document.getElementById('editPartId').value = id;
      document.getElementById('editPartNumber').value = part.partNumber || '';
      document.getElementById('editDescription').value = part.description || '';
      document.getElementById('editBrand').value = part.brand || '';
      document.getElementById('editPrice').value = part.price || 0;
      document.getElementById('editQuantity').value = part.quantity || 0;
      document.getElementById('editWeight').value = part.weight || '';
      document.getElementById('editVolume').value = part.volume || '';
      document.getElementById('editDeliveryTime').value = part.deliveryTime || '';
      document.getElementById('editMinOrderQty').value = part.minOrderQty || 1;
      document.getElementById('editStockCode').value = part.stockCode || '';

      document.getElementById('quickEditPanel').classList.add('open');
      document.getElementById('quickEditOverlay').classList.add('open');
      lucide.createIcons();
    } catch (err) {
      alert('Error loading part: ' + err.message);
    }
  }

  function closeQuickEdit() {
    document.getElementById('quickEditPanel').classList.remove('open');
    document.getElementById('quickEditOverlay').classList.remove('open');
  }

  async function saveQuickEdit() {
    const id = document.getElementById('editPartId').value;
    const deliveryTimeVal = document.getElementById('editDeliveryTime').value || '';
    // Extract first number for deliveryDays (for filtering)
    const deliveryMatch = deliveryTimeVal.match(/(\d+)/);
    const deliveryDays = deliveryMatch ? parseInt(deliveryMatch[1], 10) : null;
    
    const updates = {
      description: document.getElementById('editDescription').value,
      brand: document.getElementById('editBrand').value,
      price: parseFloat(document.getElementById('editPrice').value) || 0,
      quantity: parseInt(document.getElementById('editQuantity').value) || 0,
      weight: parseFloat(document.getElementById('editWeight').value) || null,
      volume: parseFloat(document.getElementById('editVolume').value) || null,
      deliveryTime: deliveryTimeVal,
      deliveryDays: deliveryDays,
      minOrderQty: parseInt(document.getElementById('editMinOrderQty').value) || 1,
      stockCode: document.getElementById('editStockCode').value
    };

    try {
      const response = await fetch(`/api/supplier/parts/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updates)
      });

      if (!response.ok) throw new Error('Update failed');

      closeQuickEdit();
      loadParts();
    } catch (err) {
      alert('Error saving part: ' + err.message);
    }
  }

  function toggleSelect(id) {
    if (selectedParts.has(id)) {
      selectedParts.delete(id);
    } else {
      selectedParts.add(id);
    }
    updateSelectionUI();
  }

  function toggleSelectAll(e) {
    const checkboxes = document.querySelectorAll('.row-checkbox');
    checkboxes.forEach(cb => {
      cb.checked = e.target.checked;
      if (e.target.checked) {
        selectedParts.add(cb.value);
      } else {
        selectedParts.delete(cb.value);
      }
    });
    updateSelectionUI();
  }

  function clearSelection() {
    selectedParts.clear();
    document.querySelectorAll('.row-checkbox').forEach(cb => cb.checked = false);
    document.getElementById('selectAll').checked = false;
    updateSelectionUI();
  }

  function updateSelectionUI() {
    document.getElementById('selectedCount').textContent = selectedParts.size;
    document.getElementById('bulkBar').classList.toggle('visible', selectedParts.size > 0);

    document.querySelectorAll('#partsBody tr').forEach(row => {
      const id = row.dataset.id;
      row.classList.toggle('selected', selectedParts.has(id));
    });
  }

  function openBulkEdit() {
    document.getElementById('bulkEditCount').textContent = selectedParts.size;
    document.getElementById('bulkFieldSelect').value = '';
    document.getElementById('bulkValueInput').value = '';
    document.getElementById('bulkValueField').style.display = 'none';
    document.getElementById('applyBulkBtn').disabled = true;
    document.getElementById('bulkModalOverlay').classList.add('open');
    lucide.createIcons();
  }

  function closeBulkModal(event) {
    if (event && event.target !== event.currentTarget) return;
    document.getElementById('bulkModalOverlay').classList.remove('open');
  }

  async function applyBulkEdit() {
    const field = document.getElementById('bulkFieldSelect').value;
    const value = document.getElementById('bulkValueInput').value.trim();

    if (!field || value === '') {
      alert('Please select a field and enter a value.');
      return;
    }

    try {
      const updates = {};
      
      if (field === 'deliveryTime') {
        // Store original format and extract days for filtering
        updates.deliveryTime = value;
        const deliveryMatch = value.match(/(\d+)/);
        updates.deliveryDays = deliveryMatch ? parseInt(deliveryMatch[1], 10) : null;
      } else if (['price', 'quantity', 'minOrderQty'].includes(field)) {
        updates[field] = parseFloat(value);
      } else {
        updates[field] = value;
      }

      await fetch('/api/supplier/parts/bulk', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          partIds: Array.from(selectedParts),
          updates
        })
      });

      closeBulkModal();
      clearSelection();
      loadParts();
      showSaveIndicator();
    } catch (err) {
      alert('Error updating parts: ' + err.message);
    }
  }

  async function bulkDelete() {
    if (!confirm(`Delete ${selectedParts.size} parts? This cannot be undone.`)) return;

    try {
      await fetch('/api/supplier/parts/bulk', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ partIds: Array.from(selectedParts) })
      });

      clearSelection();
      loadParts();
    } catch (err) {
      alert('Error deleting parts: ' + err.message);
    }
  }

  async function deletePart(id, event) {
    // Stop event propagation to prevent any other handlers
    if (event) {
      event.stopPropagation();
      event.preventDefault();
    }
    
    // Double confirmation for safety
    if (!confirm('Are you sure you want to delete this part?\n\nThis action cannot be undone.')) return;

    try {
      await fetch(`/api/supplier/parts/${id}`, { method: 'DELETE' });
      loadParts();
      showSaveIndicator('Part deleted');
    } catch (err) {
      alert('Error deleting part: ' + err.message);
    }
  }

  function sortBy(field) {
    document.querySelectorAll('.sortable').forEach(th => th.classList.remove('sorted'));

    if (currentSort.field === field) {
      currentSort.order = currentSort.order === 'asc' ? 'desc' : 'asc';
    } else {
      currentSort.field = field;
      currentSort.order = 'asc';
    }

    document.querySelector(`.sortable[data-sort="${field}"]`).classList.add('sorted');
    currentPage = 1;
    loadParts();
  }

  function updatePagination(data) {
    currentPage = data.page || 1;
    totalPages = data.totalPages || 1;
    const total = data.total || 0;
    const limit = data.limit || 100;

    document.getElementById('currentPage').textContent = currentPage;
    document.getElementById('totalPages').textContent = totalPages;
    document.getElementById('totalParts').textContent = total.toLocaleString();
    document.getElementById('showingFrom').textContent = total ? ((currentPage - 1) * limit) + 1 : 0;
    document.getElementById('showingTo').textContent = Math.min(currentPage * limit, total);

    document.getElementById('prevPage').disabled = currentPage <= 1;
    document.getElementById('nextPage').disabled = currentPage >= totalPages;
  }

  function changePage(delta) {
    currentPage += delta;
    loadParts();
    document.getElementById('gridWrapper').scrollTop = 0;
  }

  function exportParts() {
    const params = new URLSearchParams();
    // Export selected files
    if (selectedFiles.size > 0) {
      Array.from(selectedFiles).forEach(f => params.append('fileName', f));
    }
    window.location.href = `/api/supplier/parts/export?${params}`;
  }

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/[&<>"']/g, m => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[m]));
  }

  function debounce(fn, delay) {
    let timeout;
    return (...args) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => fn(...args), delay);
    };
  }
</script>

<%- include('partials/footer') %>
