<%- include('partials/header', { currentPage: 'parts', pageTitle: 'My Parts' }) %>

<!-- Page Header -->
<div class="page-header">
  <div class="page-header-left">
    <div class="search-box">
      <i data-lucide="search"></i>
      <input type="text" id="searchInput" placeholder="Search parts by number, description, brand...">
    </div>
    <select id="fileFilter" class="filter-select">
      <option value="">All Import Files</option>
    </select>
  </div>
  
  <div class="page-header-right">
    <button class="btn btn-secondary" id="exportBtn">
      <i data-lucide="download" style="width: 16px; height: 16px;"></i>
      Export
    </button>
    <a href="/supplier/import" class="btn btn-primary">
      <i data-lucide="upload" style="width: 16px; height: 16px;"></i>
      Upload Parts
    </a>
  </div>
</div>

<!-- Parts Table -->
<div class="card">
  <div class="table-container">
    <table class="data-table" id="partsTable">
      <thead>
        <tr>
          <th class="checkbox-col">
            <input type="checkbox" id="selectAll">
          </th>
          <th class="sortable" data-sort="partNumber">Part Number</th>
          <th class="sortable" data-sort="description">Description</th>
          <th class="sortable" data-sort="brand">Brand</th>
          <th class="sortable" data-sort="price">Price</th>
          <th class="sortable" data-sort="quantity">Qty</th>
          <th class="sortable" data-sort="stock">Stock</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="partsBody">
        <tr>
          <td colspan="8" class="loading-row">
            <div class="spinner"></div>
            <span>Loading parts...</span>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <!-- Pagination -->
  <div class="table-footer">
    <div class="pagination-info">
      Showing <span id="showingFrom">0</span>-<span id="showingTo">0</span> of <span id="totalParts">0</span> parts
    </div>
    <div class="pagination">
      <button class="btn btn-sm" id="prevPage" disabled>
        <i data-lucide="chevron-left" style="width: 16px; height: 16px;"></i>
      </button>
      <span class="page-info">Page <span id="currentPage">1</span> of <span id="totalPages">1</span></span>
      <button class="btn btn-sm" id="nextPage" disabled>
        <i data-lucide="chevron-right" style="width: 16px; height: 16px;"></i>
      </button>
    </div>
  </div>
</div>

<!-- Bulk Actions Bar (hidden by default) -->
<div class="bulk-actions-bar" id="bulkActionsBar" style="display: none;">
  <span class="selected-count"><span id="selectedCount">0</span> parts selected</span>
  <div class="bulk-buttons">
    <button class="btn btn-sm" onclick="bulkEditPrice()">
      <i data-lucide="dollar-sign" style="width: 14px; height: 14px;"></i>
      Update Price
    </button>
    <button class="btn btn-sm" onclick="bulkEditQuantity()">
      <i data-lucide="package" style="width: 14px; height: 14px;"></i>
      Update Quantity
    </button>
    <button class="btn btn-sm btn-danger" onclick="bulkDelete()">
      <i data-lucide="trash-2" style="width: 14px; height: 14px;"></i>
      Delete
    </button>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal" id="editModal">
  <div class="modal-backdrop" onclick="closeModal()"></div>
  <div class="modal-content">
    <div class="modal-header">
      <h3>Edit Part</h3>
      <button class="modal-close" onclick="closeModal()">
        <i data-lucide="x"></i>
      </button>
    </div>
    <form id="editForm">
      <input type="hidden" id="editPartId">
      <div class="form-grid">
        <div class="form-group">
          <label>Part Number</label>
          <input type="text" id="editPartNumber" readonly class="readonly">
        </div>
        <div class="form-group">
          <label>Brand</label>
          <input type="text" id="editBrand">
        </div>
        <div class="form-group full-width">
          <label>Description</label>
          <textarea id="editDescription" rows="2"></textarea>
        </div>
        <div class="form-group">
          <label>Price</label>
          <div class="input-group">
            <span class="input-addon">AED</span>
            <input type="number" id="editPrice" step="0.01" min="0">
          </div>
        </div>
        <div class="form-group">
          <label>Quantity</label>
          <input type="number" id="editQuantity" min="0">
        </div>
        <div class="form-group">
          <label>Weight (kg)</label>
          <input type="number" id="editWeight" step="0.01" min="0">
        </div>
        <div class="form-group">
          <label>Delivery Days</label>
          <input type="number" id="editDeliveryDays" min="0">
        </div>
        <div class="form-group">
          <label>Category</label>
          <input type="text" id="editCategory">
        </div>
        <div class="form-group">
          <label>Stock Status</label>
          <select id="editStock">
            <option value="in-stock">In Stock</option>
            <option value="low-stock">Low Stock</option>
            <option value="out-of-stock">Out of Stock</option>
            <option value="on-order">On Order</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<style>
