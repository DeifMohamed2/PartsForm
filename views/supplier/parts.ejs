    font-size: 14px;
    color: var(--text-secondary);
  }
  
  .input-group input {
    border-radius: 0 8px 8px 0;
    flex: 1;
  }
  
  .modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    padding: 16px 24px;
    border-top: 1px solid var(--border);
    background: var(--bg-main);
  }
  
  .loading-row {
    text-align: center;
    padding: 40px !important;
    color: var(--text-secondary);
  }
  
  .loading-row .spinner {
    margin: 0 auto 12px;
  }
  
  .empty-row {
    text-align: center;
    padding: 60px !important;
    color: var(--text-secondary);
  }
  
  .empty-row i {
    width: 48px;
    height: 48px;
    margin-bottom: 16px;
    opacity: 0.3;
  }
</style>

<script>
  let currentPage = 1;
  let totalPages = 1;
  let selectedParts = new Set();
  let currentSort = { field: 'createdAt', order: 'desc' };
  
  document.addEventListener('DOMContentLoaded', async () => {
    lucide.createIcons();
    
    // Load import files for filter
    await loadFileFilters();
    
    // Check for URL parameter to filter by file
    const urlParams = new URLSearchParams(window.location.search);
    const fileParam = urlParams.get('file');
    if (fileParam) {
      const fileSelect = document.getElementById('fileFilter');
      // Set the filter if the file exists in options
      for (let i = 0; i < fileSelect.options.length; i++) {
        if (fileSelect.options[i].value === fileParam) {
          fileSelect.value = fileParam;
          break;
        }
      }
    }
    
    // Load parts
    await loadParts();
    
    // Event listeners
    document.getElementById('searchInput').addEventListener('input', debounce(loadParts, 300));
    document.getElementById('fileFilter').addEventListener('change', loadParts);
    document.getElementById('selectAll').addEventListener('change', toggleSelectAll);
    document.getElementById('prevPage').addEventListener('click', () => changePage(-1));
    document.getElementById('nextPage').addEventListener('click', () => changePage(1));
    document.getElementById('exportBtn').addEventListener('click', exportParts);
    document.getElementById('editForm').addEventListener('submit', savePart);
    
    // Sortable headers
    document.querySelectorAll('.sortable').forEach(th => {
      th.addEventListener('click', () => sortBy(th.dataset.sort));
    });
  });
  
  async function loadFileFilters() {
    try {
      const response = await fetch('/api/supplier/files');
      const files = await response.json();
      
      const select = document.getElementById('fileFilter');
      files.forEach(file => {
        const option = document.createElement('option');
        option.value = file.fileName;
        option.textContent = `${file.fileName} (${file.partsCount})`;
        select.appendChild(option);
      });
    } catch (err) {
      console.error('Error loading file filters:', err);
    }
  }
  
  async function loadParts() {
    const search = document.getElementById('searchInput').value;
    const fileName = document.getElementById('fileFilter').value;
    
    try {
      const params = new URLSearchParams({
        page: currentPage,
        limit: 50,
        sortBy: currentSort.field,
        sortOrder: currentSort.order
      });
      
      if (search) params.append('search', search);
      if (fileName) params.append('fileName', fileName);
      
      const response = await fetch(`/api/supplier/parts?${params}`);
      const data = await response.json();
      
      renderParts(data.results || []);
      updatePagination(data);
      
    } catch (err) {
      console.error('Error loading parts:', err);
      document.getElementById('partsBody').innerHTML = `
        <tr><td colspan="8" class="empty-row">
          <i data-lucide="alert-circle"></i>
          <p>Error loading parts. Please refresh.</p>
        </td></tr>
      `;
      lucide.createIcons();
    }
  }
  
  function renderParts(parts) {
    const tbody = document.getElementById('partsBody');
    
    if (!parts.length) {
      tbody.innerHTML = `
        <tr><td colspan="8" class="empty-row">
          <i data-lucide="inbox"></i>
          <h4 style="margin: 16px 0 8px; font-weight: 600; color: var(--text-primary);">No parts found</h4>
          <p>Upload your first file to get started</p>
          <a href="/supplier/import" class="btn btn-primary" style="margin-top: 16px;">
            Upload Parts
          </a>
        </td></tr>
      `;
      lucide.createIcons();
      return;
    }
    
    tbody.innerHTML = parts.map(part => `
      <tr data-id="${part._id}">
        <td class="checkbox-col">
          <input type="checkbox" class="part-checkbox" value="${part._id}" 
                 ${selectedParts.has(part._id) ? 'checked' : ''}
                 onchange="toggleSelect('${part._id}')">
        </td>
        <td><span class="part-number">${escapeHtml(part.partNumber)}</span></td>
        <td class="description-cell" title="${escapeHtml(part.description || '')}">${escapeHtml(part.description || '-')}</td>
        <td>${escapeHtml(part.brand || '-')}</td>
        <td class="price-cell">${part.currency || 'AED'} ${(part.price || 0).toFixed(2)}</td>
        <td>${part.quantity || 0}</td>
        <td><span class="stock-badge ${part.stock || 'unknown'}">${formatStock(part.stock)}</span></td>
        <td>
          <button class="action-btn" onclick="editPart('${part._id}')" title="Edit">
            <i data-lucide="edit-2" style="width: 16px; height: 16px;"></i>
          </button>
          <button class="action-btn delete" onclick="deletePart('${part._id}')" title="Delete">
            <i data-lucide="trash-2" style="width: 16px; height: 16px;"></i>
          </button>
        </td>
      </tr>
    `).join('');
    
    lucide.createIcons();
  }
  
  function updatePagination(data) {
    currentPage = data.page || 1;
    totalPages = data.totalPages || 1;
    const total = data.total || 0;
    const limit = data.limit || 50;
    
    document.getElementById('currentPage').textContent = currentPage;
    document.getElementById('totalPages').textContent = totalPages;
    document.getElementById('totalParts').textContent = total;
    document.getElementById('showingFrom').textContent = total ? ((currentPage - 1) * limit) + 1 : 0;
    document.getElementById('showingTo').textContent = Math.min(currentPage * limit, total);
    
    document.getElementById('prevPage').disabled = currentPage <= 1;
    document.getElementById('nextPage').disabled = currentPage >= totalPages;
  }
  
  function changePage(delta) {
    currentPage += delta;
    loadParts();
  }
  
  function sortBy(field) {
    if (currentSort.field === field) {
      currentSort.order = currentSort.order === 'asc' ? 'desc' : 'asc';
    } else {
      currentSort.field = field;
      currentSort.order = 'asc';
    }
    currentPage = 1;
    loadParts();
  }
  
  function toggleSelect(id) {
    if (selectedParts.has(id)) {
      selectedParts.delete(id);
    } else {
      selectedParts.add(id);
    }
    updateBulkActions();
  }
  
  function toggleSelectAll(e) {
    const checkboxes = document.querySelectorAll('.part-checkbox');
    checkboxes.forEach(cb => {
      cb.checked = e.target.checked;
      if (e.target.checked) {
        selectedParts.add(cb.value);
      } else {
        selectedParts.delete(cb.value);
      }
    });
    updateBulkActions();
  }
  
  function updateBulkActions() {
    const bar = document.getElementById('bulkActionsBar');
    document.getElementById('selectedCount').textContent = selectedParts.size;
    bar.style.display = selectedParts.size > 0 ? 'flex' : 'none';
  }
  
  async function editPart(id) {
    try {
      const response = await fetch(`/api/supplier/parts/${id}`);
      const part = await response.json();
      
      document.getElementById('editPartId').value = id;
      document.getElementById('editPartNumber').value = part.partNumber || '';
      document.getElementById('editDescription').value = part.description || '';
      document.getElementById('editBrand').value = part.brand || '';
      document.getElementById('editPrice').value = part.price || 0;
      document.getElementById('editQuantity').value = part.quantity || 0;
      document.getElementById('editWeight').value = part.weight || '';
      document.getElementById('editDeliveryDays').value = part.deliveryDays || '';
      document.getElementById('editCategory').value = part.category || '';
      document.getElementById('editStock').value = part.stock || 'unknown';
      
      document.getElementById('editModal').classList.add('active');
      lucide.createIcons();
    } catch (err) {
      alert('Error loading part: ' + err.message);
    }
  }
  
  async function savePart(e) {
    e.preventDefault();
    
    const id = document.getElementById('editPartId').value;
    const updates = {
      description: document.getElementById('editDescription').value,
      brand: document.getElementById('editBrand').value,
      price: parseFloat(document.getElementById('editPrice').value) || 0,
      quantity: parseInt(document.getElementById('editQuantity').value) || 0,
      weight: parseFloat(document.getElementById('editWeight').value) || null,
      deliveryDays: parseInt(document.getElementById('editDeliveryDays').value) || null,
      category: document.getElementById('editCategory').value,
      stock: document.getElementById('editStock').value
    };
    
    try {
      const response = await fetch(`/api/supplier/parts/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updates)
      });
      
      if (!response.ok) throw new Error('Update failed');
      
      closeModal();
      loadParts();
    } catch (err) {
      alert('Error saving part: ' + err.message);
    }
  }
  
  async function deletePart(id) {
    if (!confirm('Are you sure you want to delete this part?')) return;
    
    try {
      await fetch(`/api/supplier/parts/${id}`, { method: 'DELETE' });
      loadParts();
    } catch (err) {
      alert('Error deleting part: ' + err.message);
    }
  }
  
  async function bulkDelete() {
    if (!confirm(`Delete ${selectedParts.size} parts? This cannot be undone.`)) return;
    
    try {
      await fetch('/api/supplier/parts/bulk', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ partIds: Array.from(selectedParts) })
      });
      
      selectedParts.clear();
      updateBulkActions();
      loadParts();
    } catch (err) {
      alert('Error deleting parts: ' + err.message);
    }
  }
  
  async function bulkEditPrice() {
    const newPrice = prompt('Enter new price for selected parts:');
    if (!newPrice) return;
    
    try {
      await fetch('/api/supplier/parts/bulk', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          partIds: Array.from(selectedParts),
          updates: { price: parseFloat(newPrice) }
        })
      });
      
      loadParts();
    } catch (err) {
      alert('Error updating parts: ' + err.message);
    }
  }
  
  async function bulkEditQuantity() {
    const newQty = prompt('Enter new quantity for selected parts:');
    if (!newQty) return;
    
    try {
      await fetch('/api/supplier/parts/bulk', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          partIds: Array.from(selectedParts),
          updates: { quantity: parseInt(newQty) }
        })
      });
      
      loadParts();
    } catch (err) {
      alert('Error updating parts: ' + err.message);
    }
  }
  
  async function exportParts() {
    window.location.href = '/api/supplier/parts/export';
  }
  
  function closeModal() {
    document.getElementById('editModal').classList.remove('active');
  }
  
  function formatStock(stock) {
    const labels = {
      'in-stock': 'In Stock',
      'low-stock': 'Low Stock',
      'out-of-stock': 'Out of Stock',
      'on-order': 'On Order',
      'unknown': 'Unknown'
    };
    return labels[stock] || stock || 'Unknown';
  }
  
  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>"']/g, m => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[m]));
  }
  
  function debounce(fn, delay) {
    let timeout;
    return (...args) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => fn(...args), delay);
    };
  }
</script>

