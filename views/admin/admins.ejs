<%- include('partials/header') %>
<link rel="stylesheet" href="/css/adminCSS/admin-dashboard.css">
<link rel="stylesheet" href="/css/adminCSS/admin-admins.css">
</head>
<body>
  <div class="admin-wrapper">
    <%- include('partials/sidebar', { activePage: 'admins' }) %>
    
    <main class="admin-main">
      <%- include('partials/topbar', { pageTitle: 'Administrators' }) %>
      
      <div class="admin-content">
        <!-- Page Header -->
        <div class="admins-page-header">
          <h2>Administrators Management</h2>
          <div class="admins-header-actions">
            <div class="admins-search-container">
              <i data-lucide="search" class="search-icon"></i>
              <input type="text" id="adminsSearch" placeholder="Search administrators..." autocomplete="off">
            </div>
            <% if (userPermissions.canWrite) { %>
            <button class="admin-btn admin-btn-primary" onclick="openCreateModal()">
              <i data-lucide="user-plus"></i>
              Add Admin
            </button>
            <% } %>
          </div>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon">
              <i data-lucide="shield"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value" id="totalAdmins"><%= admins.length %></div>
              <div class="stat-label">Total Admins</div>
            </div>
          </div>
          <div class="stat-card purple">
            <div class="stat-icon">
              <i data-lucide="crown"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value" id="superAdmins"><%= admins.filter(a => a.role === 'super_admin').length %></div>
              <div class="stat-label">Super Admins</div>
            </div>
          </div>
          <div class="stat-card green">
            <div class="stat-icon">
              <i data-lucide="user-check"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value" id="activeAdmins"><%= admins.filter(a => a.isActive).length %></div>
              <div class="stat-label">Active Admins</div>
            </div>
          </div>
          <div class="stat-card orange">
            <div class="stat-icon">
              <i data-lucide="user-x"></i>
            </div>
            <div class="stat-content">
              <div class="stat-value" id="inactiveAdmins"><%= admins.filter(a => !a.isActive).length %></div>
              <div class="stat-label">Inactive Admins</div>
            </div>
          </div>
        </div>

        <!-- Admins Table -->
        <% if (admins.length === 0) { %>
        <div class="admins-empty">
          <div class="admins-empty-icon">
            <i data-lucide="shield"></i>
          </div>
          <h3>No Administrators Found</h3>
          <p>Create your first administrator to get started.</p>
          <% if (userPermissions.canWrite) { %>
          <button class="admin-btn admin-btn-primary" onclick="openCreateModal()">
            <i data-lucide="user-plus"></i>
            Create Administrator
          </button>
          <% } %>
        </div>
        <% } else { %>
        <div class="admins-table-card">
          <table class="admins-table">
            <thead>
              <tr>
                <th>Administrator</th>
                <th>Role</th>
                <th>Status</th>
                <th>Last Login</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="adminsTableBody">
              <% admins.forEach(function(admin) { %>
              <tr data-admin-id="<%= admin._id %>">
                <td>
                  <div class="admin-cell">
                    <div class="admin-avatar <%= admin.role === 'super_admin' ? 'super' : admin.role === 'moderator' ? 'moderator' : '' %>">
                      <%= admin.firstName.charAt(0).toUpperCase() %><%= admin.lastName.charAt(0).toUpperCase() %>
                    </div>
                    <div class="admin-info">
                      <h4><%= admin.firstName %> <%= admin.lastName %></h4>
                      <p><%= admin.email %></p>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="role-badge <%= admin.role %>">
                    <% if (admin.role === 'super_admin') { %>
                      <i data-lucide="crown"></i>
                    <% } else if (admin.role === 'admin') { %>
                      <i data-lucide="shield"></i>
                    <% } else { %>
                      <i data-lucide="user"></i>
                    <% } %>
                    <%= admin.role.replace('_', ' ') %>
                  </span>
                </td>
                <td>
                  <span class="status-badge <%= admin.isActive ? 'active' : 'inactive' %>">
                    <% if (admin.isActive) { %>
                      <i data-lucide="check-circle"></i>
                      Active
                    <% } else { %>
                      <i data-lucide="x-circle"></i>
                      Inactive
                    <% } %>
                  </span>
                </td>
                <td>
                  <% if (admin.lastLogin) { %>
                    <span class="last-login"><%= new Date(admin.lastLogin).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  <% } else { %>
                    <span class="last-login never">Never</span>
                  <% } %>
                </td>
                <td><%= new Date(admin.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                <td>
                  <div class="admin-actions">
                    <% 
                      const isSelf = admin._id.toString() === currentAdmin._id.toString();
                      const isTargetSuperAdmin = admin.role === 'super_admin';
                      const canModify = userPermissions.isSuperAdmin || !isTargetSuperAdmin;
                      const canDeleteThis = userPermissions.canDelete && canModify && !isSelf;
                      const moreThanOneSuperAdmin = admins.filter(a => a.role === 'super_admin').length > 1;
                    %>
                    <% if (userPermissions.canWrite && canModify) { %>
                    <button class="admin-action-btn" title="Edit Admin" onclick="openEditModal('<%= admin._id %>')">
                      <i data-lucide="edit-2"></i>
                    </button>
                    <% } %>
                    <% if (userPermissions.canWrite && canModify && !isSelf) { %>
                    <button class="admin-action-btn" title="<%= admin.isActive ? 'Deactivate' : 'Activate' %>" onclick="toggleAdminStatus('<%= admin._id %>', <%= admin.isActive %>)">
                      <% if (admin.isActive) { %>
                        <i data-lucide="user-x"></i>
                      <% } else { %>
                        <i data-lucide="user-check"></i>
                      <% } %>
                    </button>
                    <% } %>
                    <% if (canDeleteThis && (!isTargetSuperAdmin || moreThanOneSuperAdmin)) { %>
                    <button class="admin-action-btn delete" title="Delete Admin" onclick="confirmDelete('<%= admin._id %>', '<%= admin.firstName %> <%= admin.lastName %>')">
                      <i data-lucide="trash-2"></i>
                    </button>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </main>
  </div>

  <!-- Create/Edit Admin Modal -->
  <div class="modal-overlay" id="adminModal">
    <div class="modal-container">
      <div class="modal-header">
        <h3>
          <i data-lucide="user-plus"></i>
          <span id="modalTitle">Create Administrator</span>
        </h3>
        <button class="modal-close" onclick="closeModal()">
          <i data-lucide="x"></i>
        </button>
      </div>
      <form id="adminForm" onsubmit="handleSubmit(event)">
        <div class="modal-body">
          <input type="hidden" id="adminId" name="adminId">
          
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">First Name <span class="required">*</span></label>
              <input type="text" class="form-input" id="firstName" name="firstName" required placeholder="Enter first name">
            </div>
            <div class="form-group">
              <label class="form-label">Last Name <span class="required">*</span></label>
              <input type="text" class="form-input" id="lastName" name="lastName" required placeholder="Enter last name">
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Email Address <span class="required">*</span></label>
            <input type="email" class="form-input" id="email" name="email" required placeholder="Enter email address">
            <div class="form-error" id="emailError">This email is already in use</div>
          </div>

          <div class="form-group">
            <label class="form-label">Phone Number</label>
            <input type="tel" class="form-input" id="phone" name="phone" placeholder="Enter phone number">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Password <span class="required" id="passwordRequired">*</span></label>
              <input type="password" class="form-input" id="password" name="password" placeholder="Enter password" minlength="8">
              <div class="form-hint">Minimum 8 characters</div>
            </div>
            <div class="form-group">
              <label class="form-label">Confirm Password <span class="required" id="confirmRequired">*</span></label>
              <input type="password" class="form-input" id="confirmPassword" name="confirmPassword" placeholder="Confirm password">
              <div class="form-error" id="passwordError">Passwords do not match</div>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Role <span class="required">*</span></label>
            <select class="form-select" id="role" name="role" required onchange="handleRoleChange(this.value)">
              <option value="moderator">Moderator</option>
              <option value="admin" selected>Admin</option>
              <% if (userPermissions.isSuperAdmin) { %>
              <option value="super_admin">Super Admin</option>
              <% } %>
            </select>
            <div class="role-preset-info" id="roleInfo">
              <i data-lucide="info"></i>
              <span id="roleInfoText">Admins can manage most features with customizable permissions</span>
            </div>
          </div>

          <div class="form-group" id="permissionsGroup">
            <label class="form-label">Permissions</label>
            
            <!-- Basic Permissions -->
            <div class="permissions-section">
              <div class="permissions-section-title">
                <i data-lucide="key"></i>
                Basic Access
              </div>
              <div class="permissions-grid">
                <label class="permission-item selected" onclick="togglePermission(this)">
                  <input type="checkbox" name="permissions" value="read" checked>
                  <div class="permission-checkbox"><i data-lucide="check"></i></div>
                  <div class="permission-content">
                    <div class="permission-label">Read</div>
                    <div class="permission-desc">View data and reports</div>
                  </div>
                </label>
                <label class="permission-item" onclick="togglePermission(this)">
                  <input type="checkbox" name="permissions" value="write">
                  <div class="permission-checkbox"><i data-lucide="check"></i></div>
                  <div class="permission-content">
                    <div class="permission-label">Write</div>
                    <div class="permission-desc">Create and update records</div>
                  </div>
                </label>
                <label class="permission-item" onclick="togglePermission(this)">
                  <input type="checkbox" name="permissions" value="delete">
                  <div class="permission-checkbox"><i data-lucide="check"></i></div>
                  <div class="permission-content">
                    <div class="permission-label">Delete</div>
                    <div class="permission-desc">Remove records permanently</div>
                  </div>
                </label>
              </div>
            </div>

            <!-- Management Permissions -->
            <div class="permissions-section">
              <div class="permissions-section-title">
                <i data-lucide="settings-2"></i>
                Management
              </div>
              <div class="permissions-grid">
                <label class="permission-item" onclick="togglePermission(this)">
                  <input type="checkbox" name="permissions" value="manage_orders">
                  <div class="permission-checkbox"><i data-lucide="check"></i></div>
                  <div class="permission-content">
                    <div class="permission-label">Manage Orders</div>
                    <div class="permission-desc">Full order control</div>
                  </div>
                </label>
                <label class="permission-item" onclick="togglePermission(this)">
                  <input type="checkbox" name="permissions" value="manage_users">
                  <div class="permission-checkbox"><i data-lucide="check"></i></div>
                  <div class="permission-content">
                    <div class="permission-label">Manage Users</div>
                    <div class="permission-desc">Buyer account control</div>
                  </div>
                </label>
                <label class="permission-item" onclick="togglePermission(this)">
                  <input type="checkbox" name="permissions" value="manage_integrations">
                  <div class="permission-checkbox"><i data-lucide="check"></i></div>
                  <div class="permission-content">
                    <div class="permission-label">Manage Integrations</div>
                    <div class="permission-desc">FTP and data sources</div>
                  </div>
                </label>
              </div>
            </div>

            <!-- Admin Permissions (Super Admin only) -->
            <% if (userPermissions.isSuperAdmin) { %>
            <div class="permissions-section">
              <div class="permissions-section-title">
                <i data-lucide="shield-alert"></i>
                Admin Level (Restricted)
              </div>
              <div class="permissions-grid">
                <label class="permission-item" onclick="togglePermission(this)">
                  <input type="checkbox" name="permissions" value="manage_admins">
                  <div class="permission-checkbox"><i data-lucide="check"></i></div>
                  <div class="permission-content">
                    <div class="permission-label">Manage Admins</div>
                    <div class="permission-desc">Administrator accounts</div>
                  </div>
                </label>
                <label class="permission-item" onclick="togglePermission(this)">
                  <input type="checkbox" name="permissions" value="manage_settings">
                  <div class="permission-checkbox"><i data-lucide="check"></i></div>
                  <div class="permission-content">
                    <div class="permission-label">Manage Settings</div>
                    <div class="permission-desc">System configuration</div>
                  </div>
                </label>
              </div>
              <div class="permission-warning">
                <i data-lucide="alert-triangle"></i>
                <span>These permissions grant elevated system access. Assign carefully.</span>
              </div>
            </div>
            <% } else { %>
            <div class="permission-warning">
              <i data-lucide="lock"></i>
              <span>Admin management permissions can only be granted by Super Admins.</span>
            </div>
            <% } %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
          <button type="submit" class="admin-btn admin-btn-primary" id="submitBtn">
            <i data-lucide="check"></i>
            <span id="submitBtnText">Create Admin</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div class="modal-overlay" id="deleteModal">
    <div class="modal-container modal-delete">
      <div class="modal-header">
        <h3>
          <i data-lucide="alert-triangle" class="modal-alert-icon"></i>
          Confirm Deletion
        </h3>
        <button class="modal-close" onclick="closeDeleteModal()">
          <i data-lucide="x"></i>
        </button>
      </div>
      <div class="modal-body">
        <p class="modal-delete-message">Are you sure you want to delete <strong id="deleteAdminName"></strong>? This action cannot be undone.</p>
        <input type="hidden" id="deleteAdminId">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">Cancel</button>
        <button type="button" class="btn btn-danger" onclick="deleteAdmin()">
          <i data-lucide="trash-2"></i>
          Delete Admin
        </button>
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div class="toast" id="toast">
    <i data-lucide="check-circle" class="toast-icon"></i>
    <span class="toast-message" id="toastMessage">Success!</span>
  </div>

  <%- include('partials/footer') %>

  <script>
    // Initialize Lucide icons
    lucide.createIcons();

    // Store admins data and current user permissions for client-side operations
    const adminsData = <%- JSON.stringify(admins) %>;
    const currentAdminId = '<%= currentAdmin._id %>';
    const userPermissions = <%- JSON.stringify(userPermissions) %>;
    let isEditMode = false;

    // Role presets for permission defaults
    const ROLE_PRESETS = {
      super_admin: {
        info: 'Super Admins have unrestricted access to all features and settings',
        permissions: ['read', 'write', 'delete', 'manage_users', 'manage_admins', 'manage_orders', 'manage_settings', 'manage_integrations']
      },
      admin: {
        info: 'Admins can manage most features with customizable permissions',
        permissions: ['read', 'write', 'delete', 'manage_users', 'manage_orders']
      },
      moderator: {
        info: 'Moderators have limited access for viewing and basic updates',
        permissions: ['read', 'write']
      }
    };

    // Search functionality
    document.getElementById('adminsSearch').addEventListener('input', function(e) {
      const query = e.target.value.toLowerCase();
      const rows = document.querySelectorAll('#adminsTableBody tr');
      
      rows.forEach(row => {
        const name = row.querySelector('.admin-info h4')?.textContent.toLowerCase() || '';
        const email = row.querySelector('.admin-info p')?.textContent.toLowerCase() || '';
        const visible = name.includes(query) || email.includes(query);
        row.style.display = visible ? '' : 'none';
      });
    });

    // Handle role change to update permission presets
    function handleRoleChange(role) {
      const permissionsGroup = document.getElementById('permissionsGroup');
      const roleInfoText = document.getElementById('roleInfoText');
      
      // Update role info text
      if (ROLE_PRESETS[role]) {
        roleInfoText.textContent = ROLE_PRESETS[role].info;
      }
      
      // Super admin gets all permissions automatically, hide the permissions section
      if (role === 'super_admin') {
        permissionsGroup.style.display = 'none';
        // Select all permissions
        document.querySelectorAll('.permission-item').forEach(item => {
          const input = item.querySelector('input');
          input.checked = true;
          item.classList.add('selected');
        });
      } else {
        permissionsGroup.style.display = '';
        // Set default permissions for the role
        const defaultPerms = ROLE_PRESETS[role]?.permissions || ['read'];
        document.querySelectorAll('.permission-item').forEach(item => {
          const input = item.querySelector('input');
          const shouldSelect = defaultPerms.includes(input.value);
          input.checked = shouldSelect;
          item.classList.toggle('selected', shouldSelect);
        });
      }
      
      lucide.createIcons();
    }

    // Modal functions
    function openCreateModal() {
      isEditMode = false;
      document.getElementById('modalTitle').textContent = 'Create Administrator';
      document.getElementById('submitBtnText').textContent = 'Create Admin';
      document.getElementById('adminForm').reset();
      document.getElementById('adminId').value = '';
      document.getElementById('password').required = true;
      document.getElementById('confirmPassword').required = true;
      document.getElementById('passwordRequired').style.display = '';
      document.getElementById('confirmRequired').style.display = '';
      document.getElementById('permissionsGroup').style.display = '';
      
      // Set default role to admin and trigger change
      document.getElementById('role').value = 'admin';
      handleRoleChange('admin');
      
      document.getElementById('adminModal').classList.add('active');
      lucide.createIcons();
    }

    function openEditModal(adminId) {
      isEditMode = true;
      const admin = adminsData.find(a => a._id === adminId);
      if (!admin) return;

      // Check if current user can edit this admin
      if (admin.role === 'super_admin' && !userPermissions.isSuperAdmin) {
        showToast('Only Super Admins can edit Super Admin accounts', 'error');
        return;
      }

      document.getElementById('modalTitle').textContent = 'Edit Administrator';
      document.getElementById('submitBtnText').textContent = 'Update Admin';
      document.getElementById('adminId').value = adminId;
      document.getElementById('firstName').value = admin.firstName;
      document.getElementById('lastName').value = admin.lastName;
      document.getElementById('email').value = admin.email;
      document.getElementById('phone').value = admin.phone || '';
      document.getElementById('role').value = admin.role;
      document.getElementById('password').value = '';
      document.getElementById('confirmPassword').value = '';
      document.getElementById('password').required = false;
      document.getElementById('confirmPassword').required = false;
      document.getElementById('passwordRequired').style.display = 'none';
      document.getElementById('confirmRequired').style.display = 'none';

      // Handle role-specific display
      if (admin.role === 'super_admin') {
        document.getElementById('permissionsGroup').style.display = 'none';
      } else {
        document.getElementById('permissionsGroup').style.display = '';
      }

      // Set permissions
      document.querySelectorAll('.permission-item').forEach(item => {
        const input = item.querySelector('input');
        if (admin.permissions && admin.permissions.includes(input.value)) {
          input.checked = true;
          item.classList.add('selected');
        } else {
          input.checked = false;
          item.classList.remove('selected');
        }
      });

      // Disable role dropdown if editing self
      const roleSelect = document.getElementById('role');
      if (adminId === currentAdminId) {
        roleSelect.disabled = true;
        roleSelect.title = 'You cannot change your own role';
      } else {
        roleSelect.disabled = false;
        roleSelect.title = '';
      }

      // Update role info
      handleRoleChange(admin.role);
      // Restore the actual permissions after handleRoleChange
      document.querySelectorAll('.permission-item').forEach(item => {
        const input = item.querySelector('input');
        if (admin.permissions && admin.permissions.includes(input.value)) {
          input.checked = true;
          item.classList.add('selected');
        } else {
          input.checked = false;
          item.classList.remove('selected');
        }
      });

      document.getElementById('adminModal').classList.add('active');
      lucide.createIcons();
    }

    function closeModal() {
      document.getElementById('adminModal').classList.remove('active');
      document.getElementById('emailError').style.display = 'none';
      document.getElementById('passwordError').style.display = 'none';
      // Re-enable role if it was disabled
      document.getElementById('role').disabled = false;
    }

    function togglePermission(element) {
      if (element.classList.contains('disabled')) return;
      const input = element.querySelector('input');
      input.checked = !input.checked;
      element.classList.toggle('selected', input.checked);
    }

    // Form submission
    async function handleSubmit(event) {
      event.preventDefault();
      
      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;
      
      // Validate passwords match
      if (password && password !== confirmPassword) {
        document.getElementById('passwordError').style.display = 'block';
        return;
      }
      document.getElementById('passwordError').style.display = 'none';

      const role = document.getElementById('role').value;
      
      // Collect permissions (super admin gets all)
      let permissions = [];
      if (role === 'super_admin') {
        permissions = ROLE_PRESETS.super_admin.permissions;
      } else {
        document.querySelectorAll('.permission-item input:checked').forEach(input => {
          permissions.push(input.value);
        });
      }

      const formData = {
        firstName: document.getElementById('firstName').value,
        lastName: document.getElementById('lastName').value,
        email: document.getElementById('email').value,
        phone: document.getElementById('phone').value,
        role: role,
        permissions: permissions
      };

      if (password) {
        formData.password = password;
      }

      const adminId = document.getElementById('adminId').value;
      const url = adminId ? `/admin/api/admins/${adminId}` : '/admin/api/admins';
      const method = adminId ? 'PUT' : 'POST';

      try {
        document.getElementById('submitBtn').disabled = true;
        
        const response = await fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });

        const data = await response.json();

        if (response.ok) {
          showToast(adminId ? 'Administrator updated successfully!' : 'Administrator created successfully!', 'success');
          closeModal();
          setTimeout(() => location.reload(), 1000);
        } else {
          if (data.message && data.message.includes('email')) {
            document.getElementById('emailError').style.display = 'block';
          } else {
            showToast(data.message || 'An error occurred', 'error');
          }
        }
      } catch (error) {
        showToast('Failed to save administrator', 'error');
      } finally {
        document.getElementById('submitBtn').disabled = false;
      }
    }

    // Toggle admin status
    async function toggleAdminStatus(adminId, currentStatus) {
      // Check if trying to modify self
      if (adminId === currentAdminId) {
        showToast('You cannot modify your own account status', 'error');
        return;
      }

      // Check if trying to modify super admin without permission
      const admin = adminsData.find(a => a._id === adminId);
      if (admin && admin.role === 'super_admin' && !userPermissions.isSuperAdmin) {
        showToast('Only Super Admins can modify Super Admin accounts', 'error');
        return;
      }

      try {
        const response = await fetch(`/admin/api/admins/${adminId}/status`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isActive: !currentStatus })
        });

        const data = await response.json();

        if (response.ok) {
          showToast(`Administrator ${currentStatus ? 'deactivated' : 'activated'} successfully!`, 'success');
          setTimeout(() => location.reload(), 1000);
        } else {
          showToast(data.message || 'Failed to update status', 'error');
        }
      } catch (error) {
        showToast('Failed to update administrator status', 'error');
      }
    }

    // Delete confirmation
    function confirmDelete(adminId, adminName) {
      // Check if trying to delete self
      if (adminId === currentAdminId) {
        showToast('You cannot delete your own account', 'error');
        return;
      }

      // Check if trying to delete super admin without permission
      const admin = adminsData.find(a => a._id === adminId);
      if (admin && admin.role === 'super_admin' && !userPermissions.isSuperAdmin) {
        showToast('Only Super Admins can delete Super Admin accounts', 'error');
        return;
      }

      document.getElementById('deleteAdminId').value = adminId;
      document.getElementById('deleteAdminName').textContent = adminName;
      document.getElementById('deleteModal').classList.add('active');
      lucide.createIcons();
    }

    function closeDeleteModal() {
      document.getElementById('deleteModal').classList.remove('active');
    }

    async function deleteAdmin() {
      const adminId = document.getElementById('deleteAdminId').value;
      
      try {
        const response = await fetch(`/admin/api/admins/${adminId}`, {
          method: 'DELETE'
        });

        const data = await response.json();

        if (response.ok) {
          showToast('Administrator deleted successfully!', 'success');
          closeDeleteModal();
          setTimeout(() => location.reload(), 1000);
        } else {
          showToast(data.message || 'Failed to delete administrator', 'error');
        }
      } catch (error) {
        showToast('Failed to delete administrator', 'error');
      }
    }

    // Toast notification
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toastMessage');
      const toastIcon = toast.querySelector('.toast-icon');
      
      toastMessage.textContent = message;
      toast.className = `toast ${type}`;
      toastIcon.setAttribute('data-lucide', type === 'success' ? 'check-circle' : 'alert-circle');
      lucide.createIcons();
      
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }
  </script>
</body>
</html>
