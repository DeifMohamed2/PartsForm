              <% const sellPartColors = ['#40545E', '#95AFC0', '#D4AF37', '#8E9CA6', '#64748b']; %>
              <% const sellPartIcons = ['award', 'trending-up', 'star', 'package', 'box']; %>
              <% if (topSellingParts && topSellingParts.length > 0) { %>
