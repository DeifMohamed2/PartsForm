                <% claims.slice(0, 5).forEach(function(claim) { %>
                  <div class="activity-item" style="padding: 0.875rem;">
                    <div class="activity-icon <%= claim.status === 'resolved' ? 'success' : claim.status === 'open' ? 'warning' : '' %>">
                      <i data-lucide="<%= claim.status === 'resolved' ? 'check-circle' : 'mail' %>"></i>
                    </div>
                    <div class="activity-content" style="flex: 1;">
                      <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div class="activity-text"><strong><%= claim.id %></strong></div>
