<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#2B2B2B">
    <title>PartsForm | Reset Password</title>
    <link rel="icon" type="image/png" href="/images/brand/icon-gold.png">
    <link rel="stylesheet" href="/css/brand-system.css">
    <script src="https://unpkg.com/lucide@0.294.0/dist/umd/lucide.min.js"></script>
    <style>
        @font-face { font-family: 'Quantico'; src: url('/fonts/Quantico/Quantico-Regular.ttf') format('truetype'); font-weight: 400; font-display: swap; }
        @font-face { font-family: 'Quantico'; src: url('/fonts/Quantico/Quantico-Bold.ttf') format('truetype'); font-weight: 700; font-display: swap; }
        @font-face { font-family: 'Antartida'; src: url('/fonts/Antartida/Antartida-Light.otf') format('opentype'); font-weight: 300; font-display: swap; }
        @font-face { font-family: 'Antartida'; src: url('/fonts/Antartida/Antartida-Medium.otf') format('opentype'); font-weight: 500; font-display: swap; }
        @font-face { font-family: 'Antartida'; src: url('/fonts/Antartida/Antartida-Bold.otf') format('opentype'); font-weight: 700; font-display: swap; }
        @font-face { font-family: 'Antartida'; src: url('/fonts/Antartida/Antartida-Black.otf') format('opentype'); font-weight: 900; font-display: swap; }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box }

        html, body { height: 100%; overflow: hidden }

        body { font-family: 'Antartida', sans-serif; font-weight: 500; color: var(--washi); -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale }

        .fp-page {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center
        }

        .fp-bg { position: absolute; inset: 0; z-index: 0 }

        .fp-bg__photo {
            position: absolute;
            inset: 0;
            background: url('/images/brand/moodboard/warehouse-hero.webp') center/cover no-repeat;
            filter: brightness(0.55) saturate(0.80)
        }

        .fp-bg__overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(10,18,35,.60) 0%, rgba(18,32,55,.45) 50%, rgba(10,18,35,.65) 100%)
        }

        .fp-topbar {
            position: absolute;
            top: 0; left: 0; right: 0;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px 48px
        }

        .fp-topbar__icon { height: 140px; width: auto; display: block }

        .fp-topbar__link {
            position: absolute;
            left: 48px;
            top: 50%;
            transform: translateY(-50%);
            font-family: 'Antartida', sans-serif;
            font-size: var(--text-small);
            font-weight: 500;
            color: rgba(248,250,252,.80);
            text-decoration: underline;
            text-underline-offset: 4px;
            letter-spacing: .01em;
            transition: color .2s ease
        }

        .fp-topbar__link:hover { color: var(--washi) }

        .fp-card-wrapper {
            position: relative;
            z-index: 5;
            width: 500px;
            max-height: calc(100vh - 180px);
            overflow-y: auto;
            scrollbar-width: none
        }

        .fp-card-wrapper::-webkit-scrollbar { display: none }

        .fp-card {
            padding: 36px 48px;
            background: rgba(100,125,150,.22);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border: 1px solid rgba(255,255,255,.16);
            border-radius: 0;
            box-shadow: 0 20px 80px rgba(0,0,0,.55), inset 0 1px 0 rgba(255,255,255,.10);
            opacity: .93
        }

        .fp-brand { text-align: center; margin-bottom: 18px }
        .fp-brand__logo { width: 200px; height: auto }

        /* Steps */
        .fp-steps {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px
        }

        .fp-step { display: flex; flex-direction: column; align-items: center; gap: 4px }

        .fp-step__dot {
            width: 32px; height: 32px;
            display: flex; align-items: center; justify-content: center;
            border: 2px solid rgba(248,250,252,.22);
            font-family: 'Quantico', sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: rgba(248,250,252,.35);
            transition: all .3s ease
        }

        .fp-step__label {
            font-family: 'Quantico', sans-serif;
            font-size: 14px;
            font-weight: 900;
            color: rgba(248,250,252,.32);
            letter-spacing: .07em;
            text-transform: uppercase;
            transition: all .3s ease
        }

        .fp-step.active .fp-step__dot {
            border-color: var(--sei);
            color: var(--sei);
            background: rgba(149,175,192,.15)
        }

        .fp-step.active .fp-step__label { color: var(--sei) }

        .fp-step.done .fp-step__dot {
            border-color: rgba(149,175,192,.5);
            color: rgba(149,175,192,.7);
            background: rgba(149,175,192,.08)
        }

        .fp-step.done .fp-step__label { color: rgba(149,175,192,.65) }

        .fp-step__line {
            width: 48px; height: 1px;
            background: rgba(248,250,252,.16);
            margin: 0 8px;
            margin-bottom: 16px
        }

        /* Error */
        .fp-error {
            display: none;
            padding: 9px 14px;
            margin-bottom: 12px;
            font-family: 'Antartida', sans-serif;
            font-size: var(--text-xs);
            font-weight: 500;
            color: var(--kintsugi);
            background: rgba(212,175,55,.12);
            border: 1px solid rgba(212,175,55,.25)
        }

        .fp-error.show { display: block }

        /* Panels */
        .fp-panel { display: none; flex-direction: column; gap: 10px }
        .fp-panel.active { display: flex }

        /* Panel Header */
        .fp-panel-header { text-align: center; margin-bottom: 4px }

        .fp-panel-header h2 {
            font-family: 'Quantico', sans-serif;
            font-size: 1.25rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: var(--washi);
            margin-bottom: 5px
        }

        .fp-panel-header p {
            font-family: 'Antartida', sans-serif;
            font-size: var(--text-small);
            color: rgba(248,250,252,.50);
            line-height: 1.5
        }

        .fp-panel-header .email-display {
            color: var(--kintsugi);
            font-size: var(--text-small);
            margin-top: 4px;
            display: block
        }

        /* Fields */
        .fp-field { display: flex; flex-direction: column; gap: 5px }

        .fp-field__label {
            font-family: 'Quantico', sans-serif;
            font-size: 1rem;
            font-weight: 900;
            color: rgba(248,250,252,.82);
            letter-spacing: 0.07em;
            text-transform: uppercase
        }

        .fp-input-wrap { position: relative; display: flex; align-items: center }

        .fp-input-icon {
            position: absolute;
            left: 14px;
            width: 17px; height: 17px;
            color: rgba(248,250,252,.32);
            pointer-events: none
        }

        .fp-field__input {
            width: 100%;
            height: 48px;
            padding: 0 14px 0 42px;
            font-family: 'Antartida', sans-serif;
            font-size: 1.05rem;
            font-weight: 500;
            color: var(--washi);
            background: rgba(248,250,252,.06);
            border: 1px solid rgba(248,250,252,.18);
            border-radius: 0;
            outline: none;
            transition: border-color .2s ease, background .2s ease;
            -webkit-appearance: none;
            appearance: none
        }

        .fp-field__input::placeholder { color: rgba(248,250,252,.28) }

        .fp-field__input:focus {
            background: rgba(248,250,252,.09);
            border-color: rgba(149,175,192,.50)
        }

        .fp-field__input.has-pw-toggle { padding-right: 48px }

        .fp-field__error {
            font-size: var(--text-xs);
            color: var(--kintsugi);
            min-height: 1rem
        }

        /* Password toggle */
        .fp-pw-toggle {
            position: absolute;
            right: 0; top: 0; bottom: 0;
            width: 44px;
            display: flex; align-items: center; justify-content: center;
            background: none; border: none;
            cursor: pointer;
            color: rgba(248,250,252,.38);
            transition: color .2s
        }

        .fp-pw-toggle:hover { color: rgba(248,250,252,.78) }

        /* Password strength */
        .fp-pw-strength { display: flex; align-items: center; gap: 8px; margin-top: 6px }
        .fp-pw-bars { display: flex; gap: 4px }

        .fp-pw-bar {
            width: 34px; height: 3px;
            background: rgba(248,250,252,.15);
            transition: background .3s
        }

        .fp-pw-text {
            font-size: var(--text-xs);
            color: rgba(248,250,252,.40);
            transition: color .3s
        }

        /* Code inputs */
        .fp-code-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px
        }

        .fp-code-input {
            width: 48px; height: 58px;
            text-align: center;
            font-family: 'Quantico', sans-serif;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--kintsugi);
            background: rgba(248,250,252,.06);
            border: 1px solid rgba(248,250,252,.18);
            border-radius: 0;
            outline: none;
            transition: all .2s
        }

        .fp-code-input:focus {
            border-color: var(--kintsugi);
            background: rgba(212,175,55,.05)
        }

        .fp-code-sep {
            color: rgba(248,250,252,.28);
            font-size: 1.2rem;
            margin: 0 4px
        }

        /* Timer */
        .fp-timer {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: var(--text-small);
            color: rgba(248,250,252,.45);
            padding: 8px 12px;
            background: rgba(248,250,252,.04);
            border: 1px solid rgba(248,250,252,.09)
        }

        .fp-timer strong {
            font-family: 'Quantico', sans-serif;
            color: rgba(248,250,252,.60)
        }

        /* Password requirements */
        .fp-pw-reqs {
            padding: 10px 14px;
            background: rgba(248,250,252,.04);
            border: 1px solid rgba(248,250,252,.09)
        }

        .fp-pw-reqs p {
            font-family: 'Antartida', sans-serif;
            font-size: var(--text-xs);
            font-weight: 600;
            color: rgba(248,250,252,.45);
            margin-bottom: 8px
        }

        .fp-pw-reqs ul {
            list-style: none;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px
        }

        .fp-pw-reqs li {
            font-family: 'Antartida', sans-serif;
            font-size: var(--text-xs);
            color: rgba(248,250,252,.32);
            display: flex;
            align-items: center;
            gap: 6px;
            transition: color .2s
        }

        .fp-pw-reqs li.met { color: var(--sei) }

        /* Buttons */
        .fp-btn {
            width: 100%;
            height: 54px;
            font-family: 'Quantico', sans-serif;
            font-size: .95rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .10em;
            color: var(--kurogane);
            background: var(--sei);
            border: none;
            border-radius: 0;
            cursor: pointer;
            transition: background .2s ease, transform .15s ease;
            margin-top: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none
        }

        .fp-btn:hover { background: rgba(129, 155, 172, 1); transform: translateY(-2px) }
        .fp-btn:active { background: rgba(110, 138, 156, 1); transform: translateY(0) }
        .fp-btn:disabled { opacity: .6; cursor: not-allowed; transform: none }

        /* Next Step — G. Sei (Pure Blue), solid like Verify Access */
        .fp-btn--next {
            font-family: 'Quantico', sans-serif;
            background: var(--sei);
            border: none;
            color: var(--kurogane);
            transition: background 0.2s ease, transform 0.15s ease
        }
        .fp-btn--next:hover {
            background: rgba(129, 155, 172, 1);
            transform: translateY(-2px)
        }
        .fp-btn--next:active {
            background: rgba(110, 138, 156, 1);
            transform: translateY(0)
        }

        .fp-btn--ghost {
            background: transparent;
            border: 1px solid rgba(248,250,252,.28);
            color: rgba(248,250,252,.78)
        }

        .fp-btn--ghost:hover { background: rgba(248,250,252,.07); transform: translateY(-1px) }

        .fp-btn.loading {
            position: relative;
            color: transparent;
            pointer-events: none
        }

        .fp-btn.loading::after {
            content: '';
            position: absolute;
            width: 18px; height: 18px;
            top: 50%; left: 50%;
            margin: -9px 0 0 -9px;
            border: 2px solid transparent;
            border-top-color: var(--kurogane);
            border-radius: 50%;
            animation: spin .5s linear infinite
        }

        @keyframes spin { to { transform: rotate(360deg) } }

        .fp-nav { display: flex; gap: 12px; margin-top: 4px }
        .fp-nav .fp-btn { flex: 1; margin-top: 0 }

        /* Footer */
        .fp-foot {
            text-align: center;
            font-family: 'Antartida', sans-serif;
            font-size: var(--text-small);
            color: rgba(248,250,252,.42);
            margin-top: 2px
        }

        .fp-foot a {
            color: rgba(248,250,252,.68);
            text-decoration: underline;
            text-underline-offset: 3px
        }

        .fp-foot a:hover { color: var(--washi) }

        .fp-back {
            display: inline-flex;
            align-items: center;
            gap: 4px
        }

        .resend-link.disabled { opacity: .5; cursor: not-allowed; pointer-events: none }

        /* Password match */
        .fp-pw-match {
            font-size: var(--text-xs);
            min-height: 1rem;
            display: block
        }

        /* Success */
        .fp-success-icon {
            text-align: center;
            margin: 8px 0 14px;
            color: var(--sei)
        }

        .fp-success-icon svg { width: 52px; height: 52px }

        .fp-security {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 10px 14px;
            background: rgba(248,250,252,.04);
            border: 1px solid rgba(248,250,252,.09);
            font-size: var(--text-xs);
            color: rgba(248,250,252,.42);
            line-height: 1.5;
            margin-top: 4px
        }

        .fp-security svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; color: var(--kintsugi) }

        /* Notification */
        .notification {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            background: rgba(12,22,42,.95);
            border: 1px solid rgba(255,255,255,.10);
            backdrop-filter: blur(12px);
            font-family: 'Antartida', sans-serif;
            font-size: var(--text-small);
            font-weight: 500;
            z-index: 1000;
            transition: transform .3s ease
        }

        .notification.show { transform: translateX(-50%) translateY(0) }
        .notification svg { width: 18px; height: 18px; flex-shrink: 0 }
        .notification-success { border-left: 3px solid var(--sei); color: var(--sei) }
        .notification-error { border-left: 3px solid var(--kintsugi); color: var(--kintsugi) }
        .notification-warning { border-left: 3px solid #fbbf24; color: #fbbf24 }
        .notification-info { border-left: 3px solid var(--sei); color: var(--sei) }

        @media(max-width: 560px) {
            .fp-card-wrapper { width: calc(100% - 28px) }
            .fp-card { padding: 26px 20px }
            .fp-topbar { padding: 16px 20px }
            .fp-topbar__icon { height: 80px }
            .fp-topbar__link { left: 20px; font-size: var(--text-xs) }
            .fp-code-input { width: 40px; height: 48px; font-size: 1.2rem }
            .fp-pw-reqs ul { grid-template-columns: 1fr }
        }

        @media(max-width: 400px) {
            .fp-code-input { width: 36px; height: 44px; font-size: 1.1rem }
            .fp-code-wrap { gap: 5px }
        }
    </style>
</head>

<body>
    <div class="fp-page">
        <div class="fp-bg">
            <div class="fp-bg__photo"></div>
            <div class="fp-bg__overlay"></div>
      </div>

        <div class="fp-topbar">
            <img src="/images/brand/icon-gold.svg" alt="PartsForm" class="fp-topbar__icon">
            <a href="/" class="fp-topbar__link">&laquo; Back to Login</a>
      </div>

        <div class="fp-card-wrapper">
            <div class="fp-card">

                <div class="fp-brand">
                    <img src="/images/brand/logo-tagline-dark.png" alt="PartsForm" class="fp-brand__logo">
      </div>

                <div class="fp-steps">
                    <div class="fp-step active" id="step-dot-1">
                        <div class="fp-step__dot">1</div>
                        <div class="fp-step__label">Email</div>
                    </div>
                    <div class="fp-step__line"></div>
                    <div class="fp-step" id="step-dot-2">
                        <div class="fp-step__dot">2</div>
                        <div class="fp-step__label">Verify</div>
                    </div>
                    <div class="fp-step__line"></div>
                    <div class="fp-step" id="step-dot-3">
                        <div class="fp-step__dot">3</div>
                        <div class="fp-step__label">Reset</div>
                    </div>
                    <div class="fp-step__line"></div>
                    <div class="fp-step" id="step-dot-4">
                        <div class="fp-step__dot">4</div>
                        <div class="fp-step__label">Done</div>
      </div>
    </div>

                <div class="fp-error" id="fp-error"></div>
        
        <!-- Step 1: Enter Email -->
                <div class="fp-panel active" id="panel-1">
                    <div class="fp-panel-header">
            <h2>Forgot Password?</h2>
                        <p>Enter your <strong style="color:rgba(248,250,252,.70)">buyer account</strong> email and we'll send you a verification code.</p>
          </div>
                    <form id="emailForm">
                        <div class="fp-field">
                            <label class="fp-field__label">Email Address</label>
                            <div class="fp-input-wrap">
                                <i data-lucide="mail" class="fp-input-icon"></i>
                                <input type="email" id="email" name="email" class="fp-field__input" placeholder="you@company.com" required autocomplete="email">
          </div>
                            <span class="fp-field__error" id="emailError"></span>
              </div>
                        <button type="submit" class="fp-btn fp-btn--next" id="sendCodeBtn">
              <span class="btn-text">Send Verification Code</span>
                            <span class="btn-loader" style="display:none">Sending...</span>
            </button>
          </form>
                    <p class="fp-foot">Remember your password? <a href="/">Sign In</a></p>
        </div>

                <!-- Step 2: Verify Code -->
                <div class="fp-panel" id="panel-2">
                    <div class="fp-panel-header">
            <h2>Check Your Email</h2>
                        <p>We've sent a 6-digit verification code to:<br>
                        <span class="email-display"><strong id="displayEmail"></strong></span></p>
          </div>
                    <form id="verifyForm">
                        <div class="fp-field">
                            <label class="fp-field__label" style="text-align:center;display:block;margin-bottom:10px">Verification Code</label>
                            <div class="fp-code-wrap">
                                <input type="text" class="fp-code-input" id="code1" maxlength="1" pattern="[0-9]" inputmode="numeric" autocomplete="one-time-code">
                                <input type="text" class="fp-code-input" id="code2" maxlength="1" pattern="[0-9]" inputmode="numeric">
                                <input type="text" class="fp-code-input" id="code3" maxlength="1" pattern="[0-9]" inputmode="numeric">
                                <span class="fp-code-sep">—</span>
                                <input type="text" class="fp-code-input" id="code4" maxlength="1" pattern="[0-9]" inputmode="numeric">
                                <input type="text" class="fp-code-input" id="code5" maxlength="1" pattern="[0-9]" inputmode="numeric">
                                <input type="text" class="fp-code-input" id="code6" maxlength="1" pattern="[0-9]" inputmode="numeric">
          </div>
                            <span class="fp-field__error" id="codeError" style="text-align:center;display:block"></span>
              </div>
                        <div class="fp-timer">
                            <i data-lucide="clock" style="width:15px;height:15px;flex-shrink:0"></i>
              <span>Code expires in <strong id="countdownTimer">15:00</strong></span>
            </div>
                        <button type="submit" class="fp-btn fp-btn--next" id="verifyCodeBtn">
              <span class="btn-text">Verify Code</span>
                            <span class="btn-loader" style="display:none">Verifying...</span>
            </button>
          </form>
                    <div class="fp-foot">
                        <p>Didn't receive it? <a href="#" id="resendLink" class="resend-link">Resend Code</a></p>
                        <p style="margin-top:6px"><a href="#" class="fp-back" onclick="goToStep(1); return false;"><i data-lucide="arrow-left" style="width:13px;height:13px"></i> Change Email</a></p>
          </div>
        </div>

        <!-- Step 3: Reset Password -->
                <div class="fp-panel" id="panel-3">
                    <div class="fp-panel-header">
            <h2>Create New Password</h2>
                        <p>Identity verified. Set your new password below.</p>
          </div>
                    <form id="resetForm">
                        <div class="fp-field">
                            <label class="fp-field__label">New Password</label>
                            <div class="fp-input-wrap">
                                <i data-lucide="lock" class="fp-input-icon"></i>
                                <input type="password" id="newPassword" name="password" class="fp-field__input has-pw-toggle" placeholder="Create a strong password" required minlength="8">
                                <button type="button" class="fp-pw-toggle" onclick="togglePassword('newPassword')">
                                    <i data-lucide="eye" class="eye-icon" style="width:16px;height:16px"></i>
                                    <i data-lucide="eye-off" class="eye-off-icon" style="display:none;width:16px;height:16px"></i>
                </button>
              </div>
                            <div class="fp-pw-strength" id="passwordStrength">
                                <div class="fp-pw-bars">
                                    <span class="fp-pw-bar"></span>
                                    <span class="fp-pw-bar"></span>
                                    <span class="fp-pw-bar"></span>
                                    <span class="fp-pw-bar"></span>
                </div>
                                <span class="fp-pw-text">Password strength</span>
              </div>
                            <span class="fp-field__error" id="newPasswordError"></span>
            </div>
                        <div class="fp-field">
                            <label class="fp-field__label">Confirm New Password</label>
                            <div class="fp-input-wrap">
                                <i data-lucide="lock" class="fp-input-icon"></i>
                                <input type="password" id="confirmNewPassword" name="confirmPassword" class="fp-field__input has-pw-toggle" placeholder="Confirm your new password" required minlength="8">
                                <button type="button" class="fp-pw-toggle" onclick="togglePassword('confirmNewPassword')">
                                    <i data-lucide="eye" class="eye-icon" style="width:16px;height:16px"></i>
                                    <i data-lucide="eye-off" class="eye-off-icon" style="display:none;width:16px;height:16px"></i>
                </button>
              </div>
                            <span class="fp-pw-match" id="passwordMatch"></span>
                            <span class="fp-field__error" id="confirmNewPasswordError"></span>
            </div>
                        <button type="submit" class="fp-btn" id="resetPasswordBtn">
              <span class="btn-text">Reset Password</span>
                            <span class="btn-loader" style="display:none">Resetting...</span>
            </button>
          </form>
                    <div class="fp-pw-reqs">
            <p>Password requirements:</p>
            <ul>
                            <li id="req-length"><i data-lucide="circle" style="width:12px;height:12px;flex-shrink:0"></i> At least 8 characters</li>
                            <li id="req-upper"><i data-lucide="circle" style="width:12px;height:12px;flex-shrink:0"></i> One uppercase letter</li>
                            <li id="req-lower"><i data-lucide="circle" style="width:12px;height:12px;flex-shrink:0"></i> One lowercase letter</li>
                            <li id="req-number"><i data-lucide="circle" style="width:12px;height:12px;flex-shrink:0"></i> One number</li>
            </ul>
          </div>
        </div>

        <!-- Step 4: Success -->
                <div class="fp-panel" id="panel-4">
                    <div class="fp-panel-header">
                        <div class="fp-success-icon">
              <i data-lucide="check-circle-2"></i>
            </div>
            <h2>Password Reset Complete!</h2>
                        <p>Your password has been successfully changed. Sign in with your new password.</p>
          </div>
                    <a href="/" class="fp-btn">
                        <i data-lucide="log-in" style="width:18px;height:18px"></i>
                        Sign In Now
                    </a>
                    <a href="/" class="fp-btn fp-btn--ghost" style="margin-top:8px">
                        <i data-lucide="home" style="width:18px;height:18px"></i>
                        Back to Home
                    </a>
                    <div class="fp-security">
            <i data-lucide="shield"></i>
            <p>For your security, all other sessions have been logged out. You'll need to sign in again on other devices.</p>
          </div>
        </div>

      </div>
    </div>
    </div>

<script>
document.addEventListener('DOMContentLoaded', function() {
        if (typeof lucide !== 'undefined') lucide.createIcons();

  let currentStep = 1;
  let userEmail = '';
  let resetToken = '';
  let countdownInterval = null;
        let countdownSeconds = 15 * 60;

        const codeInputs = document.querySelectorAll('.fp-code-input');

  codeInputs.forEach((input, index) => {
            input.addEventListener('input', function() {
      this.value = this.value.replace(/[^0-9]/g, '');
      if (this.value.length === 1 && index < codeInputs.length - 1) {
        codeInputs[index + 1].focus();
      }
                if (getVerificationCode().length === 6) {
        document.getElementById('verifyCodeBtn').focus();
      }
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Backspace' && this.value === '' && index > 0) {
        codeInputs[index - 1].focus();
      }
    });

    input.addEventListener('paste', function(e) {
      e.preventDefault();
      const pastedData = (e.clipboardData || window.clipboardData).getData('text');
      const digits = pastedData.replace(/[^0-9]/g, '').split('');
                codeInputs.forEach((inp, i) => { if (digits[i]) inp.value = digits[i]; });
      if (digits.length >= 6) {
        document.getElementById('verifyCodeBtn').focus();
      } else {
                    const last = Math.min(digits.length - 1, codeInputs.length - 1);
                    codeInputs[last + 1]?.focus();
      }
    });
  });

  function getVerificationCode() {
            return Array.from(codeInputs).map(inp => inp.value).join('');
  }

        // Step 1: Email
  document.getElementById('emailForm').addEventListener('submit', async function(e) {
    e.preventDefault();
            userEmail = document.getElementById('email').value.trim();
            if (!userEmail) { showError('Please enter your email address'); return; }
            if (!isValidEmail(userEmail)) { showError('Please enter a valid email address'); return; }

    setLoading('sendCodeBtn', true);
            hideError();

    try {
                const res = await fetch('/forgot-password', {
        method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: userEmail })
                });
                const result = await res.json();

      if (result.success) {
        document.getElementById('displayEmail').textContent = userEmail;
        goToStep(2);
        startCountdown();
        if (result.rateLimit && result.rateLimit.nextDelay > 0) {
          startResendCooldown(result.rateLimit.nextDelay);
        }
      } else {
                    if (result.redirectUrl) {
                        showError(result.message);
                        setTimeout(function() { window.location.href = result.redirectUrl; }, 2500);
                    } else {
                        showError(result.message || 'Failed to send verification code');
                    }
                }
            } catch (err) {
                showError('An error occurred. Please try again.');
    } finally {
      setLoading('sendCodeBtn', false);
    }
  });

        // Step 2: Verify
  document.getElementById('verifyForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const code = getVerificationCode();
            if (code.length !== 6) { showError('Please enter the complete 6-digit code'); return; }

    setLoading('verifyCodeBtn', true);
            hideError();

    try {
                const res = await fetch('/forgot-password/verify', {
        method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: userEmail, code: code })
                });
                const result = await res.json();

      if (result.success) {
        resetToken = result.resetToken;
        stopCountdown();
        goToStep(3);
        document.getElementById('newPassword').focus();
      } else {
                    showError(result.message || 'Invalid verification code');
                    codeInputs.forEach(inp => inp.value = '');
        codeInputs[0].focus();
      }
            } catch (err) {
                showError('An error occurred. Please try again.');
    } finally {
      setLoading('verifyCodeBtn', false);
    }
  });

        // Step 3: Reset
  document.getElementById('resetForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const password = document.getElementById('newPassword').value;
    const confirmPassword = document.getElementById('confirmNewPassword').value;
            if (password.length < 8) { showError('Password must be at least 8 characters long'); return; }
            if (password !== confirmPassword) { showError('Passwords do not match'); return; }

    setLoading('resetPasswordBtn', true);
            hideError();

    try {
                const res = await fetch('/forgot-password/reset', {
        method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: userEmail, resetToken, password, confirmPassword })
                });
                const result = await res.json();

      if (result.success) {
        goToStep(4);
      } else {
                    showError(result.message || 'Failed to reset password');
      }
            } catch (err) {
                showError('An error occurred. Please try again.');
    } finally {
      setLoading('resetPasswordBtn', false);
    }
  });

        // Resend cooldown
  let resendCooldown = 0;
  let resendCooldownInterval = null;

  function startResendCooldown(seconds) {
    const resendLink = document.getElementById('resendLink');
    resendCooldown = seconds;
            if (resendCooldownInterval) clearInterval(resendCooldownInterval);
    resendLink.classList.add('disabled');
    updateResendLinkText();
    resendCooldownInterval = setInterval(() => {
      resendCooldown--;
      if (resendCooldown <= 0) {
        clearInterval(resendCooldownInterval);
        resendCooldownInterval = null;
        resendLink.classList.remove('disabled');
        resendLink.textContent = 'Resend Code';
      } else {
        updateResendLinkText();
      }
    }, 1000);
  }

  function updateResendLinkText() {
    const resendLink = document.getElementById('resendLink');
    if (resendCooldown > 60) {
                resendLink.textContent = `Resend in ${Math.ceil(resendCooldown / 60)}m`;
    } else if (resendCooldown > 0) {
      resendLink.textContent = `Resend in ${resendCooldown}s`;
    }
  }

  document.getElementById('resendLink').addEventListener('click', async function(e) {
    e.preventDefault();
    if (this.classList.contains('disabled')) return;
    this.classList.add('disabled');
            this.textContent = 'Sending...';

    try {
                const res = await fetch('/forgot-password/resend', {
        method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: userEmail })
                });
                const result = await res.json();

      if (result.success) {
                    codeInputs.forEach(inp => inp.value = '');
        codeInputs[0].focus();
        countdownSeconds = 15 * 60;
        startCountdown();
        let message = 'New verification code sent!';
        if (result.rateLimit && result.rateLimit.remainingAttempts <= 2) {
          message += ` (${result.rateLimit.remainingAttempts} attempts remaining)`;
        }
        showNotification(message, 'success');
        if (result.rateLimit && result.rateLimit.nextDelay > 0) {
          startResendCooldown(result.rateLimit.nextDelay);
        } else {
          this.classList.remove('disabled');
          this.textContent = 'Resend Code';
        }
      } else {
        if (result.retryAfter) {
          startResendCooldown(result.retryAfter);
                        showNotification(result.message, result.blocked ? 'error' : 'warning');
        } else {
          showNotification(result.message || 'Failed to resend code.', 'error');
          this.classList.remove('disabled');
          this.textContent = 'Resend Code';
        }
      }
            } catch (err) {
      showNotification('Failed to resend code. Please try again.', 'error');
      this.classList.remove('disabled');
      this.textContent = 'Resend Code';
    }
  });

        // Password strength
  const newPasswordInput = document.getElementById('newPassword');
  const confirmPasswordInput = document.getElementById('confirmNewPassword');
        const passwordMatchEl = document.getElementById('passwordMatch');

  newPasswordInput.addEventListener('input', function() {
    updatePasswordStrength(this.value);
    updatePasswordRequirements(this.value);
    checkPasswordMatch();
  });

  confirmPasswordInput.addEventListener('input', checkPasswordMatch);

  function updatePasswordStrength(password) {
            const bars = document.querySelectorAll('.fp-pw-bar');
            const text = document.querySelector('.fp-pw-text');
    let strength = 0;
    if (password.length >= 8) strength++;
    if (/[A-Z]/.test(password)) strength++;
    if (/[a-z]/.test(password)) strength++;
    if (/[0-9]/.test(password)) strength++;
    if (/[^A-Za-z0-9]/.test(password)) strength++;
    const colors = ['', 'var(--kintsugi)', '#f97316', '#eab308', 'var(--sei)', 'var(--sei)'];
            const levels = ['', 'Weak', 'Fair', 'Good', 'Strong', 'Very Strong'];
            bars.forEach((bar, i) => {
                bar.style.backgroundColor = i < strength ? colors[strength] : 'rgba(248,250,252,.15)';
            });
    text.textContent = password.length > 0 ? levels[strength] : 'Password strength';
            text.style.color = colors[strength] || 'rgba(248,250,252,.40)';
  }

  function updatePasswordRequirements(password) {
            const reqs = {
      'req-length': password.length >= 8,
      'req-upper': /[A-Z]/.test(password),
      'req-lower': /[a-z]/.test(password),
                'req-number': /[0-9]/.test(password)
    };
            Object.entries(reqs).forEach(([id, met]) => {
      const li = document.getElementById(id);
      if (!li) return;
      const icon = li.querySelector('i');
      if (!icon) return;
                li.classList.toggle('met', met);
                icon.setAttribute('data-lucide', met ? 'check-circle' : 'circle');
    });
    lucide.createIcons();
  }

  function checkPasswordMatch() {
    const password = newPasswordInput.value;
    const confirm = confirmPasswordInput.value;
    if (confirm.length > 0) {
      if (password === confirm) {
                    passwordMatchEl.textContent = '✓ Passwords match';
                    passwordMatchEl.style.color = 'var(--sei)';
      } else {
                    passwordMatchEl.textContent = '✗ Passwords do not match';
                    passwordMatchEl.style.color = 'var(--kintsugi)';
      }
    } else {
                passwordMatchEl.textContent = '';
    }
  }

        // Navigation
  window.goToStep = function(step) {
    currentStep = step;
            document.querySelectorAll('.fp-panel').forEach((p, i) => {
                p.classList.toggle('active', i + 1 === step);
            });
            document.querySelectorAll('.fp-step').forEach((d, i) => {
                d.classList.toggle('active', i + 1 === step);
                d.classList.toggle('done', i + 1 < step);
            });
    lucide.createIcons();
  };

        // Countdown
  function startCountdown() {
    stopCountdown();
    countdownSeconds = 15 * 60;
    updateCountdownDisplay();
    countdownInterval = setInterval(() => {
      countdownSeconds--;
      updateCountdownDisplay();
      if (countdownSeconds <= 0) {
        stopCountdown();
                    showError('Verification code expired. Please request a new one.');
      }
    }, 1000);
  }

  function stopCountdown() {
            if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
  }

  function updateCountdownDisplay() {
            const mins = Math.floor(countdownSeconds / 60);
            const secs = countdownSeconds % 60;
            const el = document.getElementById('countdownTimer');
            el.textContent = `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
            el.style.color = countdownSeconds <= 60 ? 'var(--kintsugi)' : countdownSeconds <= 180 ? '#fbbf24' : 'rgba(248,250,252,.60)';
        }

        // Utilities
  function isValidEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  function setLoading(btnId, loading) {
    const btn = document.getElementById(btnId);
    const btnText = btn.querySelector('.btn-text');
    const btnLoader = btn.querySelector('.btn-loader');
            if (btnText) btnText.style.display = loading ? 'none' : 'inline';
            if (btnLoader) btnLoader.style.display = loading ? 'inline' : 'none';
    btn.disabled = loading;
            if (loading) btn.classList.add('loading');
            else btn.classList.remove('loading');
        }

        function showError(message) {
            const el = document.getElementById('fp-error');
            el.textContent = message;
            el.classList.add('show');
        }

        function hideError() {
            document.getElementById('fp-error').classList.remove('show');
  }

  function showNotification(message, type = 'info') {
    const notification = document.createElement('div');
    notification.className = `notification notification-${type}`;
            const icons = { success: 'check-circle', error: 'alert-circle', warning: 'alert-triangle', info: 'info' };
            notification.innerHTML = `<i data-lucide="${icons[type] || 'info'}" style="width:18px;height:18px;flex-shrink:0"></i><span>${message}</span>`;
    document.body.appendChild(notification);
    lucide.createIcons();
    setTimeout(() => notification.classList.add('show'), 10);
    const duration = type === 'warning' ? 5000 : 3000;
    setTimeout(() => {
      notification.classList.remove('show');
      setTimeout(() => notification.remove(), 300);
    }, duration);
  }
});

function togglePassword(inputId) {
  const input = document.getElementById(inputId);
        const wrapper = input.closest('.fp-input-wrap');
  const eyeIcon = wrapper.querySelector('.eye-icon');
  const eyeOffIcon = wrapper.querySelector('.eye-off-icon');
  if (input.type === 'password') {
    input.type = 'text';
    eyeIcon.style.display = 'none';
    eyeOffIcon.style.display = 'block';
  } else {
    input.type = 'password';
    eyeIcon.style.display = 'block';
    eyeOffIcon.style.display = 'none';
  }
}
</script>
</body>

</html>
