<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#2B2B2B">
    <title>PartsForm | Supplier — Reset Password</title>
    <link rel="icon" type="image/png" href="/images/brand/icon-gold.png">
    <link rel="stylesheet" href="/css/brand-system.css">
    <script src="https://unpkg.com/lucide@0.294.0/dist/umd/lucide.min.js"></script>
    <style>
        @font-face { font-family: 'Quantico'; src: url('/fonts/Quantico/Quantico-Regular.ttf') format('truetype'); font-weight: 400; font-display: swap; }
        @font-face { font-family: 'Quantico'; src: url('/fonts/Quantico/Quantico-Bold.ttf') format('truetype'); font-weight: 700; font-display: swap; }
        @font-face { font-family: 'Antartida'; src: url('/fonts/Antartida/Antartida-Light.otf') format('opentype'); font-weight: 300; font-display: swap; }
        @font-face { font-family: 'Antartida'; src: url('/fonts/Antartida/Antartida-Medium.otf') format('opentype'); font-weight: 500; font-display: swap; }
        @font-face { font-family: 'Antartida'; src: url('/fonts/Antartida/Antartida-Bold.otf') format('opentype'); font-weight: 700; font-display: swap; }
        @font-face { font-family: 'Antartida'; src: url('/fonts/Antartida/Antartida-Black.otf') format('opentype'); font-weight: 900; font-display: swap; }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box }
        html, body { height: 100%; overflow: hidden }
        body { font-family: 'Antartida', sans-serif; font-weight: 500; color: var(--washi); -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale }

        .fp-page { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center }
        .fp-bg { position: absolute; inset: 0; z-index: 0 }
        .fp-bg__photo {
            position: absolute; inset: 0;
            background: url('/images/brand/moodboard/warehouse-hero.webp') center/cover no-repeat;
            filter: brightness(0.55) saturate(0.80)
        }
        .fp-bg__overlay {
            position: absolute; inset: 0;
            background: linear-gradient(180deg, rgba(10,18,35,.60) 0%, rgba(18,32,55,.45) 50%, rgba(10,18,35,.65) 100%)
        }

        .fp-topbar {
            position: absolute; top: 0; left: 0; right: 0; z-index: 10;
            display: flex; align-items: center; justify-content: center; padding: 24px 48px
        }
        .fp-topbar__icon { height: 140px; width: auto; display: block }
        .fp-topbar__link {
            position: absolute; left: 48px; top: 50%; transform: translateY(-50%);
            font-family: 'Antartida', sans-serif; font-size: var(--text-small); font-weight: 500;
            color: rgba(248,250,252,.80); text-decoration: underline; text-underline-offset: 4px;
            letter-spacing: .01em; transition: color .2s ease
        }
        .fp-topbar__link:hover { color: var(--washi) }

        /* Role badge */
        .fp-role-badge {
            position: absolute; right: 48px; top: 50%; transform: translateY(-50%);
            display: flex; align-items: center; gap: 8px;
            padding: 5px 12px 5px 8px;
            background: rgba(100,160,220,.10);
            border: 1px solid rgba(100,160,220,.30);
            font-family: 'Quantico', sans-serif;
            font-size: 0.65rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .08em;
            color: rgba(130,185,240,.90)
        }
        .fp-role-badge svg { width: 13px; height: 13px; stroke: rgba(130,185,240,.90) }

        .fp-card-wrapper {
            position: relative; z-index: 5;
            width: 500px;
            max-height: calc(100vh - 200px);
            overflow-y: auto; scrollbar-width: none
        }
        .fp-card-wrapper::-webkit-scrollbar { display: none }

        .fp-card {
            padding: 36px 48px;
            background: rgba(100,125,150,.22);
            backdrop-filter: blur(28px); -webkit-backdrop-filter: blur(28px);
            border: 1px solid rgba(255,255,255,.16);
            box-shadow: 0 20px 80px rgba(0,0,0,.55), inset 0 1px 0 rgba(255,255,255,.10);
            opacity: .93
        }

        .fp-brand { text-align: center; margin-bottom: 18px }
        .fp-brand__logo { width: 200px; height: auto }

        /* Steps */
        .fp-steps { display: flex; align-items: center; justify-content: center; margin-bottom: 20px }
        .fp-step { display: flex; flex-direction: column; align-items: center; gap: 4px }
        .fp-step__dot {
            width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
            border: 2px solid rgba(248,250,252,.22);
            font-family: 'Quantico', sans-serif; font-size: 13px; font-weight: 700;
            color: rgba(248,250,252,.35); transition: all .3s ease
        }
        .fp-step__label {
            font-family: 'Antartida', sans-serif; font-size: 10px; font-weight: 600;
            color: rgba(248,250,252,.32); letter-spacing: .07em; text-transform: uppercase; transition: all .3s ease
        }
        .fp-step.active .fp-step__dot { border-color: var(--kintsugi); color: var(--kintsugi); background: rgba(212,175,55,.10) }
        .fp-step.active .fp-step__label { color: var(--kintsugi) }
        .fp-step.done .fp-step__dot { border-color: rgba(212,175,55,.45); color: rgba(212,175,55,.55); background: rgba(212,175,55,.06) }
        .fp-step.done .fp-step__label { color: rgba(212,175,55,.50) }
        .fp-step__line { width: 48px; height: 1px; background: rgba(248,250,252,.16); margin: 0 8px; margin-bottom: 16px }

        /* Error */
        .fp-error {
            display: none; padding: 9px 14px; margin-bottom: 12px;
            font-family: 'Antartida', sans-serif; font-size: var(--text-xs); font-weight: 500;
            color: #fca5a5; background: rgba(220,38,38,.12); border: 1px solid rgba(220,38,38,.25)
        }
        .fp-error.show { display: block }

        /* Panels */
        .fp-panel { display: none; flex-direction: column; gap: 10px }
        .fp-panel.active { display: flex }

        .fp-panel-header { text-align: center; margin-bottom: 4px }
        .fp-panel-header h2 {
            font-family: 'Quantico', sans-serif; font-size: 1.05rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .08em; color: var(--washi); margin-bottom: 5px
        }
        .fp-panel-header p { font-family: 'Antartida', sans-serif; font-size: var(--text-small); color: rgba(248,250,252,.50); line-height: 1.5 }

        /* Fields */
        .fp-field { display: flex; flex-direction: column; gap: 5px }
        .fp-field__label {
            font-family: 'Quantico', sans-serif; font-size: 0.72rem; font-weight: 700;
            color: rgba(248,250,252,.82); letter-spacing: 0.07em; text-transform: uppercase
        }
        .fp-input-wrap { position: relative; display: flex; align-items: center }
        .fp-input-icon { position: absolute; left: 14px; width: 17px; height: 17px; color: rgba(248,250,252,.32); pointer-events: none }
        .fp-field__input {
            width: 100%; height: 48px; padding: 0 14px 0 42px;
            font-family: 'Antartida', sans-serif; font-size: .95rem; font-weight: 500; color: var(--washi);
            background: rgba(248,250,252,.06); border: 1px solid rgba(248,250,252,.18); border-radius: 0;
            outline: none; transition: border-color .2s ease, background .2s ease; -webkit-appearance: none; appearance: none
        }
        .fp-field__input::placeholder { color: rgba(248,250,252,.28) }
        .fp-field__input:focus { background: rgba(248,250,252,.09); border-color: rgba(149,175,192,.50) }
        .fp-field__input.has-pw-toggle { padding-right: 48px }

        /* Password toggle */
        .fp-pw-toggle {
            position: absolute; right: 0; top: 0; bottom: 0; width: 44px;
            display: flex; align-items: center; justify-content: center;
            background: none; border: none; cursor: pointer; color: rgba(248,250,252,.38); transition: color .2s
        }
        .fp-pw-toggle:hover { color: rgba(248,250,252,.78) }

        /* Password strength */
        .fp-pw-strength { display: flex; align-items: center; gap: 8px; margin-top: 6px }
        .fp-pw-bars { display: flex; gap: 4px }
        .fp-pw-bar { width: 34px; height: 3px; background: rgba(248,250,252,.15); transition: background .3s }
        .fp-pw-text { font-size: var(--text-xs); color: rgba(248,250,252,.40); transition: color .3s }

        /* Password requirements */
        .fp-pw-reqs { padding: 10px 14px; background: rgba(248,250,252,.04); border: 1px solid rgba(248,250,252,.09) }
        .fp-pw-reqs p { font-family: 'Antartida', sans-serif; font-size: var(--text-xs); font-weight: 600; color: rgba(248,250,252,.45); margin-bottom: 8px }
        .fp-pw-reqs ul { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 6px }
        .fp-pw-reqs li {
            font-family: 'Antartida', sans-serif; font-size: var(--text-xs); color: rgba(248,250,252,.32);
            display: flex; align-items: center; gap: 6px; transition: color .2s
        }
        .fp-pw-reqs li.met { color: #34d399 }

        /* Password match */
        .fp-pw-match { font-size: var(--text-xs); min-height: 1rem; display: block }

        /* Buttons */
        .fp-btn {
            width: 100%; height: 54px;
            font-family: 'Quantico', sans-serif; font-size: .95rem; font-weight: 900;
            text-transform: uppercase; letter-spacing: .10em;
            color: var(--kurogane); background: var(--kintsugi);
            border: none; border-radius: 0; cursor: pointer;
            transition: background .2s ease, transform .15s ease;
            margin-top: 4px; display: flex; align-items: center; justify-content: center;
            gap: 8px; text-decoration: none
        }
        .fp-btn:hover { background: var(--kintsugi-hover); transform: translateY(-1px) }
        .fp-btn:active { background: var(--kintsugi-active); transform: translateY(0) }
        .fp-btn:disabled { opacity: .6; cursor: not-allowed; transform: none }
        .fp-btn--ghost {
            background: transparent; border: 1px solid rgba(248,250,252,.28); color: rgba(248,250,252,.78)
        }
        .fp-btn--ghost:hover { background: rgba(248,250,252,.07); transform: translateY(-1px) }
        .fp-btn.loading { position: relative; color: transparent; pointer-events: none }
        .fp-btn.loading::after {
            content: ''; position: absolute; width: 18px; height: 18px; top: 50%; left: 50%;
            margin: -9px 0 0 -9px; border: 2px solid transparent; border-top-color: var(--kurogane);
            border-radius: 50%; animation: spin .5s linear infinite
        }
        @keyframes spin { to { transform: rotate(360deg) } }

        /* Check email state */
        .fp-check-email { text-align: center; padding: 10px 0 }
        .fp-check-email__icon { color: var(--kintsugi); margin-bottom: 14px }
        .fp-check-email__icon svg { width: 52px; height: 52px }
        .fp-check-email h3 {
            font-family: 'Quantico', sans-serif; font-size: 1rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .07em; color: var(--washi); margin-bottom: 10px
        }
        .fp-check-email p {
            font-family: 'Antartida', sans-serif; font-size: var(--text-small);
            color: rgba(248,250,252,.55); line-height: 1.6; margin-bottom: 6px
        }
        .fp-check-email .email-highlight {
            font-family: 'Antartida', sans-serif; font-size: var(--text-small); color: var(--kintsugi); font-weight: 600
        }
        .fp-check-email__note {
            display: flex; align-items: flex-start; gap: 9px; padding: 10px 13px; margin-top: 14px;
            background: rgba(248,250,252,.04); border: 1px solid rgba(248,250,252,.09);
            font-family: 'Antartida', sans-serif; font-size: var(--text-xs);
            color: rgba(248,250,252,.38); line-height: 1.5; text-align: left
        }
        .fp-check-email__note svg { width: 14px; height: 14px; flex-shrink: 0; margin-top: 1px; color: var(--kintsugi) }

        /* Success */
        .fp-success-icon { text-align: center; margin: 8px 0 14px; color: #34d399 }
        .fp-success-icon svg { width: 52px; height: 52px }
        .fp-security {
            display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px;
            background: rgba(248,250,252,.04); border: 1px solid rgba(248,250,252,.09);
            font-size: var(--text-xs); color: rgba(248,250,252,.42); line-height: 1.5; margin-top: 4px
        }
        .fp-security svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; color: var(--kintsugi) }

        /* Footer */
        .fp-foot {
            text-align: center; font-family: 'Antartida', sans-serif;
            font-size: var(--text-small); color: rgba(248,250,252,.42); margin-top: 2px
        }
        .fp-foot a { color: rgba(248,250,252,.68); text-decoration: underline; text-underline-offset: 3px }
        .fp-foot a:hover { color: var(--washi) }

        @media(max-width: 560px) {
            .fp-card-wrapper { width: calc(100% - 28px) }
            .fp-card { padding: 26px 20px }
            .fp-topbar { padding: 16px 20px }
            .fp-topbar__icon { height: 80px }
            .fp-topbar__link { left: 20px; font-size: var(--text-xs) }
            .fp-role-badge { display: none }
            .fp-pw-reqs ul { grid-template-columns: 1fr }
        }
    </style>
</head>
<body>
    <div class="fp-page">
        <div class="fp-bg">
            <div class="fp-bg__photo"></div>
            <div class="fp-bg__overlay"></div>
        </div>

        <div class="fp-topbar">
            <img src="/images/brand/icon-gold.svg" alt="PartsForm" class="fp-topbar__icon">
            <a href="/" class="fp-topbar__link">&laquo; Back to Login</a>
            <div class="fp-role-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="0"/><path d="M3 9h18M9 21V9"/>
                </svg>
                Supplier Account
            </div>
        </div>

        <div class="fp-card-wrapper">
            <div class="fp-card">

                <div class="fp-brand">
                    <img src="/images/brand/logo-tagline-dark.png" alt="PartsForm" class="fp-brand__logo">
                </div>

                <!-- Step indicators -->
                <div class="fp-steps">
                    <div class="fp-step active" id="step-dot-1">
                        <div class="fp-step__dot">1</div>
                        <div class="fp-step__label">Email</div>
                    </div>
                    <div class="fp-step__line"></div>
                    <div class="fp-step" id="step-dot-2">
                        <div class="fp-step__dot">2</div>
                        <div class="fp-step__label">Reset</div>
                    </div>
                    <div class="fp-step__line"></div>
                    <div class="fp-step" id="step-dot-3">
                        <div class="fp-step__dot">3</div>
                        <div class="fp-step__label">Done</div>
                    </div>
                </div>

                <div class="fp-error" id="fp-error"></div>

                <!-- Panel A: Enter email -->
                <div class="fp-panel active" id="panel-email">
                    <div class="fp-panel-header">
                        <h2>Forgot Password?</h2>
                        <p>Enter your supplier account email and we'll send you a reset link.</p>
                    </div>
                    <form id="emailForm">
                        <div class="fp-field">
                            <label class="fp-field__label">Email Address</label>
                            <div class="fp-input-wrap">
                                <i data-lucide="mail" class="fp-input-icon"></i>
                                <input type="email" id="email" name="email" class="fp-field__input" placeholder="you@company.com" required autocomplete="email">
                            </div>
                        </div>
                        <button type="submit" class="fp-btn" id="sendLinkBtn">
                            <span class="btn-text">Send Reset Link</span>
                            <span class="btn-loader" style="display:none">Sending...</span>
                        </button>
                    </form>
                    <p class="fp-foot">Remember your password? <a href="/">Sign In</a></p>
                </div>

                <!-- Panel B: Check email confirmation -->
                <div class="fp-panel" id="panel-check">
                    <div class="fp-check-email">
                        <div class="fp-check-email__icon">
                            <i data-lucide="mail-check"></i>
                        </div>
                        <h3>Check Your Email</h3>
                        <p>We've sent a reset link to:</p>
                        <p class="email-highlight" id="sentEmailDisplay"></p>
                        <p style="margin-top:10px">Click the link in the email to set your new password. The link expires in <strong style="color:rgba(248,250,252,.70)">1 hour</strong>.</p>
                        <div class="fp-check-email__note">
                            <i data-lucide="shield" style="width:14px;height:14px;flex-shrink:0;margin-top:1px;color:var(--kintsugi)"></i>
                            <span>If you don't see the email, check your spam folder. Contact your system administrator if the issue persists.</span>
                        </div>
                    </div>
                    <p class="fp-foot" style="margin-top:10px"><a href="#" onclick="showPanel('email'); return false;">&laquo; Use a different email</a></p>
                </div>

                <!-- Panel C: Reset password (shown when ?token= in URL) -->
                <div class="fp-panel" id="panel-reset">
                    <div class="fp-panel-header">
                        <h2>Set New Password</h2>
                        <p>Create a strong password for your supplier account.</p>
                    </div>
                    <form id="resetForm">
                        <div class="fp-field">
                            <label class="fp-field__label">New Password</label>
                            <div class="fp-input-wrap">
                                <i data-lucide="lock" class="fp-input-icon"></i>
                                <input type="password" id="newPassword" class="fp-field__input has-pw-toggle" placeholder="Create a strong password" required minlength="8">
                                <button type="button" class="fp-pw-toggle" onclick="togglePw('newPassword')">
                                    <i data-lucide="eye" class="eye-icon" style="width:16px;height:16px"></i>
                                    <i data-lucide="eye-off" class="eye-off-icon" style="display:none;width:16px;height:16px"></i>
                                </button>
                            </div>
                            <div class="fp-pw-strength" id="pwStrength">
                                <div class="fp-pw-bars">
                                    <span class="fp-pw-bar"></span><span class="fp-pw-bar"></span>
                                    <span class="fp-pw-bar"></span><span class="fp-pw-bar"></span>
                                </div>
                                <span class="fp-pw-text">Password strength</span>
                            </div>
                        </div>
                        <div class="fp-field">
                            <label class="fp-field__label">Confirm New Password</label>
                            <div class="fp-input-wrap">
                                <i data-lucide="lock" class="fp-input-icon"></i>
                                <input type="password" id="confirmPassword" class="fp-field__input has-pw-toggle" placeholder="Repeat your new password" required minlength="8">
                                <button type="button" class="fp-pw-toggle" onclick="togglePw('confirmPassword')">
                                    <i data-lucide="eye" class="eye-icon" style="width:16px;height:16px"></i>
                                    <i data-lucide="eye-off" class="eye-off-icon" style="display:none;width:16px;height:16px"></i>
                                </button>
                            </div>
                            <span class="fp-pw-match" id="pwMatch"></span>
                        </div>
                        <div class="fp-pw-reqs">
                            <p>Password requirements:</p>
                            <ul>
                                <li id="req-length"><i data-lucide="circle" style="width:12px;height:12px;flex-shrink:0"></i> At least 8 characters</li>
                                <li id="req-upper"><i data-lucide="circle" style="width:12px;height:12px;flex-shrink:0"></i> One uppercase letter</li>
                                <li id="req-lower"><i data-lucide="circle" style="width:12px;height:12px;flex-shrink:0"></i> One lowercase letter</li>
                                <li id="req-number"><i data-lucide="circle" style="width:12px;height:12px;flex-shrink:0"></i> One number</li>
                            </ul>
                        </div>
                        <button type="submit" class="fp-btn" id="resetBtn">
                            <span class="btn-text">Reset Password</span>
                            <span class="btn-loader" style="display:none">Resetting...</span>
                        </button>
                    </form>
                </div>

                <!-- Panel D: Success -->
                <div class="fp-panel" id="panel-done">
                    <div class="fp-panel-header">
                        <div class="fp-success-icon"><i data-lucide="check-circle-2"></i></div>
                        <h2>Password Reset!</h2>
                        <p>Your supplier account password has been changed. Sign in to continue.</p>
                    </div>
                    <a href="/" class="fp-btn">
                        <i data-lucide="log-in" style="width:18px;height:18px"></i>
                        Sign In Now
                    </a>
                    <div class="fp-security" style="margin-top:12px">
                        <i data-lucide="shield"></i>
                        <p>For your security, all previous supplier sessions have been invalidated.</p>
                    </div>
                </div>

            </div>
        </div>
    </div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof lucide !== 'undefined') lucide.createIcons();

    // Read token from URL
    var params   = new URLSearchParams(window.location.search);
    var urlToken = params.get('token');

    if (urlToken) {
        setStep(2);
        showPanel('reset');
    }

    // ── Step indicator ──────────────────────────────────────────────────
    function setStep(n) {
        document.querySelectorAll('.fp-step').forEach(function(el, i) {
            el.classList.toggle('active', i + 1 === n);
            el.classList.toggle('done',   i + 1 < n);
        });
        if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    window.showPanel = function(id) {
        document.querySelectorAll('.fp-panel').forEach(function(p) { p.classList.remove('active'); });
        document.getElementById('panel-' + id).classList.add('active');
        hideError();
    };

    // ── Send reset link (step 1) ─────────────────────────────────────────
    document.getElementById('emailForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        hideError();
        var email = document.getElementById('email').value.trim();
        if (!email) { showError('Please enter your email address.'); return; }

        setLoading('sendLinkBtn', true);
        try {
            var res  = await fetch('/api/supplier/auth/forgot-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: email })
            });
            var data = await res.json();
            if (data.success) {
                document.getElementById('sentEmailDisplay').textContent = email;
                setStep(2);
                showPanel('check');
            } else {
                showError(data.message || 'Failed to send reset link. Please try again.');
            }
        } catch (err) {
            showError('Connection error. Please check your network and try again.');
        } finally {
            setLoading('sendLinkBtn', false);
        }
    });

    // ── Reset password (token-based, step 2) ────────────────────────────
    var newPwInput  = document.getElementById('newPassword');
    var confPwInput = document.getElementById('confirmPassword');
    var pwMatchEl   = document.getElementById('pwMatch');

    newPwInput.addEventListener('input', function() {
        updateStrength(this.value);
        updateReqs(this.value);
        checkMatch();
    });
    confPwInput.addEventListener('input', checkMatch);

    document.getElementById('resetForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        hideError();
        var password = newPwInput.value;
        var confirm  = confPwInput.value;

        if (password.length < 8) { showError('Password must be at least 8 characters.'); return; }
        if (!(/[A-Z]/.test(password) && /[a-z]/.test(password) && /[0-9]/.test(password))) {
            showError('Please meet all password requirements.');
            return;
        }
        if (password !== confirm) { showError('Passwords do not match.'); return; }

        setLoading('resetBtn', true);
        try {
            var res  = await fetch('/api/supplier/auth/reset-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token: urlToken, password: password })
            });
            var data = await res.json();
            if (data.success) {
                setStep(3);
                showPanel('done');
            } else {
                showError(data.message || 'Failed to reset password. The link may have expired.');
            }
        } catch (err) {
            showError('Connection error. Please try again.');
        } finally {
            setLoading('resetBtn', false);
        }
    });

    // ── Strength + requirements ──────────────────────────────────────────
    function updateStrength(pw) {
        var bars   = document.querySelectorAll('.fp-pw-bar');
        var text   = document.querySelector('.fp-pw-text');
        var s = 0;
        if (pw.length >= 8)              s++;
        if (/[A-Z]/.test(pw))            s++;
        if (/[a-z]/.test(pw))            s++;
        if (/[0-9]/.test(pw))            s++;
        if (/[^A-Za-z0-9]/.test(pw))     s++;
        var colors = ['', '#ef4444', '#f97316', '#eab308', '#22c55e', '#10b981'];
        var labels = ['', 'Weak', 'Fair', 'Good', 'Strong', 'Very Strong'];
        bars.forEach(function(bar, i) {
            bar.style.backgroundColor = i < s ? colors[s] : 'rgba(248,250,252,.15)';
        });
        text.textContent = pw.length > 0 ? labels[s] : 'Password strength';
        text.style.color = colors[s] || 'rgba(248,250,252,.40)';
    }

    function updateReqs(pw) {
        var map = {
            'req-length': pw.length >= 8,
            'req-upper':  /[A-Z]/.test(pw),
            'req-lower':  /[a-z]/.test(pw),
            'req-number': /[0-9]/.test(pw)
        };
        Object.entries(map).forEach(function([id, met]) {
            var li   = document.getElementById(id);
            var icon = li && li.querySelector('i');
            if (!li || !icon) return;
            li.classList.toggle('met', met);
            icon.setAttribute('data-lucide', met ? 'check-circle' : 'circle');
        });
        if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    function checkMatch() {
        var pw = newPwInput.value, conf = confPwInput.value;
        if (conf.length > 0) {
            pwMatchEl.textContent = pw === conf ? '✓ Passwords match' : '✗ Passwords do not match';
            pwMatchEl.style.color = pw === conf ? '#34d399' : '#f87171';
        } else {
            pwMatchEl.textContent = '';
        }
    }

    // ── Utilities ────────────────────────────────────────────────────────
    function setLoading(id, loading) {
        var btn    = document.getElementById(id);
        var text   = btn.querySelector('.btn-text');
        var loader = btn.querySelector('.btn-loader');
        if (text)   text.style.display   = loading ? 'none' : 'inline';
        if (loader) loader.style.display = loading ? 'inline' : 'none';
        btn.disabled = loading;
        btn.classList.toggle('loading', loading);
    }
    function showError(msg) {
        var el = document.getElementById('fp-error');
        el.textContent = msg; el.classList.add('show');
    }
    function hideError() {
        document.getElementById('fp-error').classList.remove('show');
    }
});

function togglePw(id) {
    var input   = document.getElementById(id);
    var wrapper = input.closest('.fp-input-wrap');
    var eye     = wrapper.querySelector('.eye-icon');
    var eyeOff  = wrapper.querySelector('.eye-off-icon');
    if (input.type === 'password') {
        input.type = 'text'; eye.style.display = 'none'; eyeOff.style.display = 'block';
    } else {
        input.type = 'password'; eye.style.display = 'block'; eyeOff.style.display = 'none';
    }
}
</script>
</body>
</html>
