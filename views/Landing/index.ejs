<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#2B2B2B">
    <title>PartsForm | Access</title>
    <link rel="icon" type="image/png" href="/images/brand/icon-gold.png">
    <link rel="stylesheet" href="/css/brand-system.css">
    <style>
        @font-face {
            font-family: 'Quantico';
            src: url('/fonts/Quantico/Quantico-Regular.ttf') format('truetype');
            font-weight: 400; font-style: normal; font-display: swap;
        }
        @font-face {
            font-family: 'Quantico';
            src: url('/fonts/Quantico/Quantico-Bold.ttf') format('truetype');
            font-weight: 700; font-style: normal; font-display: swap;
        }
        @font-face {
            font-family: 'Antartida';
            src: url('/fonts/Antartida/Antartida-Light.otf') format('opentype');
            font-weight: 300; font-style: normal; font-display: swap;
        }
        @font-face {
            font-family: 'Antartida';
            src: url('/fonts/Antartida/Antartida-Medium.otf') format('opentype');
            font-weight: 500; font-style: normal; font-display: swap;
        }
        @font-face {
            font-family: 'Antartida';
            src: url('/fonts/Antartida/Antartida-Bold.otf') format('opentype');
            font-weight: 700; font-style: normal; font-display: swap;
        }
        @font-face {
            font-family: 'Antartida';
            src: url('/fonts/Antartida/Antartida-Black.otf') format('opentype');
            font-weight: 900; font-style: normal; font-display: swap;
        }

        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }
        
        html,
        body {
            height: 100%;
            overflow: hidden
        }
        
        body {
            font-family: 'Antartida', sans-serif;
            font-weight: 500;
            color: var(--washi);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale
        }
        
        .login-page {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center
        }
        
        .login-bg {
            position: absolute;
            inset: 0;
            z-index: 0
        }
        
        .login-bg__photo {
            position: absolute;
            inset: 0;
            background: url('/images/brand/moodboard/warehouse-hero.webp') center/cover no-repeat;
            filter: brightness(0.55) saturate(0.80)
        }
        
        .login-bg__overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(10, 18, 35, 0.60) 0%, rgba(18, 32, 55, 0.45) 50%, rgba(10, 18, 35, 0.65) 100%)
        }
        
        .login-topbar {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 28px 48px
        }
        
        .login-topbar__icon {
            height: 140px;
            width: auto;
            display: block
        }
        
        .login-topbar__link {
            position: absolute;
            right: 48px;
            top: 50%;
            transform: translateY(-50%);
            font-family: 'Antartida', sans-serif;
            font-size: var(--text-small);
            font-weight: 500;
            color: rgba(248, 250, 252, 0.80);
            text-decoration: underline;
            text-underline-offset: 4px;
            letter-spacing: 0.01em;
            transition: color 0.2s ease
        }
        
        .login-topbar__link:hover {
            color: var(--washi)
        }
        
        .login-topbar__link-arrows {
            margin-right: 4px;
            font-weight: 700
        }
        
        .login-card {
            position: relative;
            z-index: 5;
            width: 480px;
            padding: 72px 56px 68px;
            background: rgba(100, 125, 150, 0.22);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border: 1px solid rgba(255, 255, 255, 0.16);
            border-radius: 0;
            box-shadow: 0 24px 90px rgba(0, 0, 0, 0.58), inset 0 1px 0 rgba(255, 255, 255, 0.10);
            opacity: 0.93
        }
        
        .login-brand {
            text-align: center;
            margin-bottom: 38px;
            margin-top: -12px
        }
        
        .login-brand__logo {
            width: 300px;
            height: auto;
            margin-bottom: 0
        }
        
        .login-form {
            display: flex;
            flex-direction: column;
            gap: 0
        }
        
        .login-field {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 8px
        }
        
        .login-field--spaced {
            margin-bottom: 22px
        }
        
        .login-field__label {
            font-family: 'Quantico', sans-serif;
            font-size: 0.82rem;
            font-weight: 700;
            color: rgba(248, 250, 252, 0.88);
            letter-spacing: 0.07em;
            text-transform: uppercase
        }
        
        .login-field__input {
            width: 100%;
            height: 54px;
            padding: 0 18px;
            font-family: 'Antartida', sans-serif;
            font-size: 1.05rem;
            font-weight: 500;
            color: var(--washi);
            background: rgba(248, 250, 252, 0.06);
            border: 1px solid rgba(248, 250, 252, 0.18);
            border-radius: 0;
            outline: none;
            transition: border-color 0.2s ease, background 0.2s ease
        }
        
        .login-field__input::placeholder {
            color: rgba(248, 250, 252, 0.30)
        }
        
        .login-field__input:focus {
            background: rgba(248, 250, 252, 0.09);
            border-color: rgba(149, 175, 192, 0.50)
        }
        
        .login-field__link {
            display: block;
            text-align: right;
            margin-top: 8px;
            font-family: 'Antartida', sans-serif;
            font-size: 0.9rem;
            font-weight: 500;
            color: rgba(248, 250, 252, 0.70);
            text-decoration: underline;
            text-underline-offset: 3px;
            transition: color 0.2s ease
        }
        
        .login-field__link:hover {
            color: var(--washi)
        }

        /* Create Account Dropdown */
        .login-create-wrap {
            position: relative;
            display: flex;
            justify-content: flex-end;
            margin-top: 7px
        }

        .login-create-toggle {
            font-family: 'Antartida', sans-serif;
            font-size: 0.9rem;
            font-weight: 500;
            color: rgba(248, 250, 252, 0.70);
            text-decoration: underline;
            text-underline-offset: 3px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
            gap: 4px;
            transition: color 0.2s ease;
            letter-spacing: 0.01em
        }

        .login-create-toggle:hover { color: var(--washi) }

        .login-create-toggle svg {
            width: 12px;
            height: 12px;
            transition: transform 0.2s ease;
            flex-shrink: 0
        }

        .login-create-wrap.open .login-create-toggle { color: var(--washi) }
        .login-create-wrap.open .login-create-toggle svg { transform: rotate(180deg) }

        .login-create-menu {
            position: absolute;
            top: calc(100% + 6px);
            right: 0;
            width: 220px;
            background: rgba(12, 22, 46, 0.96);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.14);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.55);
            z-index: 100;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-6px);
            transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease
        }

        .login-create-wrap.open .login-create-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0)
        }

        .login-create-menu__item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 13px 16px;
            text-decoration: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.07);
            transition: background 0.15s ease
        }

        .login-create-menu__item:last-child { border-bottom: none }

        .login-create-menu__item:hover {
            background: rgba(212, 175, 55, 0.08)
        }

        .login-create-menu__icon {
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(212, 175, 55, 0.10);
            border: 1px solid rgba(212, 175, 55, 0.22);
            flex-shrink: 0;
            color: var(--kintsugi)
        }

        .login-create-menu__icon svg { width: 16px; height: 16px }

        .login-create-menu__text { display: flex; flex-direction: column; gap: 2px }

        .login-create-menu__title {
            font-family: 'Quantico', sans-serif;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: var(--washi)
        }

        .login-create-menu__desc {
            font-family: 'Antartida', sans-serif;
            font-size: 0.7rem;
            color: rgba(248, 250, 252, 0.42);
            line-height: 1.3
        }

        /* Forgot Password Dropdown (mirrors Create Account dropdown) */
        .login-fp-wrap {
            position: relative;
            display: inline-block;
            margin-top: 8px;
            align-self: flex-end
        }

        .login-fp-toggle {
            font-family: 'Antartida', sans-serif;
            font-size: 0.9rem;
            font-weight: 500;
            color: rgba(248, 250, 252, 0.70);
            text-decoration: underline;
            text-underline-offset: 3px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
            gap: 4px;
            transition: color 0.2s ease;
            letter-spacing: 0.01em
        }

        .login-fp-toggle:hover { color: var(--washi) }

        .login-fp-toggle svg {
            width: 12px;
            height: 12px;
            transition: transform 0.2s ease;
            flex-shrink: 0
        }

        .login-fp-wrap.open .login-fp-toggle { color: var(--washi) }
        .login-fp-wrap.open .login-fp-toggle svg { transform: rotate(180deg) }

        .login-fp-menu {
            position: absolute;
            bottom: calc(100% + 6px);
            right: 0;
            width: 230px;
            background: rgba(12, 22, 46, 0.96);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.14);
            box-shadow: 0 -10px 36px rgba(0, 0, 0, 0.55);
            z-index: 100;
            opacity: 0;
            visibility: hidden;
            transform: translateY(6px);
            transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease
        }

        .login-fp-wrap.open .login-fp-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0)
        }

        .login-fp-menu__item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            text-decoration: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.07);
            transition: background 0.15s ease
        }

        .login-fp-menu__item:last-child { border-bottom: none }
        .login-fp-menu__item:hover { background: rgba(212, 175, 55, 0.08) }

        .login-fp-menu__icon {
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(248, 250, 252, 0.06);
            border: 1px solid rgba(248, 250, 252, 0.12);
            flex-shrink: 0;
            color: rgba(248, 250, 252, 0.55)
        }

        .login-fp-menu__icon svg { width: 14px; height: 14px }

        .login-fp-menu__text { display: flex; flex-direction: column; gap: 1px }

        .login-fp-menu__title {
            font-family: 'Quantico', sans-serif;
            font-size: 0.70rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: var(--washi)
        }

        .login-fp-menu__desc {
            font-family: 'Antartida', sans-serif;
            font-size: 0.68rem;
            color: rgba(248, 250, 252, 0.38);
            line-height: 1.3
        }

        .login-btn {
            margin-top: 28px;
            width: 100%;
            height: 62px;
            font-family: 'Quantico', sans-serif;
            font-size: 1.05rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.13em;
            color: var(--kurogane);
            background: var(--kintsugi);
            border: none;
            border-radius: 0;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.15s ease
        }
        
        .login-btn:hover {
            background: var(--kintsugi-hover);
            transform: translateY(-2px)
        }
        
        .login-btn:active {
            background: var(--kintsugi-active);
            transform: translateY(0)
        }
        
        .login-error {
            display: none;
            padding: 11px 16px;
            margin-bottom: 12px;
            font-family: 'Antartida', sans-serif;
            font-size: 0.82rem;
            font-weight: 500;
            color: #fca5a5;
            background: rgba(220, 38, 38, 0.12);
            border: 1px solid rgba(220, 38, 38, 0.25);
            border-radius: 0
        }
        
        .login-error.show {
            display: block;
            animation: shake 0.4s ease
        }
        
        @keyframes shake {
            0%,
            100% {
                transform: translateX(0)
            }
            20%,
            60% {
                transform: translateX(-4px)
            }
            40%,
            80% {
                transform: translateX(4px)
            }
        }
        
        .login-btn.loading {
            position: relative;
            color: transparent;
            pointer-events: none
        }
        
        .login-btn.loading::after {
            content: '';
            position: absolute;
            width: 18px;
            height: 18px;
            top: 50%;
            left: 50%;
            margin: -9px 0 0 -9px;
            border: 2px solid transparent;
            border-top-color: var(--kurogane);
            border-radius: 50%;
            animation: spin 0.5s linear infinite
        }
        
        @keyframes spin {
            to {
                transform: rotate(360deg)
            }
        }
        
        @media(max-width:560px) {
            .login-card {
                width: calc(100% - 32px);
                max-width: 480px;
                padding: 52px 28px 48px
            }
            .login-topbar {
                padding: 20px 20px
            }
            .login-topbar__icon {
                height: 72px
            }
            .login-topbar__link {
                right: 20px;
                font-size: var(--text-xs)
            }
            .login-brand__logo {
                width: 240px
            }
        }

        /* ── Change-password panel (for supplier first-login) ── */
        .chpw-card {
            display: none;
            position: relative;
            z-index: 5;
            width: 480px;
            padding: 60px 56px 56px;
            background: rgba(100, 125, 150, 0.22);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 24px 90px rgba(0, 0, 0, 0.58), inset 0 1px 0 rgba(255, 255, 255, 0.10)
        }
        .chpw-card.visible { display: block }

        .chpw-title {
            font-family: 'Quantico', sans-serif;
            font-size: 1.35rem;
            font-weight: 700;
            color: var(--washi);
            letter-spacing: 0.04em;
            text-transform: uppercase;
            margin-bottom: 6px
        }

        .chpw-sub {
            font-family: 'Antartida', sans-serif;
            font-size: 0.82rem;
            color: rgba(248, 250, 252, 0.55);
            line-height: 1.5;
            margin-bottom: 32px
        }

        .chpw-notice {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 11px 14px;
            background: rgba(212, 175, 55, 0.08);
            border: 1px solid rgba(212, 175, 55, 0.22);
            margin-bottom: 28px;
            font-family: 'Antartida', sans-serif;
            font-size: 0.78rem;
            color: rgba(212, 175, 55, 0.85);
            line-height: 1.5
        }

        .chpw-notice svg { flex-shrink: 0; margin-top: 1px }

        .chpw-reqs {
            margin-top: 10px;
            padding: 12px 14px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08)
        }

        .chpw-reqs__title {
            font-family: 'Quantico', sans-serif;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(248, 250, 252, 0.40);
            margin-bottom: 8px
        }

        .chpw-req {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'Antartida', sans-serif;
            font-size: 0.76rem;
            color: rgba(248, 250, 252, 0.40);
            margin-bottom: 4px;
            transition: color 0.2s
        }

        .chpw-req svg { width: 12px; height: 12px; flex-shrink: 0 }

        .chpw-req.met {
            color: #6ee7b7
        }

        .chpw-req.met svg { stroke: #6ee7b7 }

        .chpw-input-wrap {
            position: relative;
            display: flex;
            align-items: center
        }
        .chpw-input-wrap .login-field__input {
            padding-right: 48px
        }
        .chpw-pw-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
            color: rgba(248, 250, 252, 0.5);
            transition: color 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center
        }
        .chpw-pw-toggle:hover { color: rgba(248, 250, 252, 0.85) }
        .chpw-pw-toggle svg { width: 18px; height: 18px; flex-shrink: 0 }

        @media(max-width:560px) {
            .chpw-card { width: calc(100% - 32px); max-width: 480px; padding: 44px 28px 40px }
        }
    </style>
</head>

<body>
    <div class="login-page">
        <div class="login-bg">
            <div class="login-bg__photo"></div>
            <div class="login-bg__overlay"></div>
        </div>
        <div class="login-topbar">
            <img src="/images/brand/icon-gold.svg" alt="PartsForm" class="login-topbar__icon">
            <a href="/buyer/about-us" class="login-topbar__link"><span class="login-topbar__link-arrows">&raquo;</span> Go to Website</a>
        </div>
        <!-- Main login card -->
        <div class="login-card" id="login-card">
            <div class="login-brand">
                <img src="/images/brand/logo-tagline-dark.png" alt="PartsForm" class="login-brand__logo">
            </div>
            <div class="login-error" id="login-error"></div>
            <form class="login-form" id="login-form" autocomplete="on">
                <div class="login-field">
                    <label class="login-field__label" for="username">Email</label>
                    <input class="login-field__input" type="text" id="username" name="username" placeholder="Enter your email" autocomplete="email" required>
                    <div class="login-create-wrap" id="createAccWrap">
                        <button type="button" class="login-create-toggle" id="createAccToggle">
                            Create Account
                            <svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 1.5l5 5 5-5"/>
                            </svg>
                        </button>
                        <div class="login-create-menu" id="createAccMenu">
                            <a href="/register" class="login-create-menu__item">
                                <div class="login-create-menu__icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="7" width="20" height="14" rx="0"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/>
                                    </svg>
                                </div>
                                <div class="login-create-menu__text">
                                    <span class="login-create-menu__title">As Business</span>
                                    <span class="login-create-menu__desc">Buy parts &amp; manage orders</span>
                                </div>
                            </a>
                            <a href="/become-partner" class="login-create-menu__item">
                                <div class="login-create-menu__icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                    </svg>
                                </div>
                                <div class="login-create-menu__text">
                                    <span class="login-create-menu__title">As Partner</span>
                                    <span class="login-create-menu__desc">Refer &amp; earn commissions</span>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="login-field login-field--spaced">
                    <label class="login-field__label" for="password">Password</label>
                    <input class="login-field__input" type="password" id="password" name="password" placeholder="Enter your password" autocomplete="current-password" required>
                    <div class="login-fp-wrap" id="fpDropWrap">
                        <button type="button" class="login-fp-toggle" id="fpDropToggle">
                            Forgot Password
                            <svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 1.5l5 5 5-5"/>
                            </svg>
                        </button>
                        <div class="login-fp-menu" id="fpDropMenu">
                            <a href="/forgot-password" class="login-fp-menu__item">
                                <div class="login-fp-menu__icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="7" width="20" height="14" rx="0"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/>
                                    </svg>
                                </div>
                                <div class="login-fp-menu__text">
                                    <span class="login-fp-menu__title">As Business</span>
                                    <span class="login-fp-menu__desc">Buyer</span>
                                </div>
                            </a>
                            <a href="/forgot-password/partner" class="login-fp-menu__item">
                                <div class="login-fp-menu__icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                    </svg>
                                </div>
                                <div class="login-fp-menu__text">
                                    <span class="login-fp-menu__title">As Partner</span>
                                    <span class="login-fp-menu__desc">Referral partner account</span>
                                </div>
                            </a>
                            <a href="/forgot-password/supplier" class="login-fp-menu__item">
                                <div class="login-fp-menu__icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="3" width="18" height="18" rx="0"/><path d="M3 9h18M9 21V9"/>
                                    </svg>
                                </div>
                                <div class="login-fp-menu__text">
                                    <span class="login-fp-menu__title">As Supplier</span>
                                    <span class="login-fp-menu__desc">Supplier portal account</span>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
                <button type="submit" class="login-btn" id="login-btn">Verify Access</button>
            </form>
        </div>

        <!-- Supplier first-login: set new password (shown when mustChangePassword) -->
        <div class="chpw-card" id="chpw-card">
            <p class="chpw-title">Set New Password</p>
            <p class="chpw-sub">Your account requires a password change before you can continue.</p>
            <div class="chpw-notice">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>First login — set a strong permanent password to secure your account.</span>
            </div>
            <div class="login-error" id="chpw-error"></div>
            <form class="login-form" id="chpw-form" autocomplete="off">
                <div class="login-field login-field--spaced">
                    <label class="login-field__label" for="chpw-new">New Password</label>
                    <div class="chpw-input-wrap">
                        <input class="login-field__input" type="password" id="chpw-new" placeholder="Min. 8 characters" autocomplete="new-password" required minlength="8">
                        <button type="button" class="chpw-pw-toggle" onclick="toggleChpwPassword('chpw-new')" title="Show password" aria-label="Toggle password visibility">
                            <svg class="chpw-eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg class="chpw-eye-off-icon" style="display:none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        </button>
                    </div>
                    <div class="chpw-reqs" id="chpw-reqs">
                        <p class="chpw-reqs__title">Requirements</p>
                        <div class="chpw-req" id="req-len">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                            At least 8 characters
                        </div>
                        <div class="chpw-req" id="req-upper">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                            One uppercase letter
                        </div>
                        <div class="chpw-req" id="req-lower">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                            One lowercase letter
                        </div>
                        <div class="chpw-req" id="req-num">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                            One number
                        </div>
                    </div>
                </div>
                <div class="login-field login-field--spaced">
                    <label class="login-field__label" for="chpw-confirm">Confirm Password</label>
                    <div class="chpw-input-wrap">
                        <input class="login-field__input" type="password" id="chpw-confirm" placeholder="Repeat new password" autocomplete="new-password" required>
                        <button type="button" class="chpw-pw-toggle" onclick="toggleChpwPassword('chpw-confirm')" title="Show password" aria-label="Toggle password visibility">
                            <svg class="chpw-eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg class="chpw-eye-off-icon" style="display:none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        </button>
                    </div>
                </div>
                <button type="submit" class="login-btn" id="chpw-btn">Set Password &amp; Enter</button>
            </form>
        </div>
    </div>
    <script>
        // ── Create Account dropdown ──────────────────────────────────────
        var createWrap   = document.getElementById('createAccWrap');
        var createToggle = document.getElementById('createAccToggle');

        createToggle.addEventListener('click', function(e) {
            e.stopPropagation();
            fpDropWrap.classList.remove('open'); // close FP if open
            createWrap.classList.toggle('open');
        });
        document.getElementById('createAccMenu').addEventListener('click', function(e) {
            e.stopPropagation();
        });

        // ── Forgot Password dropdown ─────────────────────────────────────
        var fpDropWrap   = document.getElementById('fpDropWrap');
        var fpDropToggle = document.getElementById('fpDropToggle');

        fpDropToggle.addEventListener('click', function(e) {
            e.stopPropagation();
            createWrap.classList.remove('open'); // close Create if open
            fpDropWrap.classList.toggle('open');
        });
        document.getElementById('fpDropMenu').addEventListener('click', function(e) {
            e.stopPropagation();
        });

        document.addEventListener('click', function() {
            createWrap.classList.remove('open');
            fpDropWrap.classList.remove('open');
        });

        // ── Helpers ──────────────────────────────────────────────────────
        var supplierTempToken = null;

        function showError(elId, msg) {
            var el = document.getElementById(elId);
            el.textContent = msg;
            el.classList.add('show');
        }
        function clearError(elId) {
            var el = document.getElementById(elId);
            el.textContent = '';
            el.classList.remove('show');
        }
        function setLoading(btnId, yes) {
            document.getElementById(btnId).classList.toggle('loading', yes);
        }

        // ── Main login form ──────────────────────────────────────────────
        document.getElementById('login-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            clearError('login-error');
            var email = document.getElementById('username').value.trim();
            var password = document.getElementById('password').value;

            if (!email || !password) {
                showError('login-error', 'Please enter your email and password.');
                return;
            }
            setLoading('login-btn', true);
            try {
                var res = await fetch('/api/unified-login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email, password: password })
                });
                var data = await res.json();

                if (!res.ok || !data.success) {
                    showError('login-error', data.message || 'Invalid credentials. Please try again.');
                    setLoading('login-btn', false);
                    return;
                }

                // Supplier first-login: must change password
                if (data.requirePasswordChange && data.tempToken) {
                    supplierTempToken = data.tempToken;
                    document.getElementById('login-card').style.display = 'none';
                    document.getElementById('chpw-card').classList.add('visible');
                    document.getElementById('chpw-new').focus();
                    setLoading('login-btn', false);
                    return;
                }

                // Normal redirect
                var redirectUrl = (data.data && data.data.redirectUrl) || data.redirect || '/';
                window.location.href = redirectUrl;

            } catch (err) {
                showError('login-error', 'Connection error. Please check your network and try again.');
                setLoading('login-btn', false);
            }
        });

        // ── Change-password panel (supplier first-login) ─────────────────
        var chpwNew     = document.getElementById('chpw-new');
        var reqLen      = document.getElementById('req-len');
        var reqUpper    = document.getElementById('req-upper');
        var reqLower    = document.getElementById('req-lower');
        var reqNum      = document.getElementById('req-num');

        var CHECK_SVG  = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        var CIRCLE_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>';

        function setReq(el, met) {
            el.classList.toggle('met', met);
            el.querySelector('svg').outerHTML; // force repaint trick not needed — swap innerHTML
            el.innerHTML = (met ? CHECK_SVG : CIRCLE_SVG) + el.textContent;
        }

        function validateChpw(password) {
            var rules = {
                'req-len':   password.length >= 8,
                'req-upper': /[A-Z]/.test(password),
                'req-lower': /\p{Ll}/u.test(password),
                'req-num':   /[0-9]/.test(password)
            };
            var labels = { 'req-len': 'At least 8 characters', 'req-upper': 'One uppercase letter', 'req-lower': 'One lowercase letter', 'req-num': 'One number' };
            Object.entries(rules).forEach(function([id, met]) {
                var el = document.getElementById(id);
                el.classList.toggle('met', met);
                var text = labels[id] || (el.childNodes[el.childNodes.length - 1] && el.childNodes[el.childNodes.length - 1].textContent ? el.childNodes[el.childNodes.length - 1].textContent.trim() : '');
                el.innerHTML = (met ? CHECK_SVG : CIRCLE_SVG) + ' ' + text;
            });
            return Object.values(rules).every(Boolean);
        }

        function toggleChpwPassword(inputId) {
            var input = document.getElementById(inputId);
            var wrap = input.closest('.chpw-input-wrap');
            var eyeIcon = wrap.querySelector('.chpw-eye-icon');
            var eyeOffIcon = wrap.querySelector('.chpw-eye-off-icon');
            if (input.type === 'password') {
                input.type = 'text';
                eyeIcon.style.display = 'none';
                eyeOffIcon.style.display = 'block';
            } else {
                input.type = 'password';
                eyeIcon.style.display = 'block';
                eyeOffIcon.style.display = 'none';
            }
        }

        chpwNew.addEventListener('input', function() {
            validateChpw(chpwNew.value);
        });

        document.getElementById('chpw-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            clearError('chpw-error');
            var newPw  = document.getElementById('chpw-new').value;
            var confPw = document.getElementById('chpw-confirm').value;

            if (!validateChpw(newPw)) {
                showError('chpw-error', 'Please meet all password requirements.');
                return;
            }
            if (newPw !== confPw) {
                showError('chpw-error', 'Passwords do not match.');
                return;
            }
            setLoading('chpw-btn', true);
            try {
                var res = await fetch('/api/supplier/auth/change-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + supplierTempToken
                    },
                    body: JSON.stringify({ newPassword: newPw })
                });
                var data = await res.json();
                if (!res.ok || !data.success) {
                    showError('chpw-error', data.message || 'Failed to update password. Please try again.');
                    setLoading('chpw-btn', false);
                    return;
                }
                // Store new supplier token and redirect
                if (data.token) {
                    localStorage.setItem('supplierToken', data.token);
                    document.cookie = 'supplierToken=' + data.token + '; path=/; max-age=' + (30 * 24 * 60 * 60) + '; SameSite=Lax';
                }
                window.location.href = '/supplier';
            } catch (err) {
                showError('chpw-error', 'Connection error. Please try again.');
                setLoading('chpw-btn', false);
            }
        });
    </script>
</body>

</html>